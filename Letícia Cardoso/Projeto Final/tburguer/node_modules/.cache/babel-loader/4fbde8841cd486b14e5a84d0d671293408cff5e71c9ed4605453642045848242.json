roduct-info\">\r\n            <h4 class=\"product-name\">Cappuccino Trufado</h4>\r\n            <p class=\"product-description\">Expresso blend da casa, leite cremoso vaporizado e uma camada generosa de ganache de chocolate belga.</p>\r\n            <div class=\"product-footer\">\r\n              <span class=\"product-price\">R$ 16,90</span>\r\n              <button class=\"btn-add-product\">+</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"product-card\">\r\n          <div class=\"product-image-container\">\r\n            <img src=\"@/assets/iced-latte.jpg\" alt=\"Iced Caramel Latte\" />\r\n          </div>\r\n          <div class=\"product-info\">\r\n            <h4 class=\"product-name\">Iced Caramel Latte</h4>\r\n            <p class=\"product-description\">Café extraído a frio batido com leite gelado, cubos de gelo de café e calda artesanal de caramelo salgado.</p>\r\n            <div class=\"product-footer\">\r\n              <span class=\"product-price\">R$ 18,50</span>\r\n              <button class=\"btn-add-product\">+</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"product-card\">\r\n          <div class=\"product-badge\">Fresco</div>\r\n          <div class=\"product-image-container\">\r\n            <img src=\"@/assets/croissant.jpg\" alt=\"Croissant de Amêndoas\" />\r\n          </div>\r\n          <div class=\"product-info\">\r\n            <h4 class=\"product-name\">Croissant de Amêndoas</h4>\r\n            <p class=\"product-description\">Massa folhada francesa super crocante por fora, recheada com creme de frangipane e lascas de amêndoas tostadas.</p>\r\n            <div class=\"product-footer\">\r\n              <span class=\"product-price\">R$ 21,00</span>\r\n              <button class=\"btn-add-product\">+</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n  </div>\r\n</template>\r\n\r\n<script