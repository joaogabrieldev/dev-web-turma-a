tle\">Destaques da Semana</h2>\r\n        <p class=\"section-subtitle\">As joias do nosso cardápio que você precisa experimentar</p>\r\n      </div>\r\n\r\n      <div class=\"highlights-grid\">\r\n        <div class=\"highlight-card\">\r\n          <div class=\"card-tag popular\">Mais Pedido</div>\r\n          <div class=\"card-image\">\r\n            <img src=\"https://images.pexels.com/photos/2620242/pexels-photo-2620242.jpeg?auto=compress&cs=tinysrgb&w=600\" alt=\"Cappuccino Italiano\" />\r\n          </div>\r\n          <div class=\"card-content\">\r\n            <h3>Cappuccino Italiano</h3>\r\n            <p>Dose de espresso blend da casa, leite vaporizado e uma camada sedosa de espuma.</p>\r\n            <div class=\"card-footer\">\r\n              <span class=\"price\">R$ 12,00</span>\r\n              <button @click=\"irParaConfigurar('Cappuccino Italiano', '12.00', 'cafes', 'https://images.pexels.com/photos/2620242/pexels-photo-2620242.jpeg?auto=compress&cs=tinysrgb&w=600')\" class=\"btn-card\">Pedir</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"highlight-card\">\r\n          <div class=\"card-tag novo\">Novo no Cardápio</div>\r\n          <div class=\"card-image\">\r\n            <img src=\"https://images.pexels.com/photos/5419190/pexels-photo-5419190.jpeg?auto=compress&cs=tinysrgb&w=600\" alt=\"Cinnamon Roll\" />\r\n          </div>\r\n          <div class=\"card-content\">\r\n            <h3>Cinnamon Roll</h3>\r\n            <p>Caracol de massa doce folhada com recheio denso de canela e calda leve de glacê.</p>\r\n            <div class=\"card-footer\">\r\n              <span class=\"price\">R$ 12,50</span>\r\n              <button @click=\"irParaConfigurar('Cinnamon Roll', '12.50', 'lanches', 'https://images.pexels.com/photos/5419190/pexels-photo-5419190.jpeg?auto=compress&cs=tinysrgb&w=600')\" class=\"btn-card\">Pedir</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"highlight-card\">\r\n          <div class=\"card-tag popular\">Mais Pedido</div>\r\n          <div class=\"card-image\">\r\n            <img src=\"https://images.pexels.com/photos/36326967/pexels-photo-36326967.jpeg?auto=compress&cs=tinysrgb&w=600\" alt=\"Croissant de Manteiga\" />\r\n          </div>\r\n          <div class=\"card-content\">\r\n            <h3>Croissant de Manteiga</h3>\r\n            <p>Folhado francês clássico, crocante por fora e incrivelmente macio por dentro.</p>\r\n            <div class=\"card-footer\">\r\n              <span class=\"price\">R$ 11,00</span>\r\n              <button @click=\"irParaConfigurar('Croissant de Manteiga', '11.00', 'lanches', 'https://images.pexels.com/photos/36326967/pexels-photo-36326967.jpeg?auto=compress&cs=tinysrgb&w=600')\" class=\"btn-card\">Pedir</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <section class=\"cta-section\">\r\n      <div class=\"cta-box\">\r\n        <h2>Deseja explorar a experiência completa?</h2>\r\n        <p>Acesse nosso cardápio digital completo e monte o seu pedido personalizado como preferir.</p>\r\n        <router-link to=\"/menu\" class=\"btn-cta-menu\">Explorar Cardápio Completo →</router-link>\r\n      </div>\r\n    </section>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport BannerComponent from \"@/components/BannerComponent.vue\";\r\n\r\nexport default {\r\n  name: \"HomeView\",\r\n  components: {\r\n    BannerComponent\r\n  },\r\n  methods: {\r\n    irParaConfigurar(nome, valor, categoria, foto) {\r\n      const objetoProduto = {\r\n        id: Date.now(),\r\n        nome: nome,\r\n        valor: parseFloat(valor),\r\n        categoria: categoria,\r\n        foto: foto\r\n      };\r\n      this.$router.push({\r\n        path: \"/configuracao\",\r\n        query: { produto: JSON.stringify(objetoProduto) }\r\n      });\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* Estilos globais da Home continuam os mesmos aqui */\r\n.home-container { max-width: 100vw; margin-top: 40px; font-family: 'Plus Jakarta Sans', sans-serif; background-color: #faf6f0; color: #2b1b12; overflow-x: hidden; }\r\n.hero-section { padding: 30px 20px; display: flex; justify-content: center; }\r\n.features-section { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; max-width: 1140px; margin: 60px auto; padding: 0 20px; }\r\n.feature-card { background-color: #ffffff; padding: 35px 25px; border-radius: 20px; text-align: center; box-shadow: 0 10px 30px rgba(43, 27, 18, 0.02); border: 1px solid rgba(43, 27, 18, 0.03); }\r\n.feature-icon { font-size: 32px; display: inline-block; margin-bottom: 15px; }\r\n.feature-card h3 { font-family: 'Playfair Display', Georgia, serif; font-size: 20px; margin: 0 0 10px 0; color: #2b1b12; }\r\n.feature-card p { font-size: 14px; color: #615045; line-height: 1.6; margin: 0; }\r\n.highlights-section { max-width: 1140px; margin: 80px auto; padding: 0 20px; text-align: left; }\r\n.section-header { margin-bottom: 40px; }\r\n.section-title { font-family: 'Playfair Display', Georgia, serif; font-size: 36px; margin: 0 0 8px 0; }\r\n.section-subtitle { font-size: 15px; color: #615045; margin: 0; }\r\n.highlights-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; }\r\n.highlight-card { background-color: #ffffff; border-radius: 24px; overflow: hidden; box-shadow: 0 12px 35px rgba(43, 27, 18, 0.04); position: relative; transition: transform 0.2s; border: 1px solid rgba(43, 27, 18, 0.03); display: flex; flex-direction: column; }\r\n.highlight-card:hover { transform: translateY(-5px); }\r\n.card-tag { position: absolute; top: 15px; left: 15px; z-index: 10; padding: 6px 14px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; color: #ffffff; box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1); }\r\n.card-tag.popular { background-color: #e67e22; }\r\n.card-tag.novo { background-color: #27ae60; }\r\n.card-image { width: 100%; height: 220px; overflow: hidden; }\r\n.card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }\r\n.highlight-card:hover .card-image img { transform: scale(1.05); }\r\n.card-content { padding: 25px; display: flex; flex-direction: column; flex-grow: 1; }\r\n.card-content h3 { font-family: 'Playfair Display', Georgia, serif; font-size: 20px; margin: 0 0 10px 0; }\r\n.card-content p { font-size: 14px; color: #615045; line-height: 1.6; margin: 0 0 20px 0; flex-grow: 1; }\r\n.card-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(43, 27, 18, 0.06); padding-top: 15px; }\r\n.price { font-size: 20px; font-weight: 700; color: #2b1b12; }\r\n.btn-card { background-color: #2b1b12; color: #f7f3ee; border: none; padding: 10px 24px; border-radius: 12px; font-weight: 600; font-size: 14px; cursor: pointer; transition: opacity 0.2s; }\r\n.btn-card:hover { opacity: 0.9; }\r\n.cta-section { max-width: 1140px; margin: 40px auto 80px auto; padding: 0 20px; }\r\n.cta-box { background-color: #2b1b12; color: #f7f3ee; padding: 50px 30px; border-radius: 28px; text-align: center; box-shadow: 0 15px 35px rgba(43, 27, 18, 0.15); }\r\n.cta-box h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 32px; margin: 0 0 12px 0; }\r\n.cta-box p { font-size: 15px; max-width: 550px; margin: 0 auto 30px auto; opacity: 0.85; line-height: 1.6; }\r\n.btn-cta-menu { display: inline-block; background-color: #f7f3ee; color: #2b1b12; text-decoration: none; padding: 15px 35px; border-radius: 14px; font-weight: 600; font-size: 15px; transition: background-color 0.2s; }\r\n.btn-cta-menu:hover { background-color: #e6dfd5; }\r\n</style>"],"mappings":";AAyFA,OAAOA,eAAc,MAAO,kCAAkC;AAE9D,eAAe;EACbC,IAAI,EAAE,UAAU;EAChBC,UAAU,EAAE;IACVF;EACF,CAAC;EACDG,OAAO,EAAE;IACPC,gBAAgBA,CAACC,IAAI,EAAEC,KAAK,EAAEC,SAAS,EAAEC,IAAI,EAAE;MAC7C,MAAMC,aAAY,GAAI;QACpBC,EAAE,EAA