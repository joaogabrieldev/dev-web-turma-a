}\r\n\r\n.section-header h2 {\r\n  font-size: 36px;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.section-header p {\r\n  color: #615045;\r\n  font-size: 16px;\r\n}\r\n\r\n/* Grid refinado */\r\n.grid-cafes {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\r\n  gap: 30px;\r\n}\r\n\r\n/* Card Estilo Gourmet */\r\n.cafe-card {\r\n  background-color: #f7f3ee; /* Fundo levemente contrastante com o body */\r\n  border-radius: 24px;\r\n  overflow: hidden;\r\n  box-shadow: 0 10px 25px rgba(43, 27, 18, 0.04);\r\n  transition: transform 0.3s, box-shadow 0.3s;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.cafe-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 15px 35px rgba(43, 27, 18, 0.09);\r\n}\r\n\r\n.image-container {\r\n  width: 100%;\r\n  height: 220px;\r\n  overflow: hidden;\r\n  background-color: #2b1b12; /* Garante fundo bonito se a foto falhar */\r\n}\r\n\r\n.image-container img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  transition: transform 0.5s;\r\n}\r\n\r\n.cafe-card:hover .image-container img {\r\n  transform: scale(1.06);\r\n}\r\n\r\n.card-body {\r\n  padding: 22px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  flex-grow: 1;\r\n}\r\n\r\n.card-meta {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: baseline;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.card-meta h3 {\r\n  font-size: 20px;\r\n  font-weight: 700;\r\n}\r\n\r\n.price {\r\n  font-weight: 700;\r\n  color: #523b2e;\r\n  font-size: 17px;\r\n}\r\n\r\n.description {\r\n  font-size: 14px;\r\n  color: #615045;\r\n  line-height: 1.5;\r\n  margin-bottom: 20px;\r\n  text-align: left;\r\n  flex-grow: 1;\r\n}\r\n\r\n/* Botão elegante texturizado marrom */\r\n.btn-add {\r\n  background-color: #2b1b12; /* Botão escuro da paleta */\r\n  color: #f7f3ee;\r\n  width: 100%;\r\n  padding: 12px 18px;\r\n  border-radius: 14px;\r\n  font-weight: 500;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.btn-add:hover {\r\n  background-color: #4a3427;\r\n}\r\n\r\n.arrow {\r\n  font-style: normal;\r\n  font-weight: bold;\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAc;;EAMlBA,KAAK,EAAC;AAAY;;EAEdA,KAAK,EAAC;AAAiB;;;EAGvBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAW;;EAEdA,KAAK,EAAC;AAAO;;EAElBA,KAAK,EAAC;AAAa;;;uBAhB9BC,mBAAA,CAwBM,OAxBNC,UAwBM,G,0BAvBJC,mBAAA,CAGM;IAHDH,KAAK,EAAC;EAAgB,IACzBG,mBAAA,CAA8B,YAA1B,uBAAqB,GACzBA,mBAAA,CAAuE,WAApE,kEAAgE,E,qBAGrEA,mBAAA,CAiBM,OAjBNC,UAiBM,I,kBAhBJH,mBAAA,CAeMI,SAAA,QAAAC,WAAA,CAfgCC,IAAA,CAAAC,kBAAkB,EAA1BC,IAAI;yBAAlCR,mBAAA,CAeM;MAfDD,KAAK,EAAC,WAAW;MAAqCU,GAAG,EAAED,IAAI,CAACE;QACnER,mBAAA,CAEM,OAFNS,UAEM,GADJT,mBAAA,CAAyC;MAAnCU,GAAG,EAAEJ,IAAI,CAACK,IAAI;MAAGC,GAAG,EAAEN,IAAI,CAACO;2CAEnCb,mBAAA,CAUM,OAVNc,UAUM,GATJd,mBAAA,CAGM,OAHNe,UAGM,GAFJf,mBAAA,CAAwB,YAAAgB,gBAAA,CAAjBV,IAAI,CAACO,IAAI,kBAChBb,mBAAA,CAA8C,QAA9CiB,UAA8C,EAA1B,KAAG,GAAAD,gBAAA,CAAGV,IAAI,CAACY,KAAK,iB,GAEtClB,mBAAA,CAA0G,KAA1GmB,UAA0G,EAAAH,gBAAA,CAAhFV,IAAI,CAACc,SAAS,6EACxCpB,mBAAA,CAGS;MAHDH,KAAK,EAAC,SAAS;MAAEwB,OAAK,EAAAC,MAAA,IAAElB,IAAA,CAAAmB,cAAc,CAACjB,IAAI;uCACjDN,mBAAA,CAA6B,cAAvB,kBAAgB,oBACtBA,mBAAA,CAAsB;MAAnBH,KAAK,EAAC;IAAO,GAAC,GAAC,mB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}