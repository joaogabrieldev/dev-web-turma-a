{"ast":null,"code":"import \"core-js/modules/es.array.includes.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nexport default {\n  name: \"ConfiguracaoPedidoView\",\n  data() {\n    return {\n      produto: null,\n      nomeCliente: \"\",\n      listaPontos: [],\n      listaOpcionais: [],\n      pontoSelecionado: null,\n      opcionaisSelecionados: [],\n      exibindoErros: false,\n      // Estado do componente de alerta\n      alerta: {\n        visivel: false,\n        mensagem: \"\",\n        tipo: \"\" // erro, aviso, info, sucesso\n      }\n    };\n  },\n  computed: {\n    // Validação reativa dos campos essenciais\n    formValido() {\n      const nomePreenchido = this.nomeCliente.trim().length > 0;\n      const precisaPonto = this.produto && this.produto.categoria !== \"lanches\" && this.listaPontos.length > 0;\n      const pontoPreenchido = precisaPonto ? !!this.pontoSelecionado : true;\n      return nomePreenchido && pontoPreenchido;\n    },\n    // Ícone dinâmico baseado na paleta semântica\n    alertIcon() {\n      switch (this.alerta.tipo) {\n        case 'erro':\n          return '❌';\n        case 'aviso':\n          return '⚠️';\n        case 'info':\n          return 'ℹ️';\n        case 'sucesso':\n          return '✅';\n        default:\n          return '';\n      }\n    },\n    valorTotal() {\n      let total = 0;\n      if (this.produto && this.produto.valor) {\n        let valorBase = String(this.produto.valor).replace(',', '.');\n        total += parseFloat(valorBase) || 0;\n      }\n      if (Array.isArray(this.opcionaisSelecionados)) {\n        this.opcionaisSelecionados.forEach(id => {\n          const item = this.listaOpcionais.find(o => o.id === id);\n          if (item && item.valor) {\n            let valorOpcional = String(item.valor).replace(',', '.');\n            total += parseFloat(valorOpcional) || 0;\n          }\n        });\n      }\n      return total;\n    }\n  },\n  methods: {\n    formatarPreco(valor) {\n      if (!valor) return \"0.00\";\n      let num = parseFloat(String(valor).replace(',', '.'));\n      return isNaN(num) ? \"0.00\" : num.toFixed(2);\n    },\n    // Função para disparar os alertas semânticos em tela\n    mostrarAlerta(mensagem, tipo = \"info\") {\n      this.alerta.mensagem = mensaje;\n      this.alerta.tipo = tipo;\n      this.alerta.visivel = true;\n\n      // Auto-oculta o alerta após 3.5 segundos\n      setTimeout(() => {\n        this.alerta.visivel = false;\n      }, 3500);\n    },\n    async carregarDadosCustomizacao() {\n      try {\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\n        const todosPontos = await resPontos.json();\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\n        const dadosOpcionais = await resOpcionais.json();\n        const todosOpcionais = dadosOpcionais.complemento || [];\n        if (this.produto && this.produto.categoria === \"lanches\") {\n          this.listaPontos = [];\n          this.pontoSelecionado = \"padrao\";\n          const itensParaEvitar = [\"Chantilly\", \"Canela em pó\", \"Xarope de Baunilha\", \"Calda de Caramelo Extra\", \"Dose Dupla de Espresso\"];\n          this.listaOpcionais = todosOpcionais.filter(item => !itensParaEvitar.includes(item.nome));\n          this.mostrarAlerta(\"Carregando opções artesanais para o seu lanche.\", \"info\");\n        } else {\n          this.listaPontos = todosPontos;\n          if (this.listaPontos.length > 0) {\n            this.pontoSelecionado = this.listaPontos[0].id;\n          }\n          this.listaOpcionais = todosOpcionais;\n          this.mostrarAlerta(\"Personalize o tamanho e adicionais do seu café.\", \"info\");\n        }\n      } catch (error) {\n        this.mostrarAlerta(\"Falha de comunicação com o servidor ao carregar adicionais.\", \"erro\");\n      }\n    },\n    async enviarParaCarrinho() {\n      this.exibindoErros = true;\n\n      // Executa a validação de integridade de dados antes do POST\n      if (!this.formValido) {\n        if (!this.nomeCliente.trim()) {\n          this.mostrarAlerta(\"Preenchimento obrigatório: Digite o Nome do Cliente.\", \"erro\");\n        } else {\n          this.mostrarAlerta(\"Escolha uma opção de tamanho base antes de continuar.\", \"aviso\");\n        }\n        return;\n      }\n      const opcionaisDetalhados = this.opcionaisSelecionados.map(id => {\n        return this.listaOpcionais.find(o => o.id === id);\n      });\n      let textoPonto = \"Tamanho Único\";\n      if (this.produto.categoria !== \"lanches\") {\n        const pontoEscolhido = this.listaPontos.find(p => p.id === this.pontoSelecionado);\n        textoPonto = pontoEscolhido ? pontoEscolhido.descricao : \"\";\n      }\n      const pedidoPayload = {\n        cliente: this.nomeCliente.trim(),\n        nome_cafe: this.produto.nome,\n        foto_cafe: this.produto.foto,\n        valor_total: this.valorTotal.toFixed(2),\n        ponto: textoPonto,\n        opcionais: opcionaisDetalhados,\n        status: \"Em preparação\"\n      };\n      try {\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\"\n          },\n          body: JSON.stringify(pedidoPayload)\n        });\n        if (response.ok) {\n          this.mostrarAlerta(\"Item adicionado com sucesso! Redirecionando...\", \"sucesso\");\n          setTimeout(() => {\n            this.$router.push(\"/pedidos\");\n          }, 1500);\n        } else {\n          this.mostrarAlerta(\"Não foi possível registrar seu pedido. Tente novamente.\", \"erro\");\n        }\n      } catch (error) {\n        this.mostrarAlerta(\"Erro de rede. Verifique se o banco de dados está online.\", \"erro\");\n      }\n    }\n  },\n  mounted() {\n    const query = this.$route.query;\n    if (query.produto) {\n      try {\n        this.produto = JSON.parse(decodeURIComponent(query.produto));\n      } catch (e) {\n        console.error(e);\n      }\n    }\n    this.carregarDadosCustomizacao();\n  }\n};","map":{"version":3,"names":["name","data","produto","nomeCliente","listaPontos","listaOpcionais","pontoSelecionado","opcionaisSelecionados","exibindoErros","alerta","visivel","mensagem","tipo","computed","formValido","nomePreenchido","trim","length","precisaPonto","categoria","pontoPreenchido","alertIcon","valorTotal","total","valor","valorBase","String","replace","parseFloat","Array","isArray","forEach","id","item","find","o","valorOpcional","methods","formatarPreco","num","isNaN","toFixed","mostrarAlerta","mensaje","setTimeout","carregarDadosCustomizacao","resPontos","fetch","todosPontos","json","resOpcionais","dadosOpcionais","todosOpcionais","complemento","itensParaEvitar","filter","includes","nome","error","enviarParaCarrinho","opcionaisDetalhados","map","textoPonto","pontoEscolhido","p","descricao","pedidoPayload","cliente","nome_cafe","foto_cafe","foto","valor_total","ponto","opcionais","status","response","method","headers","body","JSON","stringify","ok","$router","push","mounted","query","$route","parse","decodeURIComponent","e","console"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\ConfiguracaoPedidoView.vue"],"sourcesContent":["<template>\r\n  <div class=\"config-container\" v-if=\"produto\">\r\n    \r\n    <transition name=\"toast-fade\">\r\n      <div v-if=\"alerta.visivel\" :class=\"['custom-alert', alerta.tipo]\">\r\n        <span class=\"alert-icon\">{{ alertIcon }}</span>\r\n        <span class=\"alert-message\">{{ alerta.mensagem }}</span>\r\n      </div>\r\n    </transition>\r\n\r\n    <div class=\"product-preview\">\r\n      <div class=\"image-box\">\r\n        <img :src=\"produto.foto\" :alt=\"produto.nome\" />\r\n      </div>\r\n      <div class=\"product-info\">\r\n        <h2>{{ produto.nome }}</h2>\r\n        <p class=\"base-price\">Preço base: R$ {{ formatarPreco(produto.valor) }}</p>\r\n        <p class=\"description\">\r\n          {{ produto.descricao || 'Item preparado com ingredientes selecionados de forma artesanal.' }}\r\n        </p>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"customization-form\">\r\n      \r\n      <div class=\"options-group\">\r\n        <h3>Identificação do Cliente <span class=\"required\">*</span></h3>\r\n        <input \r\n          type=\"text\" \r\n          v-model=\"nomeCliente\" \r\n          placeholder=\"Digite o nome para o copo/pedido\"\r\n          :class=\"['input-cliente', { 'input-error': exibindoErros && !nomeCliente.trim() }]\"\r\n        />\r\n        <span v-if=\"exibindoErros && !nomeCliente.trim()\" class=\"error-text\">\r\n          O nome do cliente é obrigatório para identificação.\r\n        </span>\r\n      </div>\r\n\r\n      <div class=\"options-group\" v-if=\"listaPontos.length > 0\">\r\n        <h3>Escolha o Tamanho / Ponto <span class=\"required\">*</span></h3>\r\n        <div class=\"radio-grid\">\r\n          <label \r\n            v-for=\"ponto in listaPontos\" \r\n            :key=\"ponto.id\" \r\n            :class=\"['radio-card', { selected: pontoSelecionado === ponto.id }]\"\r\n          >\r\n            <input \r\n              type=\"radio\" \r\n              name=\"ponto\" \r\n              :value=\"ponto.id\" \r\n              v-model=\"pontoSelecionado\"\r\n            />\r\n            <span class=\"radio-label\">{{ ponto.descricao }}</span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"options-group\">\r\n        <h3>Adicionais (Opcional)</h3>\r\n        <div class=\"checkbox-list\">\r\n          <label \r\n            v-for=\"opcional in listaOpcionais\" \r\n            :key=\"opcional.id\" \r\n            :class=\"['checkbox-item', { checked: opcionaisSelecionados.includes(opcional.id) }]\"\r\n          >\r\n            <div class=\"checkbox-wrapper\">\r\n              <input \r\n                type=\"checkbox\" \r\n                :value=\"opcional.id\" \r\n                v-model=\"opcionaisSelecionados\"\r\n              />\r\n              <span class=\"opcional-name\">{{ opcional.nome }}</span>\r\n            </div>\r\n            <span class=\"opcional-price\">{{ opcional.valor ? '+ R$ ' + formatarPreco(opcional.valor) : 'Grátis' }}</span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"summary-section\">\r\n        <div class=\"price-row\">\r\n          <span>Total do Item:</span>\r\n          <span class=\"total-price\">R$ {{ valorTotal.toFixed(2) }}</span>\r\n        </div>\r\n        <button \r\n          :class=\"['btn-submit', { 'btn-disabled': !formValido && exibindoErros }]\" \r\n          @click=\"enviarParaCarrinho\"\r\n        >\r\n          Adicionar ao Carrinho →\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"ConfiguracaoPedidoView\",\r\n  data() {\r\n    return {\r\n      produto: null,\r\n      nomeCliente: \"\",\r\n      listaPontos: [],\r\n      listaOpcionais: [],\r\n      pontoSelecionado: null,\r\n      opcionaisSelecionados: [],\r\n      exibindoErros: false,\r\n      \r\n      // Estado do componente de alerta\r\n      alerta: {\r\n        visivel: false,\r\n        mensagem: \"\",\r\n        tipo: \"\" // erro, aviso, info, sucesso\r\n      }\r\n    };\r\n  },\r\n  computed: {\r\n    // Validação reativa dos campos essenciais\r\n    formValido() {\r\n      const nomePreenchido = this.nomeCliente.trim().length > 0;\r\n      const precisaPonto = this.produto && this.produto.categoria !== \"lanches\" && this.listaPontos.length > 0;\r\n      const pontoPreenchido = precisaPonto ? !!this.pontoSelecionado : true;\r\n      \r\n      return nomePreenchido && pontoPreenchido;\r\n    },\r\n    \r\n    // Ícone dinâmico baseado na paleta semântica\r\n    alertIcon() {\r\n      switch (this.alerta.tipo) {\r\n        case 'erro': return '❌';\r\n        case 'aviso': return '⚠️';\r\n        case 'info': return 'ℹ️';\r\n        case 'sucesso': return '✅';\r\n        default: return '';\r\n      }\r\n    },\r\n\r\n    valorTotal() {\r\n      let total = 0;\r\n      if (this.produto && this.produto.valor) {\r\n        let valorBase = String(this.produto.valor).replace(',', '.');\r\n        total += parseFloat(valorBase) || 0;\r\n      }\r\n      if (Array.isArray(this.opcionaisSelecionados)) {\r\n        this.opcionaisSelecionados.forEach(id => {\r\n          const item = this.listaOpcionais.find(o => o.id === id);\r\n          if (item && item.valor) {\r\n            let valorOpcional = String(item.valor).replace(',', '.');\r\n            total += parseFloat(valorOpcional) || 0;\r\n          }\r\n        });\r\n      }\r\n      return total;\r\n    }\r\n  },\r\n  methods: {\r\n    formatarPreco(valor) {\r\n      if (!valor) return \"0.00\";\r\n      let num = parseFloat(String(valor).replace(',', '.'));\r\n      return isNaN(num) ? \"0.00\" : num.toFixed(2);\r\n    },\r\n\r\n    // Função para disparar os alertas semânticos em tela\r\n    mostrarAlerta(mensagem, tipo = \"info\") {\r\n      this.alerta.mensagem = mensaje;\r\n      this.alerta.tipo = tipo;\r\n      this.alerta.visivel = true;\r\n      \r\n      // Auto-oculta o alerta após 3.5 segundos\r\n      setTimeout(() => {\r\n        this.alerta.visivel = false;\r\n      }, 3500);\r\n    },\r\n\r\n    async carregarDadosCustomizacao() {\r\n      try {\r\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n        const todosPontos = await resPontos.json();\r\n\r\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\r\n        const dadosOpcionais = await resOpcionais.json();\r\n        const todosOpcionais = dadosOpcionais.complemento || [];\r\n\r\n        if (this.produto && this.produto.categoria === \"lanches\") {\r\n          this.listaPontos = [];\r\n          this.pontoSelecionado = \"padrao\";\r\n          const itensParaEvitar = [\"Chantilly\", \"Canela em pó\", \"Xarope de Baunilha\", \"Calda de Caramelo Extra\", \"Dose Dupla de Espresso\"];\r\n          this.listaOpcionais = todosOpcionais.filter(item => !itensParaEvitar.includes(item.nome));\r\n          \r\n          this.mostrarAlerta(\"Carregando opções artesanais para o seu lanche.\", \"info\");\r\n        } else {\r\n          this.listaPontos = todosPontos;\r\n          if (this.listaPontos.length > 0) {\r\n            this.pontoSelecionado = this.listaPontos[0].id;\r\n          }\r\n          this.listaOpcionais = todosOpcionais;\r\n          \r\n          this.mostrarAlerta(\"Personalize o tamanho e adicionais do seu café.\", \"info\");\r\n        }\r\n      } catch (error) {\r\n        this.mostrarAlerta(\"Falha de comunicação com o servidor ao carregar adicionais.\", \"erro\");\r\n      }\r\n    },\r\n\r\n    async enviarParaCarrinho() {\r\n      this.exibindoErros = true;\r\n\r\n      // Executa a validação de integridade de dados antes do POST\r\n      if (!this.formValido) {\r\n        if (!this.nomeCliente.trim()) {\r\n          this.mostrarAlerta(\"Preenchimento obrigatório: Digite o Nome do Cliente.\", \"erro\");\r\n        } else {\r\n          this.mostrarAlerta(\"Escolha uma opção de tamanho base antes de continuar.\", \"aviso\");\r\n        }\r\n        return;\r\n      }\r\n\r\n      const opcionaisDetalhados = this.opcionaisSelecionados.map(id => {\r\n        return this.listaOpcionais.find(o => o.id === id);\r\n      });\r\n\r\n      let textoPonto = \"Tamanho Único\";\r\n      if (this.produto.categoria !== \"lanches\") {\r\n        const pontoEscolhido = this.listaPontos.find(p => p.id === this.pontoSelecionado);\r\n        textoPonto = pontoEscolhido ? pontoEscolhido.descricao : \"\";\r\n      }\r\n\r\n      const pedidoPayload = {\r\n        cliente: this.nomeCliente.trim(),\r\n        nome_cafe: this.produto.nome,\r\n        foto_cafe: this.produto.foto,\r\n        valor_total: this.valorTotal.toFixed(2),\r\n        ponto: textoPonto,\r\n        opcionais: opcionaisDetalhados,\r\n        status: \"Em preparação\"\r\n      };\r\n\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify(pedidoPayload)\r\n        });\r\n\r\n        if (response.ok) {\r\n          this.mostrarAlerta(\"Item adicionado com sucesso! Redirecionando...\", \"sucesso\");\r\n          setTimeout(() => {\r\n            this.$router.push(\"/pedidos\");\r\n          }, 1500);\r\n        } else {\r\n          this.mostrarAlerta(\"Não foi possível registrar seu pedido. Tente novamente.\", \"erro\");\r\n        }\r\n      } catch (error) {\r\n        this.mostrarAlerta(\"Erro de rede. Verifique se o banco de dados está online.\", \"erro\");\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    const query = this.$route.query;\r\n    if (query.produto) {\r\n      try {\r\n        this.produto = JSON.parse(decodeURIComponent(query.produto));\r\n      } catch (e) {\r\n        console.error(e);\r\n      }\r\n    }\r\n    this.carregarDadosCustomizacao();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* COMPONENTE DE ALERTA SEMÂNTICO (NOTIFICAÇÃO EM TELA) */\r\n.custom-alert {\r\n  position: fixed;\r\n  top: 100px;\r\n  right: 20px;\r\n  z-index: 9999;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  padding: 16px 24px;\r\n  border-radius: 12px;\r\n  color: #ffffff;\r\n  font-weight: 600;\r\n  font-size: 14px;\r\n  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\r\n  min-width: 300px;\r\n  max-width: 450px;\r\n}\r\n\r\n/* Paleta Semântica */\r\n.custom-alert.erro { background-color: #d93838; }      /* Vermelho */\r\n.custom-alert.aviso { background-color: #e67e22; }     /* Laranja */\r\n.custom-alert.info { background-color: #2980b9; }      /* Azul */\r\n.custom-alert.sucesso { background-color: #27ae60; }   /* Verde */\r\n\r\n/* Campo do Cliente */\r\n.input-cliente {\r\n  width: 100%;\r\n  padding: 14px 18px;\r\n  border-radius: 12px;\r\n  border: 1px solid rgba(43, 27, 18, 0.2);\r\n  font-size: 15px;\r\n  background-color: #ffffff;\r\n  color: #2b1b12;\r\n  outline: none;\r\n  transition: border-color 0.2s;\r\n  box-sizing: border-box;\r\n}\r\n.input-cliente:focus {\r\n  border-color: #2b1b12;\r\n}\r\n.input-cliente.input-error {\r\n  border-color: #d93838;\r\n  background-color: #fff5f5;\r\n}\r\n.error-text {\r\n  color: #d93838;\r\n  font-size: 12px;\r\n  margin-top: 6px;\r\n  display: block;\r\n}\r\n.required {\r\n  color: #d93838;\r\n}\r\n\r\n/* Estados de Bloqueio do Botão */\r\n.btn-disabled {\r\n  opacity: 0.6;\r\n  cursor: not-allowed !important;\r\n  background-color: #7f7f7f !important;\r\n}\r\n\r\n/* Transições do Alerta */\r\n.toast-fade-enter-active, .toast-fade-leave-active {\r\n  transition: all 0.3s ease;\r\n}\r\n.toast-fade-enter {\r\n  transform: translateX(50px);\r\n  opacity: 0;\r\n}\r\n.toast-fade-leave-to {\r\n  transform: translateX(50px);\r\n  opacity: 0;\r\n}\r\n\r\n/* Layout Geral Mantido */\r\n.config-container {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 50px;\r\n  max-width: 1200px;\r\n  margin: 120px auto 30px auto;\r\n  padding: 0 20px;\r\n}\r\n.product-preview {\r\n  background-color: #f7f3ee;\r\n  border-radius: 24px;\r\n  padding: 25px;\r\n  box-shadow: 0 10px 25px rgba(43, 27, 18, 0.03);\r\n  text-align: left;\r\n  height: fit-content;\r\n}\r\n.image-box {\r\n  width: 100%;\r\n  height: 350px;\r\n  border-radius: 16px;\r\n  overflow: hidden;\r\n  margin-bottom: 20px;\r\n}\r\n.image-box img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;