{"ast":null,"code":"import \"core-js/modules/es.array.includes.js\";\nexport default {\n  name: \"AlertaComponent\",\n  props: {\n    mensagem: {\n      type: String,\n      default: \"\"\n    },\n    tipo: {\n      type: String,\n      default: \"info\",\n      validator: v => [\"erro\", \"aviso\", \"info\", \"sucesso\"].includes(v)\n    },\n    duracao: {\n      type: Number,\n      default: 4000\n    }\n  },\n  emits: [\"fechar\"],\n  data() {\n    return {\n      visivel: false,\n      timer: null\n    };\n  },\n  computed: {\n    icone() {\n      const icones = {\n        erro: \"❌\",\n        aviso: \"⚠️\",\n        info: \"ℹ️\",\n        sucesso: \"✅\"\n      };\n      return icones[this.tipo] || \"🔔\";\n    }\n  },\n  watch: {\n    // Sempre que mensagem mudar, reexibe com o timer reiniciado\n    mensagem(novaMsg) {\n      if (novaMsg) {\n        this.mostrar();\n      }\n    }\n  },\n  methods: {\n    mostrar() {\n      clearTimeout(this.timer);\n      this.visivel = true;\n      if (this.duracao > 0) {\n        this.timer = setTimeout(() => {\n          this.fechar();\n        }, this.duracao);\n      }\n    },\n    fechar() {\n      this.visivel = false;\n      clearTimeout(this.timer);\n      this.$emit(\"fechar\");\n    }\n  },\n  mounted() {\n    if (this.mensagem) this.mostrar();\n  },\n  beforeUnmount() {\n    clearTimeout(this.timer);\n  }\n};","map":{"version":3,"names":["name","props","mensagem","type","String","default","tipo","validator","v","includes","duracao","Number","emits","data","visivel","timer","computed","icone","icones","erro","aviso","info","sucesso","watch","novaMsg","mostrar","methods","clearTimeout","setTimeout","fechar","$emit","mounted","beforeUnmount"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\components\\AlertaComponent.vue"],"sourcesContent":["<template>\r\n  <transition name=\"alerta-slide\">\r\n    <div v-if=\"visivel && mensagem\" :class=\"['alerta-global', tipo]\" role=\"alert\">\r\n      <span class=\"alerta-icone\">{{ icone }}</span>\r\n      <p class=\"alerta-texto\">{{ mensagem }}</p>\r\n      <button class=\"alerta-fechar\" @click=\"fechar\" aria-label=\"Fechar\">×</button>\r\n    </div>\r\n  </transition>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"AlertaComponent\",\r\n  props: {\r\n    mensagem: {\r\n      type: String,\r\n      default: \"\"\r\n    },\r\n    tipo: {\r\n      type: String,\r\n      default: \"info\",\r\n      validator: (v) => [\"erro\", \"aviso\", \"info\", \"sucesso\"].includes(v)\r\n    },\r\n    duracao: {\r\n      type: Number,\r\n      default: 4000\r\n    }\r\n  },\r\n  emits: [\"fechar\"],\r\n  data() {\r\n    return {\r\n      visivel: false,\r\n      timer: null\r\n    };\r\n  },\r\n  computed: {\r\n    icone() {\r\n      const icones = { erro: \"❌\", aviso: \"⚠️\", info: \"ℹ️\", sucesso: \"✅\" };\r\n      return icones[this.tipo] || \"🔔\";\r\n    }\r\n  },\r\n  watch: {\r\n    // Sempre que mensagem mudar, reexibe com o timer reiniciado\r\n    mensagem(novaMsg) {\r\n      if (novaMsg) {\r\n        this.mostrar();\r\n      }\r\n    }\r\n  },\r\n  methods: {\r\n    mostrar() {\r\n      clearTimeout(this.timer);\r\n      this.visivel = true;\r\n      if (this.duracao > 0) {\r\n        this.timer = setTimeout(() => { this.fechar(); }, this.duracao);\r\n      }\r\n    },\r\n    fechar() {\r\n      this.visivel = false;\r\n      clearTimeout(this.timer);\r\n      this.$emit(\"fechar\");\r\n    }\r\n  },\r\n  mounted() {\r\n    if (this.mensagem) this.mostrar();\r\n  },\r\n  beforeUnmount() {\r\n    clearTimeout(this.timer);\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.alerta-global {\r\n  position: fixed;\r\n  top: 88px;  /* Abaixo da navbar fixa (72px + 16px de gap) */\r\n  right: 24px;\r\n  z-index: 9000;\r\n  display: flex;\r\n  align-items: flex-start;\r\n  gap: 12px;\r\n  padding: 14px 18px;\r\n  border-radius: 14px;\r\n  color: #ffffff;\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n  line-height: 1.5;\r\n  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.14);\r\n  min-width: 300px;\r\n  max-width: 440px;\r\n  border-left: 4px solid rgba(255, 255, 255, 0.35);\r\n}\r\n\r\n/* Paleta semântica */\r\n.alerta-global.erro    { background-color: #c0392b; } /* Vermelho — erro */\r\n.alerta-global.aviso   { background-color: #d35400; color: #fff; } /* Laranja — aviso */\r\n.alerta-global.info    { background-color: #2471a3; } /* Azul — informação */\r\n.alerta-global.sucesso { background-color: #1e8449; } /* Verde — sucesso */\r\n\r\n.alerta-icone {\r\n  font-size: 18px;\r\n  flex-shrink: 0;\r\n  margin-top: 1px;\r\n}\r\n\r\n.alerta-texto {\r\n  flex: 1;\r\n  margin: 0;\r\n}\r\n\r\n.alerta-fechar {\r\n  background: none;\r\n  border: none;\r\n  color: rgba(255, 255, 255, 0.75);\r\n  font-size: 20px;\r\n  line-height: 1;\r\n  padding: 0;\r\n  cursor: pointer;\r\n  flex-shrink: 0;\r\n  transition: color 0.15s;\r\n  margin-top: -1px;\r\n}\r\n\r\n.alerta-fechar:hover {\r\n  color: #ffffff;\r\n}\r\n\r\n/* Animação de entrada/saída */\r\n.alerta-slide-enter-active { transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }\r\n.alerta-slide-leave-active { transition: all 0.25s ease-in; }\r\n.alerta-slide-enter-from  { transform: translateX(60px); opacity: 0; }\r\n.alerta-slide-leave-to    { transform: translateX(60px); opacity: 0; }\r\n</style>"],"mappings":";AAWA,eAAe;EACbA,IAAI,EAAE,iBAAiB;EACvBC,KAAK,EAAE;IACLC,QAAQ,EAAE;MACRC,IAAI,EAAEC,MAAM;MACZC,OAAO,EAAE;IACX,CAAC;IACDC,IAAI,EAAE;MACJH,IAAI,EAAEC,MAAM;MACZC,OAAO,EAAE,MAAM;MACfE,SAAS,EAAGC,CAAC,IAAK,CAAC,MAAM,EAAE,OAAO,EAAE,MAAM,EAAE,SAAS,CAAC,CAACC,QAAQ,CAACD,CAAC;IACnE,CAAC;IACDE,OAAO,EAAE;MACPP,IAAI,EAAEQ,MAAM;MACZN,OAAO,EAAE;IACX;EACF,CAAC;EACDO,KAAK,EAAE,CAAC,QAAQ,CAAC;EACjBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,KAAK;MACdC,KAAK,EAAE;IACT,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,KAAKA,CAAA,EAAG;MACN,MAAMC,MAAK,GAAI;QAAEC,IAAI,EAAE,GAAG;QAAEC,KAAK,EA