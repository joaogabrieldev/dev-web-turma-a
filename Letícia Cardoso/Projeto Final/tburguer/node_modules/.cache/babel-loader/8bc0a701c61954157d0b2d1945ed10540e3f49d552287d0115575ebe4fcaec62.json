   <p class=\"product-description\">Expresso blend da casa, leite cremoso vaporizado e uma camada generosa de ganache de chocolate belga.</p>\r\n            <div class=\"product-footer\">\r\n              <span class=\"product-price\">R$ 16,90</span>\r\n              <button class=\"btn-add-product\">\r\n                <span>+</span>\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"product-card\">\r\n          <div class=\"product-image-placeholder\">🥤</div>\r\n          <div class=\"product-info\">\r\n            <h4 class=\"product-name\">Iced Caramel Latte</h4>\r\n            <p class=\"product-description\">Café extraído a frio batido com leite gelado, cubos de gelo de café e calda artesanal de caramelo salgado.</p>\r\n            <div class=\"product-footer\">\r\n              <span class=\"product-price\">R$ 18,50</span>\r\n              <button class=\"btn-add-product\">\r\n                <span>+</span>\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"product-card\">\r\n          <div class=\"product-badge\">Fresco</div>\r\n          <div class=\"product-image-placeholder\">🥐</div>\r\n          <div class=\"product-info\">\r\n            <h4 class=\"product-name\">Croissant de Amêndoas</h4>\r\n            <p class=\"product-description\">Massa folhada francesa super crocante por fora, recheada com creme de frangipane e lascas de amêndoas tostadas.</p>\r\n            <div class=\"product-footer\">\r\n              <span class=\"product-price\">R$ 21,00</span>\r\n              <button class=\"btn-add-product\">\r\n                <span>+</span>\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <section class=\"testimonials-section\">\r\n      <div class=\"section-header center\">\r\n        <span class=\"section-tag\">EXPERIÊNCIA ÂMBAR</span>\r\n        <h2 class=\"section-title\">Quem frequenta, ama</h2>\r\n      </div>\r\n      \r\n      <div class=\"testimonials-grid\">\r\n        <div class=\"testimonial-card\">\r\n          <p class=\"testimonial-text\">\"O melhor cappuccino trufado que já tomei na vida. O ambiente é perfeito para trabalhar, calmo e muito cheiroso!\"</p>\r\n          <div class=\"testimonial-user\">\r\n            <div class=\"user-avatar\">LA</div>\r\n            <div>\r\n              <h5 class=\"user-name\">Leticia Andrade</h5>\r\n              <span class=\"user-role\">Designer & Coffee Lover</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"testimonial-card\">\r\n          <p class=\"testimonial-text\">\"Os grãos têm notas sensoriais incríveis. Dá para perceber o cuidado desde a escolha do café até o atendimento excelente.\"</p>\r\n          <div class=\"testimonial-user\">\r\n            <div class=\"user-avatar\">MR</div>\r\n            <div>\r\n              <h5 class=\"user-name\">Mateus Ribeiro</h5>\r\n              <span class=\"user-role\">Barista Home</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport BannerComponent from \"@/components/BannerComponent.vue\";\r\n\r\nexport default {\r\n  name: \"HomeView\",\r\n  components: {\r\n    BannerComponent\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* CONFIGURAÇÃO GERAL DA HOME */\r\n.home-container {\r\n  width: 100%;\r\n  padding-bottom: 80px;\r\n  background-color: #fcfbfa; /* Off-white premium */\r\n}\r\n\r\n/* 1. SEÇÃO DE DIFERENCIAIS (GRID E ALINHAMENTO) */\r\n.features-section {\r\n  max-width: 1140px;\r\n  margin: 0 auto 80px auto;\r\n  padding: 0 20px;\r\n  display: grid;\r\n  grid-template-columns: repeat(3, 1fr);\r\n  gap: 30px;\r\n}\r\n\r\n.feature-card {\r\n  background-color: #ffffff;\r\n  padding: 35px 28px;\r\n  border-radius: 24px;\r\n  text-align: left;\r\n  border: 1px solid rgba(43, 27, 18, 0.05);\r\n  box-shadow: 0 10px 30px rgba(43, 27, 18, 0.02);\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.feature-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 15px 35px rgba(43, 27, 18, 0.06);\r\n}\r\n\r\n.feature-icon-wrapper {\r\n  background-color: #f5efe6;\r\n  width: 50px; height: 50px;\r\n  border-radius: 12px;\r\n  display: flex; align-items: center; justify-content: center;\r\n  font-size: 24px;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n/* 2. SEÇÃO DE DESTAQUES (GRID DE PRODUTOS PREMIUM) */\r\n.highlights-section {\r\n  max-width: 1140px;\r\n  margin: 0 auto 90px auto;\r\n  padding: 0 20px;\r\n}\r\n\r\n.highlights-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(3, 1fr);\r\n  gap: 30px;\r\n}\r\n\r\n.product-card {\r\n  background: #ffffff;\r\n  border-radius: 24px;\r\n  overflow: hidden;\r\n  border: 1px solid rgba(43, 27, 18, 0.05);\r\n  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);\r\n  display: flex; flex-direction: column;\r\n}\r\n\r\n.product-card:hover {\r\n  transform: translateY(-8px);\r\n  box-shadow: 0 26px 50px rgba(43, 27, 18, 0.08);\r\n}\r\n\r\n.product-image-container {\r\n  height: 220px;\r\n  overflow: hidden;\r\n}\r\n\r\n.product-image-container img {\r\n  width: 100%; height: 100%;\r\n  object-fit: cover; /* Garante que a foto preencha sem distorcer */\r\n}\r\n\r\n/* Botão interativo \"+\" */\r\n.btn-add-product {\r\n  background-color: #2b1b12;\r\n  color: #ffffff;\r\n  width: 40px; height: 40px;\r\n  border-radius: 50%;\r\n  border: none;\r\n  font-size: 22px;\r\n  cursor: pointer;\r\n  transition: transform 0.2s ease;\r\n}\r\n\r\n.btn-add-product:hover {\r\n  transform: scale(1.1);\r\n}\r\n\r\n/* 3. SEÇÃO DE DEPOIMENTOS (NOVO DIFERENCIAL) */\r\n.testimonials-section {\r\n  max-width: 1140px;\r\n  margin: 0 auto;\r\n  padding: 0 20px;\r\n}\r\n\r\n.testimonials-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(2, 1fr);\r\n  gap: 30px;\r\n}\r\n\r\n.testimonial-card {\r\n  background-color: #f5efe6;\r\n  padding: 30px;\r\n  border-radius: 24px;\r\n}\r\n</style>"],"mappings":"AAkHA,OAAOA,eAAc,MAAO,kCAAkC;AAE9D,eAAe;EACbC,IAAI,EAAE,UAAU;EAChBC,UAAU,EAAE;IACVF;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}