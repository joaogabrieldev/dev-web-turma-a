;\r\n  font-style: italic;\r\n  color: #4a3a30;\r\n  line-height: 1.6;\r\n  margin: 0 0 25px 0;\r\n}\r\n\r\n.testimonial-user {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 15px;\r\n}\r\n\r\n.user-avatar {\r\n  width: 44px;\r\n  height: 44px;\r\n  background-color: #2b1b12;\r\n  color: #ffffff;\r\n  border-radius: 50%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 13px;\r\n  font-weight: 700;\r\n}\r\n\r\n.user-name {\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  font-size: 15px;\r\n  font-weight: 700;\r\n  color: #2b1b12;\r\n  margin: 0 0 2px 0;\r\n}\r\n\r\n.user-role {\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  font-size: 12px;\r\n  color: #8c7667;\r\n}\r\n\r\n/* RESPONSIVIDADE COMPLETA */\r\n@media (max-width: 992px) {\r\n  .highlights-grid { grid-template-columns: repeat(2, 1fr); }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .features-section, .highlights-grid, .testimonials-grid {\r\n    grid-template-columns: 1fr;\r\n    gap: 24px;\r\n  }\r\n  .section-title { font-size: 28px; }\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAgB;;EAChBA,KAAK,EAAC;AAAc;;;uBAD/BC,mBAAA,CA6GM,OA7GNC,UA6GM,GA5GJC,mBAAA,CAEU,WAFVC,UAEU,GADRC,YAAA,CAAmBC,0BAAA,E","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}