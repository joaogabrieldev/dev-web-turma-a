{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuCafeteria: []\n    };\n  },\n  methods: {\n    async consultarMenu() {\n      const response = await fetch(`${this.$apiUrl}/menu`);\n      const dados = await response.json();\n\n      // Salvando na variável correta que você declarou na linha 31!\n      this.listaMenuCafeteria = dados.cafes || dados.burgues || [];\n      console.log(this.listaMenuCafeteria);\n    },\n    selecionarItem(itemSelecionado) {\n      const param = JSON.stringify(itemSelecionado);\n      const itemJson = encodeURIComponent(param);\n      this.$router.push({\n        path: \"/config\",\n        query: {\n          produto: itemJson\n        }\n      });\n    }\n  },\n  mounted() {\n    this.consultarMenu();\n  }\n};","map":{"version":3,"names":["name","data","listaMenuCafeteria","methods","consultarMenu","response","fetch","$apiUrl","dados","json","cafes","burgues","console","log","selecionarItem","itemSelecionado","param","JSON","stringify","itemJson","encodeURIComponent","$router","push","path","query","produto","mounted"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\MenuView.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <h1>Menu da Cafeteria</h1>\r\n    <div id=\"scroll-horizontal\">\r\n      <div\r\n        id=\"card-content\"\r\n        v-for=\"item in listaMenuCafeteria\" :key=\"item.id\"\r\n        \r\n      >\r\n        <div id=\"card-linha\">\r\n          <div class=\"foto-produto\">\r\n            <img :src=\"item.foto\" :alt=\"item.nome\" />\r\n            <div class=\"card-coluna\">\r\n              <p id=\"nome-content\">{{ item.nome }}</p>\r\n              <p id=\"preco-content\">R$ {{ item.valor }},00</p>\r\n              <p id=\"descricao-content\">{{ item.descricao }}</p>\r\n              <button @click=\"selecionarItem(item)\">Selecionar</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"MenuView\",\r\n  data() {\r\n    return {\r\n      listaMenuCafeteria: [],\r\n    };\r\n  },\r\n  methods: {\r\nasync consultarMenu() {\r\n  const response = await fetch(`${this.$apiUrl}/menu`);\r\n  const dados = await response.json();\r\n  \r\n  // Salvando na variável correta que você declarou na linha 31!\r\n  this.listaMenuCafeteria = dados.cafes || dados.burgues || [];\r\n  console.log(this.listaMenuCafeteria);\r\n},\r\n    selecionarItem(itemSelecionado) {\r\n      const param = JSON.stringify(itemSelecionado);\r\n      const itemJson = encodeURIComponent(param);\r\n      this.$router.push({ path: \"/config\", query: { produto: itemJson } });\r\n    },\r\n  },\r\n  mounted() {\r\n    this.consultarMenu();\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.menu-container {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  padding: 30px 20px;\r\n}\r\n\r\n.title-menu {\r\n  font-size: 28px;\r\n  font-weight: 700;\r\n  margin-bottom: 25px;\r\n  color: #1c1612;\r\n  text-align: left;\r\n}\r\n\r\n/* Grid para alinhar os cards lado a lado */\r\n.grid-produtos {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));\r\n  gap: 25px;\r\n}\r\n\r\n/* Estilo do Card Branco */\r\n.card-produto {\r\n  background-color: #ffffff;\r\n  border-radius: 24px; /* Cantos bem arredondados como na foto */\r\n  padding: 20px;\r\n  box-shadow: 0px 8px 24px rgba(180, 160, 140, 0.08); /* Sombra suave */\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  text-align: left;\r\n}\r\n\r\n.foto-wrapper {\r\n  background-color: #f5f5f7;\r\n  border-radius: 18px;\r\n  width: 100%;\r\n  height: 180px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  margin-bottom: 15px;\r\n  overflow: hidden;\r\n}\r\n\r\n.foto-wrapper img {\r\n  max-height: 80%;\r\n  object-fit: contain;\r\n}\r\n\r\n.info-produto {\r\n  width: 100%;\r\n}\r\n\r\n.nome-produto {\r\n  font-size: 18px;\r\n  font-weight: 600;\r\n  color: #2c2520;\r\n  margin-bottom: 4px;\r\n}\r\n\r\n.preco-produto {\r\n  font-size: 16px;\r\n  font-weight: 700;\r\n  color: #e79961; /* Cor de destaque do preço */\r\n  margin-bottom: 12px;\r\n}\r\n\r\n/* Botão \"Add to Cart\" / \"Selecionar\" */\r\n.btn-selecionar {\r\n  width: 100%;\r\n  padding: 12px;\r\n  background-color: #f7ebe1; /* Fundo pastel desbotado */\r\n  color: #b5764d; /* Texto marrom alaranjado */\r\n  font-weight: 600;\r\n  border-radius: 14px;\r\n}\r\n\r\n.btn-selecionar:hover {\r\n  background-color: #e79961;\r\n  color: #ffffff;\r\n}\r\n</style>"],"mappings":";AA0BA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,kBAAkB,EAAE;IACtB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACX,MAAMC,aAAaA,CAAA,EAAG;MACpB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,OAAO,CAAC;MACpD,MAAMC,KAAI,GAAI,MAAMH,QAAQ,CAACI,IAAI,CAAC,CAAC;;MAEnC;MACA,IAAI,CAACP,kBAAiB,GAAIM,KAAK,CAACE,KAAI,IAAKF,KAAK,CAACG,OAAM,IAAK,EAAE;MAC5DC,OAAO,CAACC,GAAG,CAAC,IAAI,CAACX,kBAAkB,CAAC;IACtC,CAAC;IACGY,cAAcA,CAACC,eAAe,EAAE;MAC9B,MAAMC,KAAI,GAAIC,IAAI,CAACC,SAAS,CAACH,eAAe,CAAC;MAC7C,MAAMI,QAAO,GAAIC,kBAAkB,CAACJ,KAAK,CAAC;MAC1C,IAAI,CAACK,OAAO,CAACC,IAAI,CAAC;QAAEC,IAAI,EAAE,SAAS;QAAEC,KAAK,EAAE;UAAEC,OAAO,EAAEN;QAAS;MAAE,CAAC,CAAC;IACtE;EACF,CAAC;EACDO,OAAOA,CAAA,EAAG;IACR,IAAI,CAACtB,aAAa,CAAC,CAAC;EACtB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}