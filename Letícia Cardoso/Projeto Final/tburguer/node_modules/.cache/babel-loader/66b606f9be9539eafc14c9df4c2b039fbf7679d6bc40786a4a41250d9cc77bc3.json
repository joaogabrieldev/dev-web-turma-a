          <label \r\n            v-for=\"ponto in listaPontos\" \r\n            :key=\"ponto.id\" \r\n            :class=\"['radio-card', { selected: pontoSelecionado === ponto.id }]\"\r\n          >\r\n            <input \r\n              type=\"radio\" \r\n              name=\"ponto\" \r\n              :value=\"ponto.id\" \r\n              v-model=\"pontoSelecionado\"\r\n            />\r\n            <span class=\"radio-label\">{{ ponto.tipo || ponto.nome || ponto.tamanho || 'Opção' }}</span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"options-group\">\r\n        <h3>Adicionais (Opcional)</h3>\r\n        <div class=\"checkbox-list\">\r\n          <label \r\n            v-for=\"opcional in listaOpcionais\" \r\n            :key=\"opcional.id\" \r\n            :class=\"['checkbox-item', { checked: opcionaisSelecionados.includes(opcional.id) }]\"\r\n          >\r\n            <div class=\"checkbox-wrapper\">\r\n              <input \r\n                type=\"checkbox\" \r\n                :value=\"opcional.id\" \r\n                v-model=\"opcionaisSelecionados\"\r\n              />\r\n              <span class=\"opcional-name\">{{ opcional.nome || opcional.tipo || 'Adicional' }}</span>\r\n            </div>\r\n            <span class=\"opcional-price\">+ R$ {{ formatarPreco(opcional.valor) }}</span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"ConfiguracaoPedidoView\",\r\n  data() {\r\n    return {\r\n      produto: null, // Alinhado com o nome do v-if do template\r\n      listaPontos: [],\r\n      listaOpcionais: [],\r\n      pontoSelecionado: null,\r\n      opcionaisSelecionados: []\r\n    };\r\n  },\r\n  computed: {\r\n    valorTotal() {\r\n      let total = 0;\r\n      if (this.produto && this.produto.valor) {\r\n        total += parseFloat(this.produto.valor);\r\n      }\r\n      \r\n      this.opcionaisSelecionados.forEach(id => {\r\n        const item = this.listaOpcionais.find(o => o.id === id);\r\n        if (item) {\r\n          total += parseFloat(item.valor);\r\n        }\r\n      });\r\n      \r\n      return total;\r\n    }\r\n  },\r\n  methods: {\r\n    async carregarDadosCustomizacao() {\r\n      try {\r\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n        this.listaPontos = await resPontos.json();\r\n        if (this.listaPontos.length > 0) {\r\n          this.pontoSelecionado = this.listaPontos[0].id;\r\n        }\r\n\r\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\r\n        this.listaOpcionais = await resOpcionais.json();\r\n      } catch (error) {\r\n        console.error(\"Erro ao carregar opções:\", error);\r\n      }\r\n    },\r\n    async enviarParaCarrinho() {\r\n      if (!this.pontoSelecionado) {\r\n        alert(\"Por favor, selecione um tamanho ou ponto!\");\r\n        return;\r\n      }\r\n\r\n      const opcionaisDetalhados = this.opcionaisSelecionados.map(id => {\r\n        return this.listaOpcionais.find(o => o.id === id);\r\n      });\r\n\r\n      const pontoEscolhido = this.listaPontos.find(p => p.id === this.pontoSelecionado);\r\n\r\n      const pedidoPayload = {\r\n        nome_cafe: this.produto.nome,\r\n        foto_cafe: this.produto.foto,\r\n        valor_total: this.valorTotal.toFixed(2),\r\n        ponto: pontoEscolhido ? pontoEscolhido.tipo : \"\",\r\n        opcionais: opcionaisDetalhados,\r\n        status: \"Em preparação\"\r\n      };\r\n\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify(pedidoPayload)\r\n        });\r\n\r\n        if (response.ok) {\r\n          alert(\"Pedido adicionado com sucesso!\");\r\n          this.$router.push(\"/pedidos\");\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao salvar pedido:\", error);\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    // Captura o produto vindo da rota e preenche a variável correta\r\n    const query = this.$route.query;\r\n    if (query.produto) {\r\n      this.produto = JSON.parse(decodeURIComponent(query.produto));\r\n    }\r\n    this.carregarDadosCustomizacao();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.config-container {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 50px;\r\n  max-width: 1200px;\r\n  margin: 120px auto 30px auto; /* Aumentado o margin-top para não ficar embaixo da navbar fixa */\r\n  padding: 0 20px;\r\n}\r\n\r\n.product-preview {\r\n  background-color: #f7f3ee;\r\n  border-radius: 24px;\r\n  padding: 25px;\r\n  box-shadow: 0 10px 25px rgba(43, 27, 18, 0.03);\r\n  text-align: left;\r\n  height: fit-content;\r\n}\r\n\r\n.image-box {\r\n  width: 100%;\r\n  height: 350px;\r\n  border-radius: 16px;\r\n  overflow: hidden;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.image-box img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.product-info h2 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 28px;\r\n  color: #2b1b12;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.base-price {\r\n  font-size: 18px;\r\n  font-weight: 600;\r\n  color: #523b2e;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.description {\r\n  color: #615045;\r\n  font-size: 14px;\r\n  line-height: 1.6;\r\n}\r\n\r\n.customization-form {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 30px;\r\n  text-align: left;\r\n}\r\n\r\n.options-group h3 {\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  font-size: 16px;\r\n  color: #2b1b12;\r\n  margin-bottom: 15px;\r\n  border-bottom: 1px solid rgba(43, 27, 18, 0.1);\r\n  padding-bottom: 8px;\r\n}\r\n\r\n.radio-grid {\r\n  display: flex;\r\n  gap: 12px;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n.radio-card {\r\n  border: 1px solid rgba(43, 27, 18, 0.2);\r\n  padding: 12px 20px;\r\n  border-radius: 12px;\r\n  cursor: pointer;\r\n  transition: all 0.2s ease;\r\n  background-color: #fff;\r\n}\r\n\r\n.radio-card input {\r\n  display: none;\r\n}\r\n\r\n.radio-card:hover {\r\n  background-color: rgba(43, 27, 18, 0.03);\r\n}\r\n\r\n.radio-card.selected {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  border-color: #2b1b12;\r\n}\r\n\r\n.checkbox-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n}\r\n\r\n.checkbox-item {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: 14px 20px;\r\n  border-radius: 14px;\r\n  background-color: #f7f3ee;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.checkbox-wrapper {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n}\r\n\r\n.checkbox-item:hover {\r\n  background-color: #f0e9e1;\r\n}\r\n\r\n.opcional-price {\r\n  font-weight: 600;\r\n  color: #523b2e;\r\n}\r\n\r\n.summary-section {\r\n  margin-top: 20px;\r\n  background-color: #2b1b12;\r\n  padding: 25px;\r\n  border-radius: 20px;\r\n  color: #f7f3ee;\r\n}\r\n\r\n.price-row {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  font-size: 18px;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.total-price {\r\n  font-size: 24px;\r\n  font-weight: 700;\r\n}\r\n\r\n.btn-submit {\r\n  width: 100%;\r\n  background-color: #f7f3ee;\r\n  color: #2b1b12;\r\n  border: none;\r\n  padding: 16px;\r\n  border-radius: 12px;\r\n  font-weight: 600;\r\n  font-size: 16px;\r\n  cursor: pointer;\r\n  transition: transform 0.1s, background-color 0.2s;\r\n}\r\n\r\n.btn-submit:hover {\r\n  background-color: #e6dfd5;\r\n}\r\n</style>"],"mappings":";;;EACKA,KAAK,EAAC;AAAe;;EAEbA,KAAK,EAAC;AAAY;;;EAYbA,KAAK,EAAC;AAAa;;EAK1BA,KAAK,EAAC;AAAe;;EAEnBA,KAAK,EAAC;AAAe;;EAMjBA,KAAK,EAAC;AAAkB;;;EAMrBA,KAAK,EAAC;AAAe;;EAEvBA,KAAK,EAAC;AAAgB;;6DAnCxCC,mBAAA,CAiBY,OAjBZC,UAiBY,G,0BAhBJD,mBAAA,CAAkC,YAA9B,2BAAyB,qBAC7BA,mBAAA,CAcM,OAdNE,UAcM,I,kBAbJC,mBAAA,CAYQC,SAAA,QAAAC,WAAA,CAXUC,KAAA,CAAAC,WAAW,EAApBC,KAAK;yBADdL