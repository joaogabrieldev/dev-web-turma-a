cache[0] = $event => $data.adicionaisSelecionados = $event),\n      class: \"addon-checkbox\"\n    }, null, 8 /* PROPS */, _hoisted_17), [[_vModelCheckbox, $data.adicionaisSelecionados]]), _createElementVNode(\"span\", _hoisted_18, _toDisplayString(adicional.nome), 1 /* TEXT */)]), _cache[3] || (_cache[3] = _createElementVNode(\"span\", {\n      class: \"addon-price\"\n    }, \"Grátis\", -1 /* CACHED */))]);\n  }), 128 /* KEYED_FRAGMENT */))])]), _createElementVNode(\"div\", _hoisted_19, [_createElementVNode(\"div\", _hoisted_20, [_cache[5] || (_cache[5] = _createElementVNode(\"span\", {\n    class: \"total-label\"\n  }, \"Total do Item:\", -1 /* CACHED */)), _createElementVNode(\"span\", _hoisted_21, \"R$ \" + _toDisplayString($options.formatarPreco($options.calcularTotal)), 1 /* TEXT */)]), _createElementVNode(\"button\", {\n    type: \"button\",\n    onClick: _cache[1] || (_cache[1] = (...args) => $options.enviarPedido && $options.enviarPedido(...args)),\n    class: \"btn-submit\"\n  }, \" Confirmar e Adicionar \")])])])])) : (_openBlock(), _createElementBlock(\"div\", _hoisted_22, [...(_cache[6] || (_cache[6] = [_createElementVNode(\"p\", null, \"Carregando dados do produto...\", -1 /* CACHED */)]))]));\n}","map":{"version":3,"names":["class","$data","produto","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_hoisted_3","_hoisted_4","src","foto","alt","nome","_hoisted_6","_toDisplayString","_hoisted_7","$options","formatarPreco","valor","descricao","_hoisted_8","_hoisted_9","_hoisted_10","_hoisted_11","_hoisted_12","_Fragment","_renderList","listaTamanhos","tamanho","key","id","type","_normalizeClass","active","tamanhoSelecionado","onClick","$event","selecionarTamanho","_hoisted_13","_hoisted_14","_hoisted_15","listaAdicionais","adicional","_hoisted_16","value","adicionaisSelecionados","_hoisted_18","_hoisted_19","_hoisted_20","_hoisted_21","calcularTotal","_cache","args","enviarPedido","_hoisted_22"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\ConfiguracaoPedidoView.vue"],"sourcesContent":["<template>\r\n  <div class=\"config-container\" v-if=\"produto\">\r\n    <div class=\"config-card\">\r\n      <div class=\"product-summary-side\">\r\n        <div class=\"product-image-container\">\r\n          <img :src=\"produto.foto\" :alt=\"produto.nome\" class=\"product-image\" />\r\n        </div>\r\n        <h2 class=\"product-title\">{{ produto.nome }}</h2>\r\n        <p class=\"product-base-price\">Preço base: R$ {{ formatarPreco(produto.valor) }}</p>\r\n        <p class=\"product-description\" v-if=\"produto.descricao\">{{ produto.descricao }}</p>\r\n        <p class=\"product-description\" v-else>\r\n          Produto artesanal preparado com ingredientes selecionados de alta qualidade.\r\n        </p>\r\n      </div>\r\n\r\n      <div class=\"customization-side\">\r\n        <div class=\"options-group\">\r\n          <h3 class=\"group-title\">Escolha o Tamanho / Ponto</h3>\r\n          <div class=\"sizes-grid\">\r\n            <button \r\n              v-for=\"tamanho in listaTamanhos\" \r\n              :key=\"tamanho.id\"\r\n              type=\"button\"\r\n              :class=\"['btn-size', { active: tamanhoSelecionado?.id === tamanho.id }]\"\r\n              @click=\"selecionarTamanho(tamanho)\"\r\n            >\r\n              {{ tamanho.descricao }}\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"options-group\">\r\n          <h3 class=\"group-title\">Adicionais (Opcional)</h3>\r\n          <div class=\"addons-list\">\r\n            <label v-for=\"adicional in listaAdicionais\" :key=\"adicional.id\" class=\"addon-item\">\r\n              <div class=\"addon-left\">\r\n                <input \r\n                  type=\"checkbox\" \r\n                  :value=\"adicional\" \r\n                  v-model=\"adicionaisSelecionados\" \r\n                  class=\"addon-checkbox\"\r\n                />\r\n                <span class=\"addon-name\">{{ adicional.nome }}</span>\r\n              </div>\r\n              <span class=\"addon-price\">Grátis</span>\r\n            </label>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"footer-action-bar\">\r\n          <div class=\"price-row\">\r\n            <span class=\"total-label\">Total do Item:</span>\r\n            <span class=\"total-price\">R$ {{ formatarPreco(calcularTotal) }}</span>\r\n          </div>\r\n          <button type=\"button\" @click=\"enviarPedido\" class=\"btn-submit\">\r\n            Confirmar e Adicionar\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"loading-container\" v-else>\r\n    <p>Carregando dados do produto...</p>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"ConfiguracaoPedidoView\",\r\n  data() {\r\n    return {\r\n      produto: null,\r\n      listaTamanhos: [],\r\n      listaAdicionais: [],\r\n      tamanhoSelecionado: null,\r\n      adicionaisSelecionados: [],\r\n      // Estado interno para alertas (interligado com seu AlertaComponent se houver)\r\n      alerta: {\r\n        mensagem: \"\",\r\n        tipo: \"info\",\r\n        visivel: false\r\n      }\r\n    };\r\n  },\r\n  computed: {\r\n    calcularTotal() {\r\n      if (!this.produto) return 0;\r\n      // Adicionais marcados como \"Grátis\", então mantém o preço base do produto\r\n      return parseFloat(this.produto.valor);\r\n    }\r\n  },\r\n  methods: {\r\n    formatarPreco(valor) {\r\n      if (!valor) return \"0.00\";\r\n      const num = parseFloat(String(valor).replace(\",\", \".\"));\r\n      return isNaN(num) ? \"0.00\" : num.toFixed(2);\r\n    },\r\n    selecionarTamanho(tamanho) {\r\n      this.tamanhoSelecionado = tamanho;\r\n    },\r\n    // CORRIGIDO: Removido o erro de 'mensaje is not defined'\r\n    mostrarAlerta(mensagem, tipo = \"success\") {\r\n      this.alerta.mensagem = mensagem;\r\n      this.alerta.tipo = tipo;\r\n      this.alerta.visivel = true;\r\n\r\n      // Se você usa o window.alert clássico para testes:\r\n      alert(mensagem);\r\n\r\n      setTimeout(() => {\r\n        this.alerta.visivel = false;\r\n      }, 3500);\r\n    },\r\n    async carregarDadosCustomizacao() {\r\n      try {\r\n        // Busca os tamanhos do seu db.json via json-server\r\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n        this.listaTamanhos = await resPontos.json();\r\n        \r\n        // Define o primeiro tamanho como padrão se houver\r\n        if (this.listaTamanhos.length > 0) {\r\n          this.tamanhoSelecionado = this.listaTamanhes ? this.listaTamanhos[0] : null;\r\n        }\r\n\r\n        // Busca os opcionais/complementos do seu db.json\r\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\r\n        const dadosOpcionais = await resOpcionais.json();\r\n        this.listaAdicionais = dadosOpcionais.complemento || [];\r\n      } catch (error) {\r\n        console.error(\"Erro ao carregar dados de customização:\", error);\r\n        this.mostrarAlerta(\"Erro ao conectar com o servidor.\", \"danger\");\r\n      }\r\n    },\r\n    async enviarPedido() {\r\n      if (!this.tamanhoSelecionado) {\r\n        this.mostrarAlerta(\"Por favor, selecione um tamanho/ponto.\", \"warning\");\r\n        return;\r\n      }\r\n\r\n      // Monta o objeto final esperado pela cozinha / aba de pedidos\r\n      const novoPedido = {\r\n        nome: this.produto.nome,\r\n        foto: this.produto.foto,\r\n        opcao: this.tamanhoSelecionado.descricao,\r\n        adicionais: this.adicionaisSelecionados.map(a => a.nome),\r\n        valor: this.calcularTotal,\r\n        status: \"Na Fila\" // Mapeado conforme seu db.json\r\n      };\r\n\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify(novoPedido)\r\n        });\r\n\r\n        if (response.ok) {\r\n          this.mostrarAlerta(\"Pedido enviado para a cozinha do Âmbar Café!\");\r\n          this.$router.push(\"/pedidos\");\r\n        } else {\r\n          this.mostrarAlerta(\"Falha ao salvar o pedido.\", \"danger\");\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao enviar pedido:\", error);\r\n        this.mostrarAlerta(\"Erro de rede ao enviar pedido.\", \"danger\");\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    // Recupera o produto enviado pela Home ou Menu através da Query String\r\n    if (this.$route.query.produto) {\r\n      try {\r\n        this.produto = JSON.parse(decodeURIComponent(this.$route.query.produto));\r\n      } catch (e) {\r\n        console.error(\"Erro ao parsear produto da query:\", e);\r\n      }\r\n    }\r\n    this.carregarDadosCustomizacao();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.config-container {\r\n  max-width: 1040px;\r\n  margin: 100px auto 40px auto;\r\n  padding: 0 20px;\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n}\r\n\r\n.config-card {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 40px;\r\n  background-color: #f5efe6;\r\n  border-radius: 32px;\r\n  padding: 40px;\r\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);\r\n}\r\n\r\n/* LADO ESQUERDO: RESUMO */\r\n.product-summary-side {\r\n  background-color: #faf6f0;\r\n  padding: 30px;\r\n  border-radius: 24px;\r\n  text-align: left;\r\n}\r\n\r\n.product-image-container {\r\n  width: 100%;\r\n  height: 320px;\r\n  border-radius: 20px;\r\n  overflow: hidden;\r\n  margin-bottom: 25px;\r\n}\r\n\r\n.product-image {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.product-title {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 32px;\r\n  color: #2b1b12;\r\n  margin: 0 0 10px 0;\r\n}\r\n\r\n.product-base-price {\r\n  font-size: 18px;\r\n  font-weight: 600;\r\n  color: #615045;\r\n  margin: 0 0 15px 0;\r\n}\r\n\r\n.product-description {\r\n  font-size: 14px;\r\n  color: #7a6a5e;\r\n  line-height: 1.6;\r\n  margin: 0;\r\n}\r\n\r\n/* LADO DIREITO: SELEÇÃO */\r\n.customization-side {\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: space-between;\r\n  text-align: left;\r\n}\r\n\r\n.options-group {\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.group-title {\r\n  font-size: 16px;\r\n  font-weight: 700;\r\n  color: #2b1b12;\r\n  margin-0-0-15px-0;\r\n  border-bottom: 1px solid rgba(43, 27, 18, 0.08);\r\n  padding-bottom: 8px;\r\n}\r\n\r\n/* BOTÕES DE TAMANHO */\r\n.sizes-grid {\r\n  display: flex;\r\n  gap: 12px;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n.btn-size {\r\n  background-color: #ffffff;\r\n  color: #2b1b12;\r\n  border: 1px solid rgba(43, 27, 18, 0.1);\r\n  padding: 12px 20px;\r\n  border-radius: 12px;\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n  cursor: pointer;\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n.btn-size:hover {\r\n  background-color: #f0e6da;\r\n}\r\n\r\n.btn-size.active {\r\n  background-color: #2b1b12;\r\n  color: #ffffff;\r\n  border-color: #2b1b12;\r\n}\r\n\r\n/* LISTA DE ADICIONAIS */\r\n.addons-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n}\r\n\r\n.addon-item {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  background-color: #ffffff;\r\n  padding: 14px 20px;\r\n  border-radius: 14px;\r\n  cursor: pointer;\r\n  border: 1px solid rgba(43, 27, 18, 0.02);\r\n  transition: background-color 0.15s;\r\n}\r\n\r\n.addon-item:hover {\r\n  background-color: #fcfbfa;\r\n}\r\n\r\n.addon-left {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n}\r\n\r\n.addon-checkbox {\r\n  width: 18px;\r\n  height: 18px;\r\n  accent-color: #2b1b12;\r\n  cursor: pointer;\r\n}\r\n\r\n.addon-name {\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n  color: #2b1b12;\r\n}\r\n\r\n.addon-price {\r\n  font-size: 13px;\r\n  color: #615045;\r\n  font-weight: 500;\r\n}\r\n\r\n/* FIXAÇÃO DO FOOTER */\r\n.footer-action-bar {\r\n  background-color: #2b1b12;\r\n  padding: 24px;\r\n  border-radius: 20px;\r\n  color: #f7f3ee;\r\n  margin-top: auto;\r\n}\r\n\r\n.price-row {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 16px;\r\n}\r\n\r\n.total-label {\r\n  font-size: 15px;\r\n  opacity: 0.85;\r\n}\r\n\r\n.total-price {\r\n  font-size: 26px;\r\n  font-weight: 700;\r\n}\r\n\r\n.btn-submit {\r\n  width: 100%;\r\n  background-color: #f7f3ee;\r\n  color: #2b1b12;\r\n  border: none;\r\n  padding: 16px;\r\n  border-radius: 14px;\r\n  font-size: 16px;\r\n  font-weight: 700;\r\n  cursor: pointer;\r\n  transition: transform 0.1s, background-color 0.2s;\r\n}\r\n\r\n.btn-submit:hover {\r\n  background-color: #e6dfd5;\r\n  transform: scale(1.01);\r\n}\r\n\r\n.loading-container {\r\n  text-align: center;\r\n  padding: 100px 20px;\r\n  color: #615045;\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .config-card {\r\n    grid-template-columns: 1fr;\r\n    padding: 20px;\r\n  }\r\n}\r\n</style>"],"mappings":";;;EACOA,KAAK,EAAC;;;EACJA,KAAK,EAAC;AAAa;;EACjBA,KAAK,EAAC;AAAsB;;EAC1BA,KAAK,EAAC;AAAyB;;;EAGhCA,KAAK,EAAC;AAAe;;EACtBA,KAAK,EAAC;AAAoB;;;EAC1BA,KAAK,EAAC;;;;EACNA,KAAK,EAAC;;;EAKNA,KAAK,EAAC;AAAoB;;EACxBA,KAAK,EAAC;AAAe;;EAEnBA,KAAK,EAAC;AAAY;;;EAapBA,KAAK,EAAC;AAAe;;EAEnBA,KAAK,EAAC;AAAa;;EAEfA,KAAK,EAAC;AAAY;;;EAOfA,KAAK,EAAC;AAAY;;EAO3BA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAAW;;EAEdA,KAAK,EAAC;AAAa;;;EAS9BA,KAAK,EAAC;;;SA5DyBC,KAAA,CAAAC,OAAO,I,cAA3CC,mBAAA,CA2DM,OA3DNC,UA2DM,GA1DJC,mBAAA,CAyDM,OAzDNC,UAyDM,GAxDJD,mBAAA,CAUM,OAVNE,UAUM,GATJF,mBAAA,CAEM,OAFNG,UAEM,GADJH,mBAAA,CAAqE;IAA/DI,GAAG,EAAER,KAAA,CAAAC,OAAO,CAACQ,IAAI;IAAGC,GAAG,EAAEV,KAAA,CAAAC,OAAO,CAACU,IAAI;IAAEZ,KAAK,EAAC;yCAErDK,mBAAA,CAAiD,MAAjDQ,UAAiD,EAAAC,gBAAA,CAApBb,KAAA,CAAAC,OAAO,CAACU,IAAI,kBACzCP,mBAAA,CAAmF,KAAnFU,UAAmF,EAArD,iBAAe,GAAAD,gBAAA,CAAGE,QAAA,CAAAC,aAAa,CAAChB,KAAA,CAAAC,OAAO,CAACgB,KAAK,mBAC