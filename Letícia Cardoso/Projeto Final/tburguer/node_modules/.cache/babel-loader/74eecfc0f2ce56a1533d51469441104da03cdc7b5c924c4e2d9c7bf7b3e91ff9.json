{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuCafeteria: [],\n      categoriaAtiva: 'todos' // Controla qual categoria está selecionada\n    };\n  },\n  computed: {\n    // Esta propriedade filtra a lista de forma automática e dinâmica\n    produtosFiltrados() {\n      if (this.categoriaAtiva === 'todos') {\n        return this.listaMenuCafeteria;\n      }\n      return this.listaMenuCafeteria.filter(item => item.categoria === this.categoriaAtiva);\n    }\n  },\n  methods: {\n    async consultarMenu() {\n      try {\n        const response = await fetch(`${this.$apiUrl}/menu`);\n        const dados = await response.json();\n\n        // CORREÇÃO: Como o json-server mapeia a rota /menu diretamente para a lista,\n        // ou se ele retornar o objeto completo, garantimos que pegamos a array correta:\n        if (Array.isArray(dados)) {\n          this.listaMenuCafeteria = dados;\n        } else if (dados && dados.menu) {\n          this.listaMenuCafeteria = dados.menu;\n        } else {\n          this.listaMenuCafeteria = [];\n        }\n      } catch (error) {\n        console.error(\"Erro ao buscar o menu:\", error);\n      }\n    },\n    selecionarItem(item) {\n      const param = JSON.stringify(item);\n      const itemJson = encodeURIComponent(param);\n      this.$router.push({\n        path: \"/config\",\n        query: {\n          produto: itemJson\n        }\n      });\n    }\n  },\n  mounted() {\n    this.consultarMenu();\n  }\n};","map":{"version":3,"names":["name","data","listaMenuCafeteria","categoriaAtiva","computed","produtosFiltrados","filter","item","categoria","methods","consultarMenu","response","fetch","$apiUrl","dados","json","Array","isArray","menu","error","console","selecionarItem","param","JSON","stringify","itemJson","encodeURIComponent","$router","push","path","query","produto","mounted"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\MenuView.vue"],"sourcesContent":["<template>\r\n  <div class=\"menu-section\">\r\n    <div class=\"section-header\">\r\n      <h2>Nossas Especialidades</h2>\r\n      <p>Escolha o seu café perfeito, preparado por baristas experientes.</p>\r\n    </div>\r\n\r\n    <div class=\"filter-container\">\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'todos' }]\" \r\n        @click=\"categoriaAtiva = 'todos'\"\r\n      >\r\n        Todos\r\n      </button>\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'bebidas' }]\" \r\n        @click=\"categoriaAtiva = 'bebidas'\"\r\n      >\r\n        Bebidas\r\n      </button>\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'lanches' }]\" \r\n        @click=\"categoriaAtiva = 'lanches'\"\r\n      >\r\n        Lanches\r\n      </button>\r\n    </div>\r\n\r\n    <div class=\"grid-cafes\">\r\n      <div class=\"cafe-card\" v-for=\"item in produtosFiltrados\" :key=\"item.id\">\r\n        <div class=\"image-container\">\r\n          <img :src=\"item.foto\" :alt=\"item.nome\" />\r\n        </div>\r\n        <div class=\"card-body\">\r\n          <div class=\"card-meta\">\r\n            <h3>{{ item.nome }}</h3>\r\n            <span class=\"price\">R$ {{ item.valor }}</span>\r\n          </div>\r\n          <p class=\"description\">\r\n            {{ item.descricao || 'Grãos premium moídos na hora com extração balanceada.' }}\r\n          </p>\r\n          <button class=\"btn-add\" @click=\"selecionarItem(item)\">\r\n            <span>Selecionar Opção</span>\r\n            <i class=\"arrow\">→</i>\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"MenuView\",\r\n  data() {\r\n    return {\r\n      listaMenuCafeteria: [],\r\n      categoriaAtiva: 'todos' // Controla qual categoria está selecionada\r\n    };\r\n  },\r\n  computed: {\r\n    // Esta propriedade filtra a lista de forma automática e dinâmica\r\n    produtosFiltrados() {\r\n      if (this.categoriaAtiva === 'todos') {\r\n        return this.listaMenuCafeteria;\r\n      }\r\n      return this.listaMenuCafeteria.filter(item => item.categoria === this.categoriaAtiva);\r\n    }\r\n  },\r\n  methods: {\r\n   async consultarMenu() {\r\n      try {\r\n        const response = await fetch(`${this.$apiUrl}/menu`);\r\n        const dados = await response.json();\r\n        \r\n        // CORREÇÃO: Como o json-server mapeia a rota /menu diretamente para a lista,\r\n        // ou se ele retornar o objeto completo, garantimos que pegamos a array correta:\r\n        if (Array.isArray(dados)) {\r\n          this.listaMenuCafeteria = dados;\r\n        } else if (dados && dados.menu) {\r\n          this.listaMenuCafeteria = dados.menu;\r\n        } else {\r\n          this.listaMenuCafeteria = [];\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao buscar o menu:\", error);\r\n      }\r\n    },\r\n    selecionarItem(item) {\r\n      const param = JSON.stringify(item);\r\n      const itemJson = encodeURIComponent(param);\r\n      this.$router.push({ path: \"/config\", query: { produto: itemJson } });\r\n    }\r\n  },\r\n  mounted() {\r\n    this.consultarMenu();\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.menu-section {\r\n  padding: 40px 40px 60px 40px;\r\n  max-width: 1300px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.section-header {\r\n  margin-bottom: 35px;\r\n  text-align: left;\r\n}\r\n\r\n.section-header h2 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 36px;\r\n  margin-bottom: 8px;\r\n  color: #2b1b12;\r\n}\r\n\r\n.section-header p {\r\n  color: #615045;\r\n  font-size: 16px;\r\n}\r\n\r\n/* Container dos Filtros */\r\n.filter-container {\r\n  display: flex;\r\n  gap: 15px;\r\n  margin-bottom: 40px;\r\n}\r\n\r\n.filter-btn {\r\n  background-color: transparent;\r\n  color: #615045;\r\n  border: 1px solid rgba(43, 27, 18, 0.2);\r\n  padding: 10px 24px;\r\n  border-radius: 50px; /* Formato pílula idêntico à referência */\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  font-weight: 500;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n.filter-btn:hover {\r\n  background-color: rgba(43, 27, 18, 0.05);\r\n  color: #2b1b12;\r\n}\r\n\r\n/* Botão Ativo (Fundo marrom espresso) */\r\n.filter-btn.active {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  border-color: #2b1b12;\r\n  font-weight: 600;\r\n  box-shadow: 0 4px 12px rgba(43, 27, 18, 0.15);\r\n}\r\n\r\n.grid-cafes {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\r\n  gap: 30px;\r\n}\r\n\r\n.cafe-card {\r\n  background-color: #f7f3ee;\r\n  border-radius: 24px;\r\n  overflow: hidden;\r\n  box-shadow: 0 10px 25px rgba(43, 27, 18, 0.04);\r\n  transition: transform 0.3s, box-shadow 0.3s;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.cafe-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 15px 35px rgba(43, 27, 18, 0.09);\r\n}\r\n\r\n.image-container {\r\n  width: 100%;\r\n  height: 220px;\r\n  overflow: hidden;\r\n  background-color: #dfd7cc;\r\n}\r\n\r\n.image-container img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  transition: transform 0.5s;\r\n}\r\n\r\n.cafe-card:hover .image-container img {\r\n  transform: scale(1.06);\r\n}\r\n\r\n.card-body {\r\n  padding: 22px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  flex-grow: 1;\r\n}\r\n\r\n.card-meta {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: baseline;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.card-meta h3 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 20px;\r\n  font-weight: 700;\r\n  color: #2b1b12;\r\n}\r\n\r\n.price {\r\n  font-weight: 700;\r\n  color: #523b2e;\r\n  font-size: 17px;\r\n}\r\n\r\n.description {\r\n  font-size: 14px;\r\n  color: #615045;\r\n  line-height: 1.5;\r\n  margin-bottom: 20px;\r\n  text-align: left;\r\n  flex-grow: 1;\r\n}\r\n\r\n.btn-add {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  width: 100%;\r\n  padding: 14px 18px;\r\n  border-radius: 14px;\r\n  font-weight: 500;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  border: none;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.btn-add:hover {\r\n  background-color: #4a3427;\r\n}\r\n\r\n.arrow {\r\n  font-style: normal;\r\n  font-weight: bold;\r\n}\r\n</style>"],"mappings":";;;AAoDA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,kBAAkB,EAAE,EAAE;MACtBC,cAAc,EAAE,OAAM,CAAE;IAC1B,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACR;IACAC,iBAAiBA,CAAA,EAAG;MAClB,IAAI,IAAI,CAACF,cAAa,KAAM,OAAO,EAAE;QACnC,OAAO,IAAI,CAACD,kBAAkB;MAChC;MACA,OAAO,IAAI,CAACA,kBAAkB,CAACI,MAAM,CAACC,IAAG,IAAKA,IAAI,CAACC,SAAQ,KAAM,IAAI,CAACL,cAAc,CAAC;IACvF;EACF,CAAC;EACDM,OAAO,EAAE;IACR,MAAMC,aAAaA,CAAA,EAAG;MACnB,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,OAAO,CAAC;QACpD,MAAMC,KAAI,GAAI,MAAMH,QAAQ,CAACI,IAAI,CAAC,CAAC;;QAEnC;QACA;QACA,IAAIC,KAAK,CAACC,OAAO,CAACH,KAAK,CAAC,EAAE;UACxB,IAAI,CAACZ,kBAAiB,GAAIY,KAAK;QACjC,OAAO,IAAIA,KAAI,IAAKA,KAAK,CAACI,IAAI,EAAE;UAC9B,IAAI,CAAChB,kBAAiB,GAAIY,KAAK,CAACI,IAAI;QACtC,OAAO;UACL,IAAI,CAAChB,kBAAiB,GAAI,EAAE;QAC9B;MACF,EAAE,OAAOiB,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,wBAAwB,EAAEA,KAAK,CAAC;MAChD;IACF,CAAC;IACDE,cAAcA,CAACd,IAAI,EAAE;MACnB,MAAMe,KAAI,GAAIC,IAAI,CAACC,SAAS,CAACjB,IAAI,CAAC;MAClC,MAAMkB,QAAO,GAAIC,kBAAkB,CAACJ,KAAK,CAAC;MAC1C,IAAI,CAACK,OAAO,CAACC,IAAI,CAAC;QAAEC,IAAI,EAAE,SAAS;QAAEC,KAAK,EAAE;UAAEC,OAAO,EAAEN;QAAS;MAAE,CAAC,CAAC;IACtE;EACF,CAAC;EACDO,OAAOA,CAAA,EAAG;IACR,IAAI,CAACtB,aAAa,CAAC,CAAC;EACtB;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDepen