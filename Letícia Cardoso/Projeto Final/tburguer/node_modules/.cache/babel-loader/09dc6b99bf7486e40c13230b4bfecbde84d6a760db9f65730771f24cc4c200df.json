teria: []\r\n    };\r\n  },\r\n  methods: {\r\n    async consultarMenu() {\r\n      try {\r\n        const response = await fetch(`${this.$apiUrl}/menu`);\r\n        const dados = await response.json();\r\n        this.listaMenuCafeteria = dados.cafes || dados.burgues || [];\r\n      } catch (error) {\r\n        console.error(\"Erro ao buscar o menu:\", error);\r\n      }\r\n    },\r\n    selecionarItem(item) {\r\n      const param = JSON.stringify(item);\r\n      const itemJson = encodeURIComponent(param);\r\n      this.$router.push({ path: \"/config\", query: { produto: itemJson } });\r\n    }\r\n  },\r\n  mounted() {\r\n    this.consultarMenu();\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.menu-section {\r\n  padding: 60px 40px;\r\n  max-width: 1300px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.section-header {\r\n  margin-bottom: 45px;\r\n  text-align: left;\r\n}\r\n\r\n.section-header h2 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 36px;\r\n  margin-bottom: 8px;\r\n  color: #2b1b12;\r\n}\r\n\r\n.section-header p {\r\n  color: #615045;\r\n  font-size: 16px;\r\n}\r\n\r\n.grid-cafes {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\r\n  gap: 30px;\r\n}\r\n\r\n.cafe-card {\r\n  background-color: #f7f3ee;\r\n  border-radius: 24px;\r\n  overflow: hidden;\r\n  box-shadow: 0 10px 25px rgba(43, 27, 18, 0.04);\r\n  transition: transform 0.3s, box-shadow 0.3s;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.cafe-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 15px 35px rgba(43, 27, 18, 0.09);\r\n}\r\n\r\n.image-container {\r\n  width: 100%;\r\n  height: 220px;\r\n  overflow: hidden;\r\n  background-color: #dfd7cc;\r\n}\r\n\r\n.image-container img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  transition: transform 0.5s;\r\n}\r\n\r\n.cafe-card:hover .image-container img {\r\n  transform: scale(1.06);\r\n}\r\n\r\n.card-body {\r\n  padding: 22px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  flex-grow: 1;\r\n}\r\n\r\n.card-meta {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: baseline;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.card-meta h3 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 20px;\r\n  font-weight: 700;\r\n  color: #2b1b12;\r\n}\r\n\r\n.price {\r\n  font-weight: 700;\r\n  color: #523b2e;\r\n  font-size: 17px;\r\n}\r\n\r\n.description {\r\n  font-size: 14px;\r\n  color: #615045;\r\n  line-height: 1.5;\r\n  margin-bottom: 20px;\r\n  text-align: left;\r\n  flex-grow: 1;\r\n}\r\n\r\n.btn-add {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  width: 100%;\r\n  padding: 14px 18px;\r\n  border-radius: 14px;\r\n  font-weight: 500;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  border: none;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.btn-add:hover {\r\n  background-color: #4a3427;\r\n}\r\n\r\n.arrow {\r\n  font-style: normal;\r\n  font-weight: bold;\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAc;;EAMlBA,KAAK,EAAC;AAAY;;EAEdA,KAAK,EAAC;AAAiB;;;EAGvBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAW;;EAEdA,KAAK,EAAC;AAAO;;EAElBA,KAAK,EAAC;AAAa;;;uBAhB9BC,mBAAA,CA0BM,OA1BNC,UA0BM,G,0BAzBJC,mBAAA,CAGM;IAHDH,KAAK,EAAC;EAAgB,IACzBG,mBAAA,CAA8B,YAA1B,uBAAqB,GACzBA,mBAAA,CAAuE,WAApE,kEAAgE,E,qBAGrEA,mBAAA,CAmBM,OAnBNC,UAmBM,I,kBAlBJH,mBAAA,CAiBMI,SAAA,QAAAC,WAAA,CAjBgCC,KAAA,CAAAC,kBAAkB,EAA1BC,IAAI;yBAAlCR,mBAAA,CAiBM;MAjBDD,KAAK,EAAC,WAAW;MAAqCU,GAAG,EAAED,IAAI,CAACE;QACnER,mBAAA,CAEM,OAFNS,UAEM,GADJT,mBAAA,CAAyC;MAAnCU,GAAG,EAAEJ,IAAI,CAACK,IAAI;MAAGC,GAAG,EAAEN,IAAI,CAACO;2CAEnCb,mBAAA,CAYM,OAZNc,UAYM,GAXJd,mBAAA,CAGM,OAHNe,UAGM,GAFJf,mBAAA,CAAwB,YAAAgB,gBAAA,CAAjBV,IAAI,CAACO,IAAI,kBAChBb,mBAAA,CAA8C,QAA9CiB,UAA8C,EAA1B,KAAG,GAAAD,gBAAA,CAAGV,IAAI,CAACY,KAAK,iB,GAEtClB,mBAAA,CAEI,KAFJmB,UAEI,EAAAH,gBAAA,CADCV,IAAI,CAACc,SAAS,6EAEnBpB,mBAAA,CAGS;MAHDH,KAAK,EAAC,SAAS;MAAEwB,OAAK,EAAAC,MAAA,IAA