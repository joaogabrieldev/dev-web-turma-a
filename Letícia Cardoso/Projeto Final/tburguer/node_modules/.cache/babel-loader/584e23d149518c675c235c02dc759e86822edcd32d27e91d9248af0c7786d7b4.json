{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nexport default {\n  name: \"ConfiguracaoPedidoView\",\n  data() {\n    return {\n      produto: null,\n      listaTamanhos: [],\n      listaAdicionais: [],\n      tamanhoSelecionado: null,\n      adicionaisSelecionados: []\n    };\n  },\n  methods: {\n    formatarPreco(valor) {\n      if (!valor) return \"0.00\";\n      const num = parseFloat(String(valor).replace(\",\", \".\"));\n      return isNaN(num) ? \"0.00\" : num.toFixed(2);\n    },\n    selecionarTamanho(tamanho) {\n      this.tamanhoSelecionado = tamanho;\n    },\n    async carregarDadosCustomizacao() {\n      try {\n        // Conecta com os tamanhos do db.json via json-server\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\n        this.listaTamanhos = await resPontos.json();\n        if (this.listaTamanhos.length > 0) {\n          this.tamanhoSelecionado = this.listaTamanhos[0];\n        }\n\n        // Conecta com os adicionais do db.json\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\n        const dados = await resOpcionais.json();\n        this.listaAdicionais = dados.complemento || [];\n      } catch (error) {\n        console.error(\"Erro ao sincronizar com o db.json:\", error);\n      }\n    },\n    async enviarPedido() {\n      if (!this.tamanhoSelecionado) {\n        alert(\"Por favor, selecione um tamanho.\");\n        return;\n      }\n      const pedidoFinal = {\n        nome: this.produto.nome,\n        foto: this.produto.foto,\n        opcao: this.tamanhoSelecionado.descricao,\n        adicionais: this.adicionaisSelecionados.map(a => a.nome),\n        valor: parseFloat(this.produto.valor),\n        status: \"Na Fila\"\n      };\n      try {\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\"\n          },\n          body: JSON.stringify(pedidoFinal)\n        });\n        if (response.ok) {\n          alert(\"Pedido enviado para a cozinha do Âmbar Café!\");\n          this.$router.push(\"/pedidos\");\n        }\n      } catch (error) {\n        console.error(\"Erro ao enviar o pedido:\", error);\n      }\n    }\n  },\n  created() {\n    if (this.$route.query.produto) {\n      try {\n        this.produto = JSON.parse(this.$route.query.produto);\n      } catch (e) {\n        console.error(\"Erro ao ler dados do produto:\", e);\n      }\n    }\n    this.carregarDadosCustomizacao();\n  }\n};","map":{"version":3,"names":["name","data","produto","listaTamanhos","listaAdicionais","tamanhoSelecionado","adicionaisSelecionados","methods","formatarPreco","valor","num","parseFloat","String","replace","isNaN","toFixed","selecionarTamanho","tamanho","carregarDadosCustomizacao","resPontos","fetch","json","length","resOpcionais","dados","complemento","error","console","enviarPedido","alert","pedidoFinal","nome","foto","opcao","descricao","adicionais","map","a","status","response","method","headers","body","JSON","stringify","ok","$router","push","created","$route","query","parse","e"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\ConfiguracaoPedidoView.vue"],"sourcesContent":["<template>\r\n  <div class=\"config-container\" v-if=\"produto\">\r\n    <div class=\"config-card\">\r\n      \r\n      <div class=\"product-summary-side\">\r\n        <div class=\"product-image-container\">\r\n          <img :src=\"produto.foto\" :alt=\"produto.nome\" class=\"product-image\" />\r\n        </div>\r\n        <h2 class=\"product-title\">{{ produto.nome }}</h2>\r\n        <p class=\"product-base-price\">Preço base: R$ {{ formatarPreco(produto.valor) }}</p>\r\n        <p class=\"product-description\">\r\n          Preparado artesanalmente com insumos frescos e selecionados da mais alta qualidade.\r\n        </p>\r\n      </div>\r\n\r\n      <div class=\"customization-side\">\r\n        \r\n        <div class=\"options-group\">\r\n          <h3 class=\"group-title\">Escolha o Tamanho / Ponto</h3>\r\n          <div class=\"sizes-grid\">\r\n            <button \r\n              v-for=\"tamanho in listaTamanhos\" \r\n              :key=\"tamanho.id\"\r\n              type=\"button\"\r\n              :class=\"['btn-size', { active: tamanhoSelecionado?.id === tamanho.id }]\"\r\n              @click=\"selecionarTamanho(tamanho)\"\r\n            >\r\n              {{ tamanho.descricao }}\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"options-group\">\r\n          <h3 class=\"group-title\">Adicionais (Opcional)</h3>\r\n          <div class=\"addons-list\">\r\n            <label v-for=\"adicional in listaAdicionais\" :key=\"adicional.id\" class=\"addon-item\">\r\n              <div class=\"addon-left\">\r\n                <input \r\n                  type=\"checkbox\" \r\n                  :value=\"adicional\" \r\n                  v-model=\"adicionaisSelecionados\" \r\n                  class=\"addon-checkbox\"\r\n                />\r\n                <span class=\"addon-name\">{{ adicional.nome }}</span>\r\n              </div>\r\n              <span class=\"addon-price\">Grátis</span>\r\n            </label>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"footer-action-bar\">\r\n          <div class=\"price-row\">\r\n            <span class=\"total-label\">Total do Item:</span>\r\n            <span class=\"total-price\">R$ {{ formatarPreco(produto.valor) }}</span>\r\n          </div>\r\n          <button type=\"button\" @click=\"enviarPedido\" class=\"btn-submit\">\r\n            Confirmar e Adicionar\r\n          </button>\r\n        </div>\r\n\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"loading-container\" v-else>\r\n    <p>Buscando os detalhes do produto selecionado...</p>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"ConfiguracaoPedidoView\",\r\n  data() {\r\n    return {\r\n      produto: null,\r\n      listaTamanhos: [],\r\n      listaAdicionais: [],\r\n      tamanhoSelecionado: null,\r\n      adicionaisSelecionados: []\r\n    };\r\n  },\r\n  methods: {\r\n    formatarPreco(valor) {\r\n      if (!valor) return \"0.00\";\r\n      const num = parseFloat(String(valor).replace(\",\", \".\"));\r\n      return isNaN(num) ? \"0.00\" : num.toFixed(2);\r\n    },\r\n    selecionarTamanho(tamanho) {\r\n      this.tamanhoSelecionado = tamanho;\r\n    },\r\n    async carregarDadosCustomizacao() {\r\n      try {\r\n        // Conecta com os tamanhos do db.json via json-server\r\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n        this.listaTamanhos = await resPontos.json();\r\n        if (this.listaTamanhos.length > 0) {\r\n          this.tamanhoSelecionado = this.listaTamanhos[0];\r\n        }\r\n\r\n        // Conecta com os adicionais do db.json\r\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\r\n        const dados = await resOpcionais.json();\r\n        this.listaAdicionais = dados.complemento || [];\r\n      } catch (error) {\r\n        console.error(\"Erro ao sincronizar com o db.json:\", error);\r\n      }\r\n    },\r\n    async enviarPedido() {\r\n      if (!this.tamanhoSelecionado) {\r\n        alert(\"Por favor, selecione um tamanho.\");\r\n        return;\r\n      }\r\n\r\n      const pedidoFinal = {\r\n        nome: this.produto.nome,\r\n        foto: this.produto.foto,\r\n        opcao: this.tamanhoSelecionado.descricao,\r\n        adicionais: this.adicionaisSelecionados.map(a => a.nome),\r\n        valor: parseFloat(this.produto.valor),\r\n        status: \"Na Fila\"\r\n      };\r\n\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify(pedidoFinal)\r\n        });\r\n\r\n        if (response.ok) {\r\n          alert(\"Pedido enviado para a cozinha do Âmbar Café!\");\r\n          this.$router.push(\"/pedidos\");\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao enviar o pedido:\", error);\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    if (this.$route.query.produto) {\r\n      try {\r\n        this.produto = JSON.parse(this.$route.query.produto);\r\n      } catch (e) {\r\n        console.error(\"Erro ao ler dados do produto:\", e);\r\n      }\r\n    }\r\n    this.carregarDadosCustomizacao();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.config-container {\r\n  max-width: 1040px;\r\n  margin: 100px auto 40px auto;\r\n  padding: 0 20px;\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n}\r\n\r\n.config-card {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 40px;\r\n  background-color: #f5efe6;\r\n  border-radius: 32px;\r\n  padding: 40px;\r\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);\r\n}\r\n\r\n.product-summary-side {\r\n  background-color: #faf6f0;\r\n  padding: 30px;\r\n  border-radius: 24px;\r\n  text-align: left;\r\n}\r\n\r\n.product-image-container {\r\n  width: 100%;\r\n  height: 320px;\r\n  border-radius: 20px;\r\n  overflow: hidden;\r\n  margin-bottom: 25px;\r\n}\r\n\r\n.product-image {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.product-title {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 32px;\r\n  color: #2b1b12;\r\n  margin: 0 0 10px 0;\r\n}\r\n\r\n.product-base-price {\r\n  font-size: 18px;\r\n  font-weight: 600;\r\n  color: #615045;\r\n  margin: 0 0 15px 0;\r\n}\r\n\r\n.product-description {\r\n  font-size: 14px;\r\n  color: #7a6a5e;\r\n  line-height: 1.6;\r\n  margin: 0;\r\n}\r\n\r\n.customization-side {\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: space-between;\r\n  text-align: left;\r\n}\r\n\r\n.options-group {\r\n  margin-bottom: 25px;\r\n}\r\n\r\n.group-title {\r\n  font-size: 16px;\r\n  font-weight: 700;\r\n  color: #2b1b12;\r\n  margin: 0 0 15px 0;\r\n  border-bottom: 1px solid rgba(43, 27, 18, 0.08);\r\n  padding-bottom: 8px;\r\n}\r\n\r\n.sizes-grid {\r\n  display: flex;\r\n  gap: 12px;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n.btn-size {\r\n  background-color: #ffffff;\r\n  color: #2b1b12;\r\n  border: 1px solid rgba(43, 27, 18, 0.1);\r\n  padding: 12px 20px;\r\n  border-radius: 12px;\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n  cursor: pointer;\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n.btn-size.active {\r\n  background-color: #2b1b12;\r\n  color: #ffffff;\r\n  border-color: #2b1b12;\r\n}\r\n\r\n.addons-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n}\r\n\r\n.addon-item {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  background-color: #ffffff;\r\n  padding: 14px 20px;\r\n  border-radius: 14px;\r\n  cursor: pointer;\r\n}\r\n\r\n.addon-left {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n}\r\n\r\n.addon-checkbox {\r\n  width: 18px;\r\n  height: 18px;\r\n  accent-color: #2b1b12;\r\n}\r\n\r\n.addon-name {\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n}\r\n\r\n.addon-price {\r\n  font-size: 13px;\r\n  color: #615045;\r\n}\r\n\r\n.footer-action-bar {\r\n  background-color: #2b1b12;\r\n  padding: 24px;\r\n  border-radius: 20px;\r\n  color: #f7f3ee;\r\n  margin-top: 20px;\r\n}\r\n\r\n.price-row {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 16px;\r\n}\r\n\r\n.total-price {\r\n  font-size: 24px;\r\n  font-weight: 700;\r\n}\r\n\r\n.btn-submit {\r\n  width: 100%;\r\n  background-color: #f7f3ee;\r\n  color: #2b1b12;\r\n  border: none;\r\n  padding: 16px;\r\n  border-radius: 14px;\r\n  font-size: 16px;\r\n  font-weight: 700;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.btn-submit:hover {\r\n  background-color: #e6dfd5;\r\n}\r\n\r\n.loading-container {\r\n  text-align: center;\r\n  padding: 100px 20px;\r\n  color: #615045;\r\n}\r\n</style>"],"mappings":";;;AAqEA,eAAe;EACbA,IAAI,EAAE,wBAAwB;EAC9BC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,IAAI;MACbC,aAAa,EAAE,EAAE;MACjBC,eAAe,EAAE,EAAE;MACnBC,kBAAkB,EAAE,IAAI;MACxBC,sBAAsB,EAAE;IAC1B,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,aAAaA,CAACC,KAAK,EAAE;MACnB,IAAI,CAACA,KAAK,EAAE,OAAO,MAAM;MACzB,MAAMC,GAAE,GAAIC,UAAU,CAACC,MAAM,CAACH,KAAK,CAAC,CAACI,OAAO,CAAC,GAAG,EAAE,GAAG,CAAC,CAAC;MACvD,OAAOC,KAAK,CAACJ,GAAG,IAAI,MAAK,GAAIA,GAAG,CAACK,OAAO,CAAC,CAAC,CAAC;IAC7C,CAAC;IACDC,iBAAiBA,CAACC,OAAO,EAAE;MACzB,IAAI,CAACZ,kBAAiB,GAAIY,OAAO;IACnC,CAAC;IACD,MAAMC,yBAAyBA,CAAA,EAAG;MAChC,IAAI;QACF;QACA,MAAMC,SAAQ,GAAI,MAAMC,KAAK,CAAC,oCAAoC,CAAC;QACnE,IAAI,CAACjB,aAAY,GAAI,MAAMgB,SAAS,CAACE,IAAI,CAAC,CAAC;QAC3C,IAAI,IAAI,CAAClB,aAAa,CAACmB,MAAK,GAAI,CAAC,EAAE;UACjC,IAAI,CAACjB,kBAAiB,GAAI,IAAI,CAACF,aAAa,CAAC,CAAC,CAAC;QACjD;;QAEA;QACA,MAAMoB,YAAW,GAAI,MAAMH,KAAK,CAAC,iCAAiC,CAAC;QACnE,MAAMI,KAAI,GAAI,MAAMD,YAAY,CAACF,IAAI,CAAC,CAAC;QACvC,IAAI,CAACjB,eAAc,GAAIoB,KAAK,CAACC,WAAU,IAAK,EAAE;MAChD,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,oCAAoC,EAAEA,KAAK,CAAC;MAC5D;IACF,CAAC;IACD,MAAME,YAAYA,CAAA,EAAG;MACnB,IAAI,CAAC,IAAI,CAACvB,kBAAkB,EAAE;QAC5BwB,KAAK,CAAC,kCAAkC,CAAC;QACzC;MACF;MAEA,MAAMC,WAAU,GAAI;QAClBC,IAAI,EAAE,IAAI,CAAC7B,OAAO,CAAC6B,IAAI;QACvBC,IAAI,EAAE,IAAI,CAAC9B,OAAO,CAAC8B,IAAI;QACvBC,KAAK,EAAE,IAAI,CAAC5B,kBAAkB,CAAC6B,SAAS;QACxCC,UAAU,EAAE,IAAI,CAAC7B,sBAAsB,CAAC8B,GAAG,CAACC,CAAA,IAAKA,CAAC,CAACN,IAAI,CAAC;QACxDtB,KAAK,EAAEE,UAAU,CAAC,IAAI,CAACT,OAAO,CAACO,KAAK,CAAC;QACrC6B,MAAM,EAAE;MACV,CAAC;MAED,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMnB,KAAK,CAAC,+BAA+B,EAAE;UAC5DoB,MAAM,EAAE,MAAM;UACdC,OAAO,EAAE;YAAE,cAAc,EAAE;UAAmB,CAAC;UAC/CC,IAAI,EAAEC,IAAI,CAACC,SAAS,CAACd,WAAW;QAClC,CAAC,CAAC;QAEF,IAAIS,QAAQ,CAACM,EAAE,EAAE;UACfhB,KAAK,CAAC,8CAA8C,CAAC;UACrD,IAAI,CAACiB,OAAO,CAACC,IA