{"ast":null,"code":"export default {\n  name: \"NavBarComponent\"\n};","map":{"version":3,"names":["name"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\components\\NavBarComponent.vue"],"sourcesContent":["<template>\r\n  <nav id=\"nav-bar\">\r\n    <router-link to=\"/\" id=\"logo-container\">\r\n      <span class=\"brand-title\">Âmbar Café.</span>\r\n    </router-link>\r\n\r\n    <div id=\"nav-links\">\r\n      <router-link to=\"/\">Home</router-link>\r\n      <router-link to=\"/menu\">Menu</router-link>\r\n    </div>\r\n\r\n    <div id=\"nav-actions\">\r\n      <router-link to=\"/pedidos\" class=\"btn-nav-action\">\r\n        Criar Pedido\r\n      </router-link>\r\n    </div>\r\n  </nav>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"NavBarComponent\"\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n#nav-bar {\r\n  background-color: #eae3da; /* Cor creme idêntica à referência */\r\n  padding: 25px 40px;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  border-bottom: 1px solid rgba(43, 27, 18, 0.08);\r\n}\r\n\r\n#logo-container {\r\n  text-decoration: none;\r\n}\r\n\r\n.brand-title {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 26px;\r\n  font-weight: 700;\r\n  color: #2b1b12; /* Marrom espresso escuro */\r\n  letter-spacing: -0.5px;\r\n}\r\n\r\n#nav-links {\r\n  display: flex;\r\n  gap: 35px;\r\n}\r\n\r\n#nav-links a {\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  text-decoration: none;\r\n  color: #5c4d43; /* Marrom médio suave */\r\n  font-weight: 500;\r\n  font-size: 15px;\r\n  transition: color 0.2s ease;\r\n}\r\n\r\n#nav-links a:hover, \r\n#nav-links a.router-link-exact-active {\r\n  color: #2b1b12; /* Fica escuro quando ativo ou com mouse em cima */\r\n  font-weight: 600;\r\n}\r\n\r\n/* O botão oval marrom escuro da referência */\r\n.btn-nav-action {\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  display: inline-block;\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee !important;\r\n  text-decoration: none;\r\n  padding: 12px 28px;\r\n  border-radius: 50px; /* Formato cápsula oval perfeito */\r\n  font-size: 14px;\r\n  font-weight: 600;\r\n  letter-spacing: 0.5px;\r\n  box-shadow: 0 4px 12px rgba(43, 27, 18, 0.15);\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n.btn-nav-action:hover {\r\n  background-color: #4a3427;\r\n  transform: translateY(-1px);\r\n  box-shadow: 0 6px 16px rgba(43, 27, 18, 0.25);\r\n}\r\n</style>"],"mappings":"AAoBA,eAAe;EACbA,IAAI,EAAE;AACR","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}