oriaAtiva = 'todos'\"\r\n      >\r\n        Todos\r\n      </button>\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'bebidas' }]\" \r\n        @click=\"categoriaAtiva = 'bebidas'\"\r\n      >\r\n        Bebidas\r\n      </button>\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'lanches' }]\" \r\n        @click=\"categoriaAtiva = 'lanches'\"\r\n      >\r\n        Lanches\r\n      </button>\r\n    </div>\r\n\r\n    <div id=\"scroll-horizontal\">\r\n      <div \r\n        id=\"card-content\" \r\n        v-for=\"item in produtosFiltrados\" \r\n        :key=\"item.id\"\r\n      >\r\n        <div id=\"card-linha\">\r\n          <div class=\"foto-produto\">\r\n            <img :src=\"item.foto\" :alt=\"item.nome\" />\r\n          </div>\r\n          <div class=\"card-coluna\">\r\n            <p id=\"nome-content\">{{ item.nome }}</p>\r\n            <p id=\"preco-content\">R$ {{ item.valor }}</p>\r\n            <p id=\"descricao-content\">{{ item.descricao }}</p>\r\n            <button @click=\"selecionarItem(item)\">Selecionar</button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"MenuView\",\r\n  data() {\r\n    return {\r\n      listaMenuCafeteria: [],\r\n      categoriaAtiva: 'todos'\r\n    };\r\n  },\r\n  computed: {\r\n    // Filtra dinamicamente baseado no botão clicado\r\n    produtosFiltrados() {\r\n      if (this.categoriaAtiva === 'todos') {\r\n        return this.listaMenuCafeteria;\r\n      }\r\n      return this.listaMenuCafeteria.filter(item => item.categoria === this.categoriaAtiva);\r\n    }\r\n  },\r\n  methods: {\r\n    async consultarMenu() {\r\n      try {\r\n        const response = await fetch(`${this.$apiUrl}/menu`);\r\n        const dados = await response.json();\r\n        \r\n        // CORREÇÃO CRUCIAL: Se o JSON Server devolver um objeto, acessamos .menu\r\n        // Se ele devolver a Array diretamente, usamos os dados brutos.\r\n        if (dados && dados.menu) {\r\n          this.listaMenuCafeteria = dados.menu;\r\n        } else if (Array.isArray(dados)) {\r\n          this.listaMenuCafeteria = dados;\r\n        } else {\r\n          this.listaMenuCafeteria = [];\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao buscar o menu da cafeteria:\", error);\r\n      }\r\n    },\r\n    selecionarItem(item) {\r\n      const param = JSON.stringify(item);\r\n      const itemJson = encodeURIComponent(param);\r\n      this.$router.push({ path: \"/config\", query: { produto: itemJson } });\r\n    }\r\n  },\r\n  mounted() {\r\n    this.consultarMenu();\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* ESTILOS DOS BOTÕES DE FILTRO */\r\n.menu-section {\r\n  padding: 20px 40px;\r\n  max-width: 1300px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.section-header {\r\n  margin-bottom: 20px;\r\n  text-align: left;\r\n}\r\n\r\n.section-header h2 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 32px;\r\n  color: #2b1b12;\r\n  margin-bottom: 5px;\r\n}\r\n\r\n.section-header p {\r\n  color: #615045;\r\n  font-size: 15px;\r\n}\r\n\r\n.filter-container {\r\n  display: flex;\r\n  gap: 12px;\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.filter-btn {\r\n  background-color: transparent;\r\n  color: #615045;\r\n  border: 1px solid rgba(43, 27, 18, 0.2);\r\n  padding: 8px 20px;\r\n  border-radius: 50px;\r\n  font-weight: 500;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n.filter-btn:hover {\r\n  background-color: rgba(43, 27, 18, 0.05);\r\n  color: #2b1b12;\r\n}\r\n\r\n.filter-btn.active {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  border-color: #2b1b12;\r\n  font-weight: 600;\r\n  box-shadow: 0 4px 12px rgba(43, 27, 18, 0.15);\r\n}\r\n\r\n/* SEUS ESTILOS ORIGINAIS DO SCROLL HORIZONTAL (Mantidos e higienizados) */\r\n#scroll-horizontal {\r\n  display: flex;\r\n  overflow-x: auto;\r\n  gap: 20px;\r\n  padding-bottom: 15px;\r\n}\r\n\r\n#card-content {\r\n  background-color: #f7f3ee;\r\n  border-radius: 15px;\r\n  padding: 15px;\r\n  min-width: 320px;\r\n  box-shadow: 0 4px 10px rgba(0,0,0,0.05);\r\n}\r\n\r\n#card-linha {\r\n  display: flex;\r\n  gap: 15px;\r\n  align-items: center;\r\n}\r\n\r\n.foto-produto {\r\n  width: 90px;\r\n  height: 90px;\r\n  border-radius: 10px;\r\n  overflow: hidden;\r\n}\r\n\r\n.foto-produto img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.card-coluna {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: flex-start;\r\n  text-align: left;\r\n  flex: 1;\r\n}\r\n\r\n#nome-content {\r\n  font-weight: bold;\r\n  font-size: 16px;\r\n  color: #2b1b12;\r\n  margin: 0 0 4px 0;\r\n}\r\n\r\n#preco-content {\r\n  color: #523b2e;\r\n  font-weight: 600;\r\n  margin: 0 0 4px 0;\r\n}\r\n\r\n#descricao-content {\r\n  font-size: 12px;\r\n  color: #777;\r\n  margin: 0 0 10px 0;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n  overflow: hidden;\r\n}\r\n\r\n.card-coluna button {\r\n  background-color: #2b1b12;\r\n  color: white;\r\n  border: none;\r\n  padding: 6px 14px;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n  font-size: 13px;\r\n}\r\n\r\n.card-coluna button:hover {\r\n  background-color: #4a3427;\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAc;;EAMlBA,KAAK,EAAC;AAAkB;;EAqBxBC,EAAE,EAAC;AAAmB;;EAMlBA,EAAE,EAAC;AAAY;;EACbD,KAAK,EAAC;AAAc;;;EAGpBA,KAAK,EAAC;AAAa;;EACnBC,EAAE,EAAC;AAAc;;EACjBA,EAAE,EAAC;AAAe;;EAClBA,EAAE,EAAC;AAAmB;;;uBAxCnCC,mBAAA,CA8CM,OA9CNC,UA8CM,G,0BA7CJC,mBAAA,CAGM;IAHDJ,KAAK,EAAC;EAAgB,IACzBI,mBAAA,CAA8B,YAA1B,uBAAqB,GACzBA,mBAAA,CAAuE,WAApE,kEAAgE,E,qBAGrEA,mBAAA,CAmBM,OAnBNC,UAmBM,GAlBJD,mBAAA,CAKS;IAJNJ,KAAK,EAAAM,eAAA;MAAAC,MAAA,EAA2BC,KAAA,CAAAC,cAAc;IAAA;IAC9CC,OAAK,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEJ,KAAA,CAAAC,cAAc;KACvB,SAED,kBACAL,mBAAA,CAKS;IAJNJ,KAAK,EAAAM,eAAA;MAAAC,MAAA,EAA2BC,KAAA,CAAAC,cAAc