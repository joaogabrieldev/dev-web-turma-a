"$options","alertIcon","_hoisted_3","mensagem","modalRemover","_hoisted_4","_hoisted_5","_hoisted_6","nomeItem","_hoisted_7","onClick","_cache","args","fecharModal","confirmarRemocao","listaPedidos","length","_hoisted_8","_component_router_link","to","_hoisted_9","_hoisted_10","_Fragment","_renderList","pedido","key","id","_hoisted_11","src","foto_cafe","alt","nome_cafe","_hoisted_13","_hoisted_14","ponto","opcionais","_hoisted_15","opc","nome","_hoisted_16","_hoisted_17","status","_hoisted_18","_hoisted_19","parseFloat","valor_total","toFixed","$event","abrirModalRemover","title","_hoisted_21","_hoisted_22","_hoisted_23","totalGeral","finalizarCompra"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\PedidosView.vue"],"sourcesContent":["<template>\r\n  <div class=\"carrinho-container\">\r\n    <h1 class=\"page-title\">Seu Carrinho de Compras</h1>\r\n\r\n    <transition name=\"toast-fade\">\r\n      <div v-if=\"alerta.visivel\" :class=\"['custom-alert', alerta.tipo]\">\r\n        <span class=\"alert-icon\">{{ alertIcon }}</span>\r\n        <span class=\"alert-message\">{{ alerta.mensagem }}</span>\r\n      </div>\r\n    </transition>\r\n\r\n    <transition name=\"modal-fade\">\r\n      <div v-if=\"modalRemover.visivel\" class=\"modal-overlay\">\r\n        <div class=\"modal-card\">\r\n          <div class=\"modal-header\">\r\n            <span class=\"modal-icon\">⚠️</span>\r\n            <h3>Confirmar Ação</h3>\r\n          </div>\r\n          <div class=\"modal-body\">\r\n            <p>Tem certeza que deseja remover <strong>{{ modalRemover.nomeItem }}</strong> do seu carrinho?</p>\r\n          </div>\r\n          <div class=\"modal-footer\">\r\n            <button class=\"btn-modal-cancelar\" @click=\"fecharModal\">Cancelar</button>\r\n            <button class=\"btn-modal-confirmar\" @click=\"confirmarRemocao\">Sim, Remover</button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </transition>\r\n\r\n    <div v-if=\"listaPedidos.length === 0\" class=\"carrinho-vazio\">\r\n      <p>O seu carrinho está vazio no momento.</p>\r\n      <router-link to=\"/menu\" class=\"btn-voltar\">Ver o Cardápio</router-link>\r\n    </div>\r\n\r\n    <div v-else class=\"carrinho-conteudo\">\r\n      <div class=\"lista-itens\">\r\n        <div v-for=\"pedido in listaPedidos\" :key=\"pedido.id\" class=\"pedido-card\">\r\n          <div class=\"pedido-foto\">\r\n            <img :src=\"pedido.foto_cafe\" :alt=\"pedido.nome_cafe\" />\r\n          </div>\r\n          \r\n          <div class=\"pedido-detalhes\">\r\n            <h3>{{ pedido.nome_cafe }}</h3>\r\n            <p class=\"pedido-opcao\"><strong>Opção:</strong> {{ pedido.ponto || 'Tamanho Único' }}</p>\r\n            \r\n            <div v-if=\"pedido.opcionais && pedido.opcionais.length > 0\" class=\"pedido-adicionais\">\r\n              <strong>Adicionais:</strong>\r\n              <ul>\r\n                <li v-for=\"opc in pedido.opcionais\" :key=\"opc.id\">\r\n                  • {{ opc.nome }}\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            \r\n            <p class=\"pedido-status\">\r\n              <span class=\"badge\">{{ pedido.status || 'Em preparação' }}</span>\r\n            </p>\r\n          </div>\r\n\r\n          <div class=\"pedido-preco-acao\">\r\n            <span class=\"preco-item\">R$ {{ parseFloat(pedido.valor_total).toFixed(2) }}</span>\r\n            <button class=\"btn-remover\" @click=\"abrirModalRemover(pedido)\" title=\"Remover item\">\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"3 6 5 6 21 6\"></polyline><path d=\"M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2\"></path><line x1=\"10\" y1=\"11\" x2=\"10\" y2=\"17\"></line><line x1=\"14\" y1=\"11\" x2=\"14\" y2=\"17\"></line></svg>\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"resumo-carrinho\">\r\n        <h3>Resumo do Pedido</h3>\r\n        <div class=\"resumo-linha\">\r\n          <span>Total dos Itens:</span>\r\n          <span class=\"resumo-total\">R$ {{ totalGeral.toFixed(2) }}</span>\r\n        </div>\r\n        <button class=\"btn-finalizar\" @click=\"finalizarCompra\">\r\n          Confirmar e Pagar\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"PedidosView\",\r\n  data() {\r\n    return {\r\n      listaPedidos: [],\r\n      modalRemover: {\r\n        visivel: false,\r\n        idItem: null,\r\n        nomeItem: \"\"\r\n      },\r\n      // Estado para os alertas customizados da tela\r\n      alerta: {\r\n        visivel: false,\r\n        mensagem: \"\",\r\n        tipo: \"\" \r\n      }\r\n    };\r\n  },\r\n  computed: {\r\n    totalGeral() {\r\n      return this.listaPedidos.reduce((soma, item) => {\r\n        let preco = String(item.valor_total).replace(',', '.');\r\n        return soma + (parseFloat(preco) || 0);\r\n      }, 0);\r\n    },\r\n    // Ícone correspondente à cor semântica do alerta\r\n    alertIcon() {\r\n      switch (this.alerta.tipo) {\r\n        case 'erro': return '❌';\r\n        case 'aviso': return '⚠️';\r\n        case 'info': return 'ℹ️';\r\n        case 'sucesso': return '✅';\r\n        default: return '';\r\n      }\r\n    }\r\n  },\r\n  methods: {\r\n    // Disparador de notificações personalizadas\r\n    mostrarAlerta(mensagem, tipo = \"info\") {\r\n      this.alerta.mensagem = mensagem;\r\n      this.alerta.tipo = tipo;\r\n      this.alerta.visivel = true;\r\n      \r\n      setTimeout(() => {\r\n        this.alerta.visivel = false;\r\n      }, 3500);\r\n    },\r\n\r\n    async buscarPedidos() {\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\");\r\n        this.listaPedidos = await response.json();\r\n      } catch (error) {\r\n        this.mostrarAlerta(\"Erro de comunicação ao carregar os itens do carrinho.\", \"erro\");\r\n      }\r\n    },\r\n    \r\n    abrirModalRemover(pedido) {\r\n      this.modalRemover.idItem = pedido.id;\r\n      this.modalRemover.nomeItem = pedido.nome_cafe;\r\n      this.modalRemover.visivel = true;\r\n    },\r\n\r\n    fecharModal() {\r\n      this.modalRemover.visivel = false;\r\n      this.modalRemover.idItem = null;\r\n      this.modalRemover.nomeItem = \"\";\r\n    },\r\n\r\n    async confirmarRemocao() {\r\n      const id = this.modalRemover.idItem;\r\n      try {\r\n        const response = await fetch(`http://localhost:3000/pedidos/${id}`, {\r\n          method: \"DELETE\"\r\n        });\r\n        \r\n        if (response.ok) {\r\n          this.listaPedidos = this.listaPedidos.filter(p => p.id !== id);\r\n          this.fecharModal();\r\n          this.mostrarAlerta(\"Item removido com sucesso do carrinho.\", \"sucesso\");\r\n        } else {\r\n          this.mostrarAlerta(\"Não foi possível excluir o item.\", \"erro\");\r\n        }\r\n      } catch (error) {\r\n        this.mostrarAlerta(\"Erro ao tentar excluir. Tente novamente.\", \"erro\");\r\n      }\r\n    },\r\n\r\n    finalizarCompra() {\r\n      // Substituição do pop-up do botão \"Confirmar e Pagar\"\r\n      this.mostrarAlerta(\"Pedido enviado para a cozinha do Âmbar Café com sucesso!\", \"sucesso\");\r\n    }\r\n  },\r\n  mounted() {\r\n    this.buscarPedidos();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* COMPONENTE DE ALERTA SEMÂNTICO (NOTIFICAÇÃO EM TELA) */\r\n.custom-alert {\r\n  position: fixed;\r\n  top: 100px;\r\n  right: 20px;\r\n  z-index: 10000;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  padding: 16px 24px;\r\n  border-radius: 12px;\r\n  color: #ffffff;\r\n  font-weight: 600;\r\n  font-size: 14px;\r\n  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\r\n  min-width: 300px;\r\n  max-width: 450px;\r\n}\r\n\r\n/* Cores Semânticas Requeridas */\r\n.custom-alert.erro { background-color: #d93838; }      /* Vermelho */\r\n.custom-alert.aviso { background-color: #e67e22; }     /* Laranja */\r\n.custom-alert.info { background-color: #2980b9; }      /* Azul */\r\n.custom-alert.sucesso { background-color: #27ae60; }   /* Verde */\r\n\r\n/* Transições do Alerta */\r\n.toast-fade-enter-active, .toast-fade-leave-active {\r\n  transition: all 0.3s ease;\r\n}\r\n.toast-fade-enter, .toast-fade-leave-to {\r\n  transform: translateX(50px);\r\n  opacity: 0;\r\n}\r\n\r\n/* MODAL DE CONFIRMAÇÃO */\r\n.modal-overlay {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100vw;\r\n  height: 100vh;\r\n  background-color: rgba(43, 27, 18, 0.4);\r\n  backdrop-filter: blur(4px);\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  z-index: 9999;\r\n}\r\n.modal-card {\r\n  background-color: #f7f3ee;\r\n  border-radius: 20px;\r\n  width: 90%;\r\n  max-width: 420px;\r\n  padding: 25px;\r\n  box-shadow: 0 15px 40px rgba(43, 27, 18, 0.15);\r\n  border: 1px solid rgba(230, 126, 34, 0.2);\r\n}\r\n.modal-header {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  margin-bottom: 15px;\r\n}\r\n.modal-icon {\r\n  font-size: 24px;\r\n  background-color: #e67e22;\r\n  color: #ffffff;\r\n  width: 38px;\r\n  height: 38px;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  border-radius: 50%;\r\n}\r\n.modal-header h3 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  color: #2b1b12;\r\n  font-size: 20px;\r\n  margin: 0;\r\n}\r\n.modal-body p {\r\n  color: #615045;\r\n  font-size: 15px;\r\n  line-height: 1.5;\r\n  margin: 0 0 25px 0;\r\n}\r\n.modal-footer {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: 12px;\r\n}\r\n.btn-modal-cancelar {\r\n  background-color: #e6dfd5;\r\n  color: #523b2e;\r\n  border: none;\r\n  padding: 10px 20px;\r\n  border-radius: 8px;\r\n  font-weight: 600;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n.btn-modal-cancelar:hover { background-color: #dcd4c9; }\r\n.btn-modal-confirmar {\r\n  background-color: #a84343;\r\n  color: #ffffff;\r\n  border: none;\r\n  padding: 10px 20px;\r\n  border-radius: 8px;\r\n  font-weight: 600;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n  transition: opacity 0.2s;\r\n}\r\n.btn-modal-confirmar:hover { opacity: 0.9; }\r\n\r\n.modal-fade-enter-active, .modal-fade-leave-active { transition: opacity 0.25s ease; }\r\n.modal-fade-enter, .modal-fade-leave-to { opacity: 0; }\r\n\r\n/* Layout Base do Carrinho */\r\n.carrinho-container {\r\n  max-width: 1100px;\r\n  margin: 120px auto 40px auto;\r\n  padding: 0 20px;\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  text-align: left;\r\n}\r\n.page-title {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  color: #2b1b12;\r\n  font-size: 32px;\r\n  margin-bottom: 30px;\r\n}\r\n.carrinho-vazio {\r\n  text-align: center;\r\n  padding: 60px;\r\n  background-color: #f7f3ee;\r\n  border-radius: 20px;\r\n  color: #615045;\r\n}\r\n.btn-voltar {\r\n  display: inline-block;\r\n  margin-top: 20px;\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  text-decoration: none;\r\n  padding: 12px 24px;\r\n  border-radius: 10px;\r\n  font-weight: 600;\r\n  transition: opacity 0.2s;\r\n}\r\n.btn-voltar:hover { opacity: 0.9; }\r\n.carrinho-conteudo {\r\n  display: grid;\r\n  grid-template-columns: 2fr 1fr;\r\n  gap: 40px;\r\n  align-items: start;\r\n}\r\n.lista-itens {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 16px;\r\n}\r\n.pedido-card {\r\n  display: flex;\r\n  align-items: center;\r\n  background-color: #f7f3ee;\r\n  padding: 20px;\r\n  border-radius: 18px;\r\n  box-shadow: 0 4px 15px rgba(43, 27, 18, 0.02);\r\n}\r\n.pedido-foto {\r\n  width: 100px;\r\n  height: 100px;\r\n  border-radius: 12px;\r\n  overflow: hidden;\r\n  margin-right: 20px;\r\n  flex-shrin