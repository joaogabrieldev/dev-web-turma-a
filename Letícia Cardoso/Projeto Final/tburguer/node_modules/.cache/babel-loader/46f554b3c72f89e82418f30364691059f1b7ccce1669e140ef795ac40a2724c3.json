n    </div>\r\n\r\n    <div class=\"filter-container\">\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'todos' }]\" \r\n        @click=\"categoriaAtiva = 'todos'\"\r\n      >\r\n        Todos\r\n      </button>\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'bebidas' }]\" \r\n        @click=\"categoriaAtiva = 'bebidas'\"\r\n      >\r\n        Bebidas\r\n      </button>\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'lanches' }]\" \r\n        @click=\"categoriaAtiva = 'lanches'\"\r\n      >\r\n        Lanches\r\n      </button>\r\n    </div>\r\n\r\n    <div class=\"grid-cafes\">\r\n      <div class=\"cafe-card\" v-for=\"item in produtosFiltrados\" :key=\"item.id\">\r\n        <div class=\"image-container\">\r\n          <img :src=\"item.foto\" :alt=\"item.nome\" />\r\n        </div>\r\n        <div class=\"card-body\">\r\n          <div class=\"card-meta\">\r\n            <h3>{{ item.nome }}</h3>\r\n            <span class=\"price\">R$ {{ item.valor }}</span>\r\n          </div>\r\n          <p class=\"description\">\r\n            {{ item.descricao || 'Grãos premium moídos na hora com extração balanceada.' }}\r\n          </p>\r\n          <button class=\"btn-add\" @click=\"selecionarItem(item)\">\r\n            <span>Selecionar Opção</span>\r\n            <i class=\"arrow\">→</i>\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"MenuView\",\r\n  data() {\r\n    return {\r\n      listaMenuCafeteria: [],\r\n      categoriaAtiva: 'todos'\r\n    };\r\n  },\r\n  computed: {\r\n    produtosFiltrados() {\r\n      if (this.categoriaAtiva === 'todos') {\r\n        return this.listaMenuCafeteria;\r\n      }\r\n      return this.listaMenuCafeteria.filter(item => item.categoria === this.categoriaAtiva);\r\n    }\r\n  },\r\n  methods: {\r\n   async consultarMenu() {\r\n      try {\r\n        const response = await fetch(`${this.$apiUrl}/menu`);\r\n        const dados = await response.json();\r\n        \r\n        // CORREÇÃO: Como o seu JSON Server entrega a Array direto no topo (conforme o print),\r\n        // nós salvamos os dados diretamente na lista!\r\n        if (Array.isArray(dados)) {\r\n          this.listaMenuCafeteria = dados;\r\n        } else {\r\n          this.listaMenuCafeteria = [];\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao buscar o menu:\", error);\r\n      }\r\n    },\r\n    selecionarItem(item) {\r\n      const param = JSON.stringify(item);\r\n      const itemJson = encodeURIComponent(param);\r\n      this.$router.push({ path: \"/config\", query: { produto: itemJson } });\r\n    }\r\n  },\r\n  mounted() {\r\n    this.consultarMenu();\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.menu-section {\r\n  padding: 40px 40px 60px 40px;\r\n  max-width: 1300px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.section-header {\r\n  margin-bottom: 35px;\r\n  text-align: left;\r\n}\r\n\r\n.section-header h2 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 36px;\r\n  margin-bottom: 8px;\r\n  color: #2b1b12;\r\n}\r\n\r\n.section-header p {\r\n  color: #615045;\r\n  font-size: 16px;\r\n}\r\n\r\n.filter-container {\r\n  display: flex;\r\n  gap: 15px;\r\n  margin-bottom: 40px;\r\n}\r\n\r\n.filter-btn {\r\n  background-color: transparent;\r\n  color: #615045;\r\n  border: 1px solid rgba(43, 27, 18, 0.2);\r\n  padding: 10px 24px;\r\n  border-radius: 50px;\r\n  font-weight: 500;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n.filter-btn:hover {\r\n  background-color: rgba(43, 27, 18, 0.05);\r\n  color: #2b1b12;\r\n}\r\n\r\n.filter-btn.active {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  border-color: #2b1b12;\r\n  font-weight: 600;\r\n  box-shadow: 0 4px 12px rgba(43, 27, 18, 0.15);\r\n}\r\n\r\n.grid-cafes {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\r\n  gap: 30px;\r\n}\r\n\r\n.cafe-card {\r\n  background-color: #f7f3ee;\r\n  border-radius: 24px;\r\n  overflow: hidden;\r\n  box-shadow: 0 10px 25px rgba(43, 27, 18, 0.04);\r\n  transition: transform 0.3s, box-shadow 0.3s;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.cafe-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 15px 35px rgba(43, 27, 18, 0.09);\r\n}\r\n\r\n.image-container {\r\n  width: 100%;\r\n  height: 220px;\r\n  overflow: hidden;\r\n  background-color: #dfd7cc;\r\n}\r\n\r\n.image-container img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  transition: transform 0.5s;\r\n}\r\n\r\n.cafe-card:hover .image-container img {\r\n  transform: scale(1.06);\r\n}\r\n\r\n.card-body {\r\n  padding: 22px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  flex-grow: 1;\r\n}\r\n\r\n.card-meta {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: baseline;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.card-meta h3 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 20px;\r\n  font-weight: 700;\r\n  color: #2b1b12;\r\n}\r\n\r\n.price {\r\n  font-weight: 700;\r\n  color: #523b2e;\r\n  font-size: 17px;\r\n}\r\n\r\n.description {\r\n  font-size: 14px;\r\n  color: #615045;\r\n  line-height: 1.5;\r\n  margin-bottom: 20px;\r\n  text-align: left;\r\n  flex-grow: 1;\r\n}\r\n\r\n.btn-add {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  width: 100%;\r\n  padding: 14px 18px;\r\n  border-radius: 14px;\r\n  font-weight: 500;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  border: none;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.btn-add:hover {\r\n  background-color: #4a3427;\r\n}\r\n\r\n.arrow {\r\n  font-style: normal;\r\n  font-weight: bold;\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAc;;EAMlBA,KAAK,EAAC;AAAkB;;EAqBxBA,KAAK,EAAC;AAAY;;EAEdA,KAA