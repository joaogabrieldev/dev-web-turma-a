{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nexport default {\n  name: \"ConfiguracaoPedidoView\",\n  data() {\n    return {\n      produto: null,\n      // Alinhado com o nome do v-if do template\n      listaPontos: [],\n      listaOpcionais: [],\n      pontoSelecionado: null,\n      opcionaisSelecionados: []\n    };\n  },\n  computed: {\n    valorTotal() {\n      let total = 0;\n      if (this.produto && this.produto.valor) {\n        total += parseFloat(this.produto.valor);\n      }\n      this.opcionaisSelecionados.forEach(id => {\n        const item = this.listaOpcionais.find(o => o.id === id);\n        if (item) {\n          total += parseFloat(item.valor);\n        }\n      });\n      return total;\n    }\n  },\n  methods: {\n    async carregarDadosCustomizacao() {\n      try {\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\n        this.listaPontos = await resPontos.json();\n        if (this.listaPontos.length > 0) {\n          this.pontoSelecionado = this.listaPontos[0].id;\n        }\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\n        this.listaOpcionais = await resOpcionais.json();\n      } catch (error) {\n        console.error(\"Erro ao carregar opções:\", error);\n      }\n    },\n    async enviarParaCarrinho() {\n      if (!this.pontoSelecionado) {\n        alert(\"Por favor, selecione um tamanho ou ponto!\");\n        return;\n      }\n      const opcionaisDetalhados = this.opcionaisSelecionados.map(id => {\n        return this.listaOpcionais.find(o => o.id === id);\n      });\n      const pontoEscolhido = this.listaPontos.find(p => p.id === this.pontoSelecionado);\n      const pedidoPayload = {\n        nome_cafe: this.produto.nome,\n        foto_cafe: this.produto.foto,\n        valor_total: this.valorTotal.toFixed(2),\n        ponto: pontoEscolhido ? pontoEscolhido.tipo : \"\",\n        opcionais: opcionaisDetalhados,\n        status: \"Em preparação\"\n      };\n      try {\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\"\n          },\n          body: JSON.stringify(pedidoPayload)\n        });\n        if (response.ok) {\n          alert(\"Pedido adicionado com sucesso!\");\n          this.$router.push(\"/pedidos\");\n        }\n      } catch (error) {\n        console.error(\"Erro ao salvar pedido:\", error);\n      }\n    }\n  },\n  mounted() {\n    // Captura o produto vindo da rota e preenche a variável correta\n    const query = this.$route.query;\n    if (query.produto) {\n      this.produto = JSON.parse(decodeURIComponent(query.produto));\n    }\n    this.carregarDadosCustomizacao();\n  }\n};","map":{"version":3,"names":["name","data","produto","listaPontos","listaOpcionais","pontoSelecionado","opcionaisSelecionados","computed","valorTotal","total","valor","parseFloat","forEach","id","item","find","o","methods","carregarDadosCustomizacao","resPontos","fetch","json","length","resOpcionais","error","console","enviarParaCarrinho","alert","opcionaisDetalhados","map","pontoEscolhido","p","pedidoPayload","nome_cafe","nome","foto_cafe","foto","valor_total","toFixed","ponto","tipo","opcionais","status","response","method","headers","body","JSON","stringify","ok","$router","push","mounted","query","$route","parse","decodeURIComponent"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\ConfiguracaoPedidoView.vue"],"sourcesContent":["<template>\r\n  <div class=\"config-container\" v-if=\"produto\">\r\n    <div class=\"product-preview\">\r\n      <div class=\"image-box\">\r\n        <img :src=\"produto.foto\" :alt=\"produto.nome\" />\r\n      </div>\r\n      <div class=\"product-info\">\r\n        <h2>{{ produto.nome }}</h2>\r\n        <p class=\"base-price\">Preço base: R$ {{ produto.valor }}</p>\r\n        <p class=\"description\">\r\n          {{ produto.descricao || 'Item preparado com ingredientes selecionados de forma artesanal.' }}\r\n        </p>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"customization-form\">\r\n      <div class=\"options-group\">\r\n        <h3>Escolha o Tamanho / Ponto</h3>\r\n        <div class=\"radio-grid\">\r\n          <label \r\n            v-for=\"ponto in listaPontos\" \r\n            :key=\"ponto.id\" \r\n            :class=\"['radio-card', { selected: pontoSelecionado === ponto.id }]\"\r\n          >\r\n            <input \r\n              type=\"radio\" \r\n              name=\"ponto\" \r\n              :value=\"ponto.id\" \r\n              v-model=\"pontoSelecionado\"\r\n            />\r\n            <span class=\"radio-label\">{{ ponto.tipo }}</span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"options-group\">\r\n        <h3>Adicionais (Opcional)</h3>\r\n        <div class=\"checkbox-list\">\r\n          <label \r\n            v-for=\"opcional in listaOpcionais\" \r\n            :key=\"opcional.id\" \r\n            :class=\"['checkbox-item', { checked: opcionaisSelecionados.includes(opcional.id) }]\"\r\n          >\r\n            <div class=\"checkbox-wrapper\">\r\n              <input \r\n                type=\"checkbox\" \r\n                :value=\"opcional.id\" \r\n                v-model=\"opcionaisSelecionados\"\r\n              />\r\n              <span class=\"opcional-name\">{{ opcional.nome }}</span>\r\n            </div>\r\n            <span class=\"opcional-price\">+ R$ {{ opcional.valor }}</span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"summary-section\">\r\n        <div class=\"price-row\">\r\n          <span>Total do Item:</span>\r\n          <span class=\"total-price\">R$ {{ valorTotal.toFixed(2) }}</span>\r\n        </div>\r\n        <button class=\"btn-submit\" @click=\"enviarParaCarrinho\">\r\n          Adicionar ao Carrinho →\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"ConfiguracaoPedidoView\",\r\n  data() {\r\n    return {\r\n      produto: null, // Alinhado com o nome do v-if do template\r\n      listaPontos: [],\r\n      listaOpcionais: [],\r\n      pontoSelecionado: null,\r\n      opcionaisSelecionados: []\r\n    };\r\n  },\r\n  computed: {\r\n    valorTotal() {\r\n      let total = 0;\r\n      if (this.produto && this.produto.valor) {\r\n        total += parseFloat(this.produto.valor);\r\n      }\r\n      \r\n      this.opcionaisSelecionados.forEach(id => {\r\n        const item = this.listaOpcionais.find(o => o.id === id);\r\n        if (item) {\r\n          total += parseFloat(item.valor);\r\n        }\r\n      });\r\n      \r\n      return total;\r\n    }\r\n  },\r\n  methods: {\r\n    async carregarDadosCustomizacao() {\r\n      try {\r\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n        this.listaPontos = await resPontos.json();\r\n        if (this.listaPontos.length > 0) {\r\n          this.pontoSelecionado = this.listaPontos[0].id;\r\n        }\r\n\r\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\r\n        this.listaOpcionais = await resOpcionais.json();\r\n      } catch (error) {\r\n        console.error(\"Erro ao carregar opções:\", error);\r\n      }\r\n    },\r\n    async enviarParaCarrinho() {\r\n      if (!this.pontoSelecionado) {\r\n        alert(\"Por favor, selecione um tamanho ou ponto!\");\r\n        return;\r\n      }\r\n\r\n      const opcionaisDetalhados = this.opcionaisSelecionados.map(id => {\r\n        return this.listaOpcionais.find(o => o.id === id);\r\n      });\r\n\r\n      const pontoEscolhido = this.listaPontos.find(p => p.id === this.pontoSelecionado);\r\n\r\n      const pedidoPayload = {\r\n        nome_cafe: this.produto.nome,\r\n        foto_cafe: this.produto.foto,\r\n        valor_total: this.valorTotal.toFixed(2),\r\n        ponto: pontoEscolhido ? pontoEscolhido.tipo : \"\",\r\n        opcionais: opcionaisDetalhados,\r\n        status: \"Em preparação\"\r\n      };\r\n\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify(pedidoPayload)\r\n        });\r\n\r\n        if (response.ok) {\r\n          alert(\"Pedido adicionado com sucesso!\");\r\n          this.$router.push(\"/pedidos\");\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao salvar pedido:\", error);\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    // Captura o produto vindo da rota e preenche a variável correta\r\n    const query = this.$route.query;\r\n    if (query.produto) {\r\n      this.produto = JSON.parse(decodeURIComponent(query.produto));\r\n    }\r\n    this.carregarDadosCustomizacao();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.config-container {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 50px;\r\n  max-width: 1200px;\r\n  margin: 120px auto 30px auto; /* Aumentado o margin-top para não ficar embaixo da navbar fixa */\r\n  padding: 0 20px;\r\n}\r\n\r\n.product-preview {\r\n  background-color: #f7f3ee;\r\n  border-radius: 24px;\r\n  padding: 25px;\r\n  box-shadow: 0 10px 25px rgba(43, 27, 18, 0.03);\r\n  text-align: left;\r\n  height: fit-content;\r\n}\r\n\r\n.image-box {\r\n  width: 100%;\r\n  height: 350px;\r\n  border-radius: 16px;\r\n  overflow: hidden;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.image-box img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.product-info h2 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 28px;\r\n  color: #2b1b12;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.base-price {\r\n  font-size: 18px;\r\n  font-weight: 600;\r\n  color: #523b2e;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.description {\r\n  color: #615045;\r\n  font-size: 14px;\r\n  line-height: 1.6;\r\n}\r\n\r\n.customization-form {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 30px;\r\n  text-align: left;\r\n}\r\n\r\n.options-group h3 {\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  font-size: 16px;\r\n  color: #2b1b12;\r\n  margin-bottom: 15px;\r\n  border-bottom: 1px solid rgba(43, 27, 18, 0.1);\r\n  padding-bottom: 8px;\r\n}\r\n\r\n.radio-grid {\r\n  display: flex;\r\n  gap: 12px;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n.radio-card {\r\n  border: 1px solid rgba(43, 27, 18, 0.2);\r\n  padding: 12px 20px;\r\n  border-radius: 12px;\r\n  cursor: pointer;\r\n  transition: all 0.2s ease;\r\n  background-color: #fff;\r\n}\r\n\r\n.radio-card input {\r\n  display: none;\r\n}\r\n\r\n.radio-card:hover {\r\n  background-color: rgba(43, 27, 18, 0.03);\r\n}\r\n\r\n.radio-card.selected {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  border-color: #2b1b12;\r\n}\r\n\r\n.checkbox-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n}\r\n\r\n.checkbox-item {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: 14px 20px;\r\n  border-radius: 14px;\r\n  background-color: #f7f3ee;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.checkbox-wrapper {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n}\r\n\r\n.checkbox-item:hover {\r\n  background-color: #f0e9e1;\r\n}\r\n\r\n.opcional-price {\r\n  font-weight: 600;\r\n  color: #523b2e;\r\n}\r\n\r\n.summary-section {\r\n  margin-top: 20px;\r\n  background-color: #2b1b12;\r\n  padding: 25px;\r\n  border-radius: 20px;\r\n  color: #f7f3ee;\r\n}\r\n\r\n.price-row {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  font-size: 18px;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.total-price {\r\n  font-size: 24px;\r\n  font-weight: 700;\r\n}\r\n\r\n.btn-submit {\r\n  width: 100%;\r\n  background-color: #f7f3ee;\r\n  color: #2b1b12;\r\n  border: none;\r\n  padding: 16px;\r\n  border-radius: 12px;\r\n  font-weight: 600;\r\n  font-size: 16px;\r\n  cursor: pointer;\r\n  transition: transform 0.1s, background-color 0.2s;\r\n}\r\n\r\n.btn-submit:hover {\r\n  background-color: #e6dfd5;\r\n}\r\n</style>"],"mappings":";;;;;AAsEA,eAAe;EACbA,IAAI,EAAE,wBAAwB;EAC9BC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,IAAI;MAAE;MACfC,WAAW,EAAE,EAAE;MACfC,cAAc,EAAE,EAAE;MAClBC,gBAAgB,EAAE,IAAI;MACtBC,qBAAqB,EAAE;IACzB,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,UAAUA,CAAA,EAAG;MACX,IAAIC,KAAI,GAAI,CAAC;MACb,IAAI,IAAI,CAACP,OAAM,IAAK,IAAI,CAACA,OAAO,CAACQ,KAAK,EAAE;QACtCD,KAAI,IAAKE,UAAU,CAAC,IAAI,CAACT,OAAO,CAACQ,KAAK,CAAC;MACzC;MAEA,IAAI,CAACJ,qBAAqB,CAACM,OAAO,CAACC,EAAC,IAAK;QACvC,MAAMC,IAAG,GAAI,IAAI,CAACV,cAAc,CAACW,IAAI,CAACC,CAAA,IAAKA,CAAC,CAACH,EAAC,KAAMA,EAAE,CAAC;QACvD,IAAIC,IAAI,EAAE;UACRL,KAAI,IAAKE,UAAU,CAACG,IAAI,CAACJ,KAAK,CAAC;QACjC;MACF,CAAC,CAAC;MAEF,OAAOD,KAAK;IACd;EACF,CAAC;EACDQ,OAAO,EAAE;IACP,MAAMC,yBAAyBA,CAAA,EAAG;MAChC,IAAI;QACF,MAAMC,SAAQ,GAAI,MAAMC,KAAK,CAAC,oCAAoC,CAAC;QACnE,IAAI,CAACjB,WAAU,GAAI,MAAMgB,SAAS,CAACE,IAAI,CAAC,CAAC;QACzC,IAAI,IAAI,CAAClB,WAAW,CAACmB,MAAK,GAAI,CAAC,EAAE;UAC/B,IAAI,CAACjB,gBAAe,GAAI,IAAI,CAACF,WAAW,CAAC,CAAC,CAAC,CAACU,EAAE;QAChD;QAEA,MAAMU,YAAW,GAAI,MAAMH,KAAK,CAAC,iCAAiC,CAAC;QACnE,IAAI,CAAChB,cAAa,GAAI,MAAMmB,YAAY,CAACF,IAAI,CAAC,CAAC;MACjD,EAAE,OAAOG,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,0BAA0B,EAAEA,KAAK,CAAC;MAClD;IACF,CAAC;IACD,MAAME,kBAAkBA,CAAA,EAAG;MACzB,IAAI,CAAC,IAAI,CAACrB,gBAAgB,EAAE;QAC1BsB,KAAK,CAAC,2CAA2C,CAAC;QAClD;MACF;MAEA,MAAMC,mBAAkB,GAAI,IAAI,CAACtB,qBAAqB,CAACuB,GAAG,CAAChB,EAAC,IAAK;QAC/D,OAAO,IAAI,CAACT,cAAc,CAACW,IAAI,CAACC,CAAA,IAAKA,CAAC,CAACH,EAAC,KAAMA,EAAE,CAAC;MACnD,CAAC,CAAC;MAEF,MAAMiB,cAAa,GAAI,IAAI,CAAC3B,WAAW,CAACY,IAAI,CAACgB,CAAA,IAAKA,CAAC,CAAClB,EAAC,KAAM,