]),\n    _: 1 /* STABLE */\n  }), $data.listaPedidos.length === 0 ? (_openBlock(), _createElementBlock(\"div\", _hoisted_8, [_cache[7] || (_cache[7] = _createElementVNode(\"p\", null, \"O seu carrinho está vazio no momento.\", -1 /* CACHED */)), _createVNode(_component_router_link, {\n    to: \"/menu\",\n    class: \"btn-voltar\"\n  }, {\n    default: _withCtx(() => [...(_cache[6] || (_cache[6] = [_createTextVNode(\"Ver o Cardápio\", -1 /* CACHED */)]))]),\n    _: 1 /* STABLE */\n  })])) : (_openBlock(), _createElementBlock(\"div\", _hoisted_9, [_createElementVNode(\"div\", _hoisted_10, [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($data.listaPedidos, pedido => {\n    return _openBlock(), _createElementBlock(\"div\", {\n      key: pedido.id,\n      class: \"pedido-card\"\n    }, [_createElementVNode(\"div\", _hoisted_11, [_createElementVNode(\"img\", {\n      src: pedido.foto_cafe,\n      alt: pedido.nome_cafe\n    }, null, 8 /* PROPS */, _hoisted_12)]), _createElementVNode(\"div\", _hoisted_13, [_createElementVNode(\"h3\", null, _toDisplayString(pedido.nome_cafe), 1 /* TEXT */), _createElementVNode(\"p\", _hoisted_14, [_cache[8] || (_cache[8] = _createElementVNode(\"strong\", null, \"Opção:\", -1 /* CACHED */)), _createTextVNode(\" \" + _toDisplayString(pedido.ponto || 'Tamanho Único'), 1 /* TEXT */)]), pedido.opcionais && pedido.opcionais.length > 0 ? (_openBlock(), _createElementBlock(\"div\", _hoisted_15, [_cache[9] || (_cache[9] = _createElementVNode(\"strong\", null, \"Adicionais:\", -1 /* CACHED */)), _createElementVNode(\"ul\", null, [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList(pedido.opcionais, opc => {\n      return _openBlock(), _createElementBlock(\"li\", {\n        key: opc.id\n      }, \" • \" + _toDisplayString(opc.nome), 1 /* TEXT */);\n    }), 128 /* KEYED_FRAGMENT */))])])) : _createCommentVNode(\"v-if\", true), _createElementVNode(\"p\", _hoisted_16, [_createElementVNode(\"span\", _hoisted_17, _toDisp