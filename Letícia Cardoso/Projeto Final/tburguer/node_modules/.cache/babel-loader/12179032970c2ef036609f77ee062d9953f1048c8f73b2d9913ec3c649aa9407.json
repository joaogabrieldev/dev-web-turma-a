{"ast":null,"code":"import { toDisplayString as _toDisplayString, createElementVNode as _createElementVNode, normalizeClass as _normalizeClass, openBlock as _openBlock, createElementBlock as _createElementBlock, createCommentVNode as _createCommentVNode, Transition as _Transition, withCtx as _withCtx, createBlock as _createBlock } from \"vue\";\nconst _hoisted_1 = {\n  class: \"alerta-icone\"\n};\nconst _hoisted_2 = {\n  class: \"alerta-texto\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createBlock(_Transition, {\n    name: \"alerta-slide\"\n  }, {\n    default: _withCtx(() => [$data.visivel && $props.mensagem ? (_openBlock(), _createElementBlock(\"div\", {\n      key: 0,\n      class: _normalizeClass(['alerta-global', $props.tipo]),\n      role: \"alert\"\n    }, [_createElementVNode(\"span\", _hoisted_1, _toDisplayString($options.icone), 1 /* TEXT */), _createElementVNode(\"p\", _hoisted_2, _toDisplayString($props.mensagem), 1 /* TEXT */), _createElementVNode(\"button\", {\n      class: \"alerta-fechar\",\n      onClick: _cache[0] || (_cache[0] = (...args) => $options.fechar && $options.fechar(...args)),\n      \"aria-label\": \"Fechar\"\n    }, \"×\")], 2 /* CLASS */)) : _createCommentVNode(\"v-if\", true)]),\n    _: 1 /* STABLE */\n  });\n}","map":{"version":3,"names":["class","_createBlock","_Transition","name","$data","visivel","$props","mensagem","_createElementBlock","_normalizeClass","tipo","role","_createElementVNode","_hoisted_1","_toDisplayString","$options","icone","_hoisted_2","onClick","_cache","args","fechar"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\components\\AlertaComponent.vue"],"sourcesContent":["<template>\r\n  <transition name=\"alerta-slide\">\r\n    <div v-if=\"visivel && mensagem\" :class=\"['alerta-global', tipo]\" role=\"alert\">\r\n      <span class=\"alerta-icone\">{{ icone }}</span>\r\n      <p class=\"alerta-texto\">{{ mensagem }}</p>\r\n      <button class=\"alerta-fechar\" @click=\"fechar\" aria-label=\"Fechar\">×</button>\r\n    </div>\r\n  </transition>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"AlertaComponent\",\r\n  props: {\r\n    mensagem: {\r\n      type: String,\r\n      default: \"\"\r\n    },\r\n    tipo: {\r\n      type: String,\r\n      default: \"info\",\r\n      validator: (v) => [\"erro\", \"aviso\", \"info\", \"sucesso\"].includes(v)\r\n    },\r\n    duracao: {\r\n      type: Number,\r\n      default: 4000\r\n    }\r\n  },\r\n  emits: [\"fechar\"],\r\n  data() {\r\n    return {\r\n      visivel: false,\r\n      timer: null\r\n    };\r\n  },\r\n  computed: {\r\n    icone() {\r\n      const icones = { erro: \"❌\", aviso: \"⚠️\", info: \"ℹ️\", sucesso: \"✅\" };\r\n      return icones[this.tipo] || \"🔔\";\r\n    }\r\n  },\r\n  watch: {\r\n    // Sempre que mensagem mudar, reexibe com o timer reiniciado\r\n    mensagem(novaMsg) {\r\n      if (novaMsg) {\r\n        this.mostrar();\r\n      }\r\n    }\r\n  },\r\n  methods: {\r\n    mostrar() {\r\n      clearTimeout(this.timer);\r\n      this.visivel = true;\r\n      if (this.duracao > 0) {\r\n        this.timer = setTimeout(() => { this.fechar(); }, this.duracao);\r\n      }\r\n    },\r\n    fechar() {\r\n      this.visivel = false;\r\n      clearTimeout(this.timer);\r\n      this.$emit(\"fechar\");\r\n    }\r\n  },\r\n  mounted() {\r\n    if (this.mensagem) this.mostrar();\r\n  },\r\n  beforeUnmount() {\r\n    clearTimeout(this.timer);\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.alerta-global {\r\n  position: fixed;\r\n  top: 88px;  /* Abaixo da navbar fixa (72px + 16px de gap) */\r\n  right: 24px;\r\n  z-index: 9000;\r\n  display: flex;\r\n  align-items: flex-start;\r\n  gap: 12px;\r\n  padding: 14px 18px;\r\n  border-radius: 14px;\r\n  color: #ffffff;\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n  line-height: 1.5;\r\n  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.14);\r\n  min-width: 300px;\r\n  max-width: 440px;\r\n  border-left: 4px solid rgba(255, 255, 255, 0.35);\r\n}\r\n\r\n/* Paleta semântica */\r\n.alerta-global.erro    { background-color: #c0392b; } /* Vermelho — erro */\r\n.alerta-global.aviso   { background-color: #d35400; color: #fff; } /* Laranja — aviso */\r\n.alerta-global.info    { background-color: #2471a3; } /* Azul — informação */\r\n.alerta-global.sucesso { background-color: #1e8449; } /* Verde — sucesso */\r\n\r\n.alerta-icone {\r\n  font-size: 18px;\r\n  flex-shrink: 0;\r\n  margin-top: 1px;\r\n}\r\n\r\n.alerta-texto {\r\n  flex: 1;\r\n  margin: 0;\r\n}\r\n\r\n.alerta-fechar {\r\n  background: none;\r\n  border: none;\r\n  color: rgba(255, 255, 255, 0.75);\r\n  font-size: 20px;\r\n  line-height: 1;\r\n  padding: 0;\r\n  cursor: pointer;\r\n  flex-shrink: 0;\r\n  transition: color 0.15s;\r\n  margin-top: -1px;\r\n}\r\n\r\n.alerta-fechar:hover {\r\n  color: #ffffff;\r\n}\r\n\r\n/* Animação de entrada/saída */\r\n.alerta-slide-enter-active { transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); }\r\n.alerta-slide-leave-active { transition: all 0.25s ease-in; }\r\n.alerta-slide-enter-from  { transform: translateX(60px); opacity: 0; }\r\n.alerta-slide-leave-to    { transform: translateX(60px); opacity: 0; }\r\n</style>"],"mappings":";;EAGYA,KAAK,EAAC;AAAc;;EACvBA,KAAK,EAAC;AAAc;;uBAH3BC,YAAA,CAMaC,WAAA;IANDC,IAAI,EAAC;EAAc;sBACzB,MAKwC,CALjCC,KAAA,CAAAC,OAAO,IAAIC,MAAA,CAAAC,QAAQ,I,cAA9BC,mBAAA,CAIM;;MAJ2BR,KAAK,EAAAS,eAAA,mBAAoBH,MAAA,CAAAI,IAAI;MAAGC,IAAI,EAAC;QACpEC,mBAAA,CAA6C,QAA7CC,UAA6C,EAAAC,gBAAA,CAAfC,QAAA,CAAAC,KAAK,kBACnCJ,mBAAA,CAA0C,KAA1CK,UAA0C,EAAAH,gBAAA,CAAfR,MAAA,CAAAC,QAAQ,kBACnCK,mBAAA,CAA4E;MAApEZ,KAAK,EAAC,eAAe;MAAEkB,OAAK,EAAAC,MAAA,QAAAA,MAAA,UAAAC,IAAA,KAAEL,QAAA,CAAAM,MAAA,IAAAN,QAAA,CAAAM,MAAA,IAAAD,IAAA,CAAM;MAAE,YAAU,EAAC;OAAS,GAAC,E","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}