{"ast":null,"code":"export default {\n  name: \"BannerComponent\"\n};","map":{"version":3,"names":["name"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\components\\BannerComponent.vue"],"sourcesContent":["<template>\r\n  <div class=\"banner-wrapper\">\r\n    <div class=\"hero-cover\">\r\n      <div class=\"hero-content-overlay\">\r\n        <div class=\"hero-badge\">ARTESANAL & FRESCO</div>\r\n        <h1 class=\"hero-title\">Brewed Fresh,<br />Served Warm</h1>\r\n        <p class=\"hero-subtitle\">\r\n          Sinta o aroma marcante dos grãos selecionados e a cremosidade perfeita em cada xícara.\r\n        </p>\r\n        \r\n        <router-link to=\"/menu\" class=\"btn-hero-menu\">\r\n          Conheça o Menu\r\n        </router-link>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"BannerComponent\"\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* Remove margens extras e centraliza o banner na página */\r\n.banner-wrapper {\r\n  width: 100%;\r\n  max-width: 1140px;\r\n  margin: 0 auto;\r\n  padding: 0 20px;\r\n}\r\n\r\n/* O fundo escuro ou imagem do seu layout original */\r\n.hero-cover {\r\n  width: 100%;\r\n  height: 520px;\r\n  background-color: #2b1b12; /* Cor base sofisticada da sua paleta */\r\n  border-radius: 32px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  box-shadow: 0 20px 40px rgba(43, 27, 18, 0.08);\r\n}\r\n\r\n.hero-content-overlay {\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n  align-items: center;\r\n  text-align: center;\r\n  color: #f7f3ee;\r\n  padding: 0 20px;\r\n}\r\n\r\n.hero-badge {\r\n  background-color: rgba(255, 255, 255, 0.15);\r\n  backdrop-filter: blur(8px);\r\n  padding: 6px 16px;\r\n  border-radius: 30px;\r\n  font-size: 11px;\r\n  font-weight: 700;\r\n  letter-spacing: 2px;\r\n  text-transform: uppercase;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.hero-title {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 52px;\r\n  line-height: 1.15;\r\n  margin: 0 0 15px 0;\r\n  font-weight: 700;\r\n}\r\n\r\n.hero-subtitle {\r\n  font-size: 16px;\r\n  max-width: 520px;\r\n  margin: 0 0 35px 0;\r\n  opacity: 0.9;\r\n  line-height: 1.6;\r\n}\r\n\r\n/* O botão com comportamento de link real sem sublinhado */\r\n.btn-hero-menu {\r\n  display: inline-block;\r\n  background-color: #ffffff;\r\n  color: #2b1b12;\r\n  text-decoration: none;\r\n  padding: 15px 38px;\r\n  border-radius: 30px;\r\n  font-weight: 600;\r\n  font-size: 15px;\r\n  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);\r\n  transition: background-color 0.2s, transform 0.2s;\r\n  cursor: pointer;\r\n}\r\n\r\n.btn-hero-menu:hover {\r\n  background-color: #f7f3ee;\r\n  transform: translateY(-2px);\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .hero-title { font-size: 34px; }\r\n  .hero-cover { height: 420px; }\r\n}\r\n</style>"],"mappings":"AAmBA,eAAe;EACbA,IAAI,EAAE;AACR,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}