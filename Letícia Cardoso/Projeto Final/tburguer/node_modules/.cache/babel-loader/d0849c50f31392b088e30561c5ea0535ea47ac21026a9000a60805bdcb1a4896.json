e: \"radio\",\n      name: \"tamanho\",\n      value: op.value,\n      \"onUpdate:modelValue\": _cache[4] || (_cache[4] = $event => $data.tamanhoSelecionado = $event),\n      onChange: _cache[5] || (_cache[5] = $event => $data.erros.tamanho = false)\n    }, null, 40, _hoisted_18), [[_vModelRadio, $data.tamanhoSelecionado]]), _createElementVNode(\"span\", _hoisted_19, [_createElementVNode(\"strong\", null, _toDisplayString(op.label), 1), _createElementVNode(\"small\", null, _toDisplayString(op.desc), 1)])], 2);\n  }), 128))]), $data.erros.tamanho ? (_openBlock(), _createElementBlock(\"span\", _hoisted_20, \"Selecione uma opção para continuar.\")) : _createCommentVNode(\"\", true)], 2), $data.produto.categoria === 'bebidas' ? (_openBlock(), _createElementBlock(\"div\", {\n    key: 0,\n    class: _normalizeClass([\"options-group\", {\n      'has-error': $data.erros.leite\n    }])\n  }, [_cache[14] || (_cache[14] = _createElementVNode(\"h3\", {\n    class: \"group-title\"\n  }, [_createTextVNode(\" Tipo de Leite \"), _createElementVNode(\"span\", {\n    class: \"required\"\n  }, \"*\")], -1)), _createElementVNode(\"div\", _hoisted_21, [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($data.opcoesLeite, op => {\n    return _openBlock(), _createElementBlock(\"label\", {\n      key: op.value,\n      class: _normalizeClass(['radio-card', {\n        selected: $data.leiteSelecionado === op.value\n      }])\n    }, [_withDirectives(_createElementVNode(\"input\", {\n      type: \"radio\",\n      name: \"leite\",\n      value: op.value,\n      \"onUpdate:modelValue\": _cache[6] || (_cache[6] = $event => $data.leiteSelecionado = $event),\n      onChange: _cache[7] || (_cache[7] = $event => $data.erros.leite = false)\n    }, null, 40, _hoisted_22), [[_vModelRadio, $data.leiteSelecionado]]), _createElementVNode(\"span\", _hoisted_23, [_createElementVNode(\"strong\", null, _toDisplayString(op.label), 1), op.extra ? (_openBlock(), _createElementBlock(\"small\", _ho