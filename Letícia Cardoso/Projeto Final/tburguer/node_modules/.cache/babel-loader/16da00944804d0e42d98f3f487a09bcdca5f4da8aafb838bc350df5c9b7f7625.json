{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuCafeteria: []\n    };\n  },\n  methods: {\n    async consultarMenu() {\n      try {\n        const response = await fetch(`${this.$apiUrl}/menu`);\n        const dados = await response.json();\n        this.listaMenuCafeteria = dados.cafes || dados.burgues || [];\n      } catch (error) {\n        console.error(\"Erro ao buscar o menu:\", error);\n      }\n    },\n    selecionarItem(item) {\n      const param = JSON.stringify(item);\n      const itemJson = encodeURIComponent(param);\n      this.$router.push({\n        path: \"/config\",\n        query: {\n          produto: itemJson\n        }\n      });\n    }\n  },\n  mounted() {\n    this.consultarMenu();\n  }\n};","map":{"version":3,"names":["name","data","listaMenuCafeteria","methods","consultarMenu","response","fetch","$apiUrl","dados","json","cafes","burgues","error","console","selecionarItem","item","param","JSON","stringify","itemJson","encodeURIComponent","$router","push","path","query","produto","mounted"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\MenuView.vue"],"sourcesContent":["<template>\r\n  <div class=\"menu-section\">\r\n    <div class=\"section-header\">\r\n      <h2>Nossas Especialidades</h2>\r\n      <p>Escolha o seu café perfeito, preparado por baristas experientes.</p>\r\n    </div>\r\n\r\n    <div class=\"grid-cafes\">\r\n      <div class=\"cafe-card\" v-for=\"item in listaMenuCafeteria\" :key=\"item.id\">\r\n        <div class=\"image-container\">\r\n          <img :src=\"item.foto\" :alt=\"item.nome\" />\r\n        </div>\r\n        <div class=\"card-body\">\r\n          <div class=\"card-meta\">\r\n            <h3>{{ item.nome }}</h3>\r\n            <span class=\"price\">R$ {{ item.valor }}</span>\r\n          </div>\r\n          <p class=\"description\">\r\n            {{ item.descricao || 'Grãos premium moídos na hora com extração balanceada.' }}\r\n          </p>\r\n          <button class=\"btn-add\" @click=\"selecionarItem(item)\">\r\n            <span>Selecionar Opção</span>\r\n            <i class=\"arrow\">→</i>\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"MenuView\",\r\n  data() {\r\n    return {\r\n      listaMenuCafeteria: []\r\n    };\r\n  },\r\n  methods: {\r\n    async consultarMenu() {\r\n      try {\r\n        const response = await fetch(`${this.$apiUrl}/menu`);\r\n        const dados = await response.json();\r\n        this.listaMenuCafeteria = dados.cafes || dados.burgues || [];\r\n      } catch (error) {\r\n        console.error(\"Erro ao buscar o menu:\", error);\r\n      }\r\n    },\r\n    selecionarItem(item) {\r\n      const param = JSON.stringify(item);\r\n      const itemJson = encodeURIComponent(param);\r\n      this.$router.push({ path: \"/config\", query: { produto: itemJson } });\r\n    }\r\n  },\r\n  mounted() {\r\n    this.consultarMenu();\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.menu-section {\r\n  padding: 60px 40px;\r\n  max-width: 1300px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.section-header {\r\n  margin-bottom: 45px;\r\n  text-align: left;\r\n}\r\n\r\n.section-header h2 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 36px;\r\n  margin-bottom: 8px;\r\n  color: #2b1b12;\r\n}\r\n\r\n.section-header p {\r\n  color: #615045;\r\n  font-size: 16px;\r\n}\r\n\r\n.grid-cafes {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\r\n  gap: 30px;\r\n}\r\n\r\n.cafe-card {\r\n  background-color: #f7f3ee;\r\n  border-radius: 24px;\r\n  overflow: hidden;\r\n  box-shadow: 0 10px 25px rgba(43, 27, 18, 0.04);\r\n  transition: transform 0.3s, box-shadow 0.3s;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.cafe-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 15px 35px rgba(43, 27, 18, 0.09);\r\n}\r\n\r\n.image-container {\r\n  width: 100%;\r\n  height: 220px;\r\n  overflow: hidden;\r\n  background-color: #dfd7cc;\r\n}\r\n\r\n.image-container img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  transition: transform 0.5s;\r\n}\r\n\r\n.cafe-card:hover .image-container img {\r\n  transform: scale(1.06);\r\n}\r\n\r\n.card-body {\r\n  padding: 22px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  flex-grow: 1;\r\n}\r\n\r\n.card-meta {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: baseline;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.card-meta h3 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 20px;\r\n  font-weight: 700;\r\n  color: #2b1b12;\r\n}\r\n\r\n.price {\r\n  font-weight: 700;\r\n  color: #523b2e;\r\n  font-size: 17px;\r\n}\r\n\r\n.description {\r\n  font-size: 14px;\r\n  color: #615045;\r\n  line-height: 1.5;\r\n  margin-bottom: 20px;\r\n  text-align: left;\r\n  flex-grow: 1;\r\n}\r\n\r\n.btn-add {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  width: 100%;\r\n  padding: 14px 18px;\r\n  border-radius: 14px;\r\n  font-weight: 500;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  border: none;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.btn-add:hover {\r\n  background-color: #4a3427;\r\n}\r\n\r\n.arrow {\r\n  font-style: normal;\r\n  font-weight: bold;\r\n}\r\n</style>"],"mappings":";AA+BA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,kBAAkB,EAAE;IACtB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,aAAaA,CAAA,EAAG;MACpB,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,OAAO,CAAC;QACpD,MAAMC,KAAI,GAAI,MAAMH,QAAQ,CAACI,IAAI,CAAC,CAAC;QACnC,IAAI,CAACP,kBAAiB,GAAIM,KAAK,CAACE,KAAI,IAAKF,KAAK,CAACG,OAAM,IAAK,EAAE;MAC9D,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,wBAAwB,EAAEA,KAAK,CAAC;MAChD;IACF,CAAC;IACDE,cAAcA,CAACC,IAA