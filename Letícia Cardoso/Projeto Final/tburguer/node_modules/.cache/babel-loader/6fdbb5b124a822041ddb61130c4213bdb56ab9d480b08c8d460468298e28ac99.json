{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nexport default {\n  name: \"ConfiguracaoPedidoView\",\n  data() {\n    return {\n      produto: null,\n      listaTamanhos: [],\n      listaAdicionais: [],\n      tamanhoSelecionado: null,\n      adicionaisSelecionados: [],\n      // Estado interno para alertas (interligado com seu AlertaComponent se houver)\n      alerta: {\n        mensagem: \"\",\n        tipo: \"info\",\n        visivel: false\n      }\n    };\n  },\n  computed: {\n    calcularTotal() {\n      if (!this.produto) return 0;\n      // Adicionais marcados como \"Grátis\", então mantém o preço base do produto\n      return parseFloat(this.produto.valor);\n    }\n  },\n  methods: {\n    formatarPreco(valor) {\n      if (!valor) return \"0.00\";\n      const num = parseFloat(String(valor).replace(\",\", \".\"));\n      return isNaN(num) ? \"0.00\" : num.toFixed(2);\n    },\n    selecionarTamanho(tamanho) {\n      this.tamanhoSelecionado = tamanho;\n    },\n    // CORRIGIDO: Removido o erro de 'mensaje is not defined'\n    mostrarAlerta(mensagem, tipo = \"success\") {\n      this.alerta.mensagem = mensagem;\n      this.alerta.tipo = tipo;\n      this.alerta.visivel = true;\n\n      // Se você usa o window.alert clássico para testes:\n      alert(mensagem);\n      setTimeout(() => {\n        this.alerta.visivel = false;\n      }, 3500);\n    },\n    async carregarDadosCustomizacao() {\n      try {\n        // Busca os tamanhos do seu db.json via json-server\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\n        this.listaTamanhos = await resPontos.json();\n\n        // Define o primeiro tamanho como padrão se houver\n        if (this.listaTamanhos.length > 0) {\n          this.tamanhoSelecionado = this.listaTamanhes ? this.listaTamanhos[0] : null;\n        }\n\n        // Busca os opcionais/complementos do seu db.json\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\n        const dadosOpcionais = await resOpcionais.json();\n        this.listaAdicionais = dadosOpcionais.complemento || [];\n      } catch (error) {\n        console.error(\"Erro ao carregar dados de customização:\", error);\n        this.mostrarAlerta(\"Erro ao conectar com o servidor.\", \"danger\");\n      }\n    },\n    async enviarPedido() {\n      if (!this.tamanhoSelecionado) {\n        this.mostrarAlerta(\"Por favor, selecione um tamanho/ponto.\", \"warning\");\n        return;\n      }\n\n      // Monta o objeto final esperado pela cozinha / aba de pedidos\n      const novoPedido = {\n        nome: this.produto.nome,\n        foto: this.produto.foto,\n        opcao: this.tamanhoSelecionado.descricao,\n        adicionais: this.adicionaisSelecionados.map(a => a.nome),\n        valor: this.calcularTotal,\n        status: \"Na Fila\" // Mapeado conforme seu db.json\n      };\n      try {\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\"\n          },\n          body: JSON.stringify(novoPedido)\n        });\n        if (response.ok) {\n          this.mostrarAlerta(\"Pedido enviado para a cozinha do Âmbar Café!\");\n          this.$router.push(\"/pedidos\");\n        } else {\n          this.mostrarAlerta(\"Falha ao salvar o pedido.\", \"danger\");\n        }\n      } catch (error) {\n        console.error(\"Erro ao enviar pedido:\", error);\n        this.mostrarAlerta(\"Erro de rede ao enviar pedido.\", \"danger\");\n      }\n    }\n  },\n  created() {\n    // Recupera o produto enviado pela Home ou Menu através da Query String\n    if (this.$route.query.produto) {\n      try {\n        this.produto = JSON.parse(decodeURIComponent(this.$route.query.produto));\n      } catch (e) {\n        console.error(\"Erro ao parsear produto da query:\", e);\n      }\n    }\n    this.carregarDadosCustomizacao();\n  }\n};","map":{"version":3,"names":["name","data","produto","listaTamanhos","listaAdicionais","tamanhoSelecionado","adicionaisSelecionados","alerta","mensagem","tipo","visivel","computed","calcularTotal","parseFloat","valor","methods","formatarPreco","num","String","replace","isNaN","toFixed","selecionarTamanho","tamanho","mostrarAlerta","alert","setTimeout","carregarDadosCustomizacao","resPontos","fetch","json","length","listaTamanhes","resOpcionais","dadosOpcionais","complemento","error","console","enviarPedido","novoPedido","nome","foto","opcao","descricao","adicionais","map","a","status","response","method","headers","body","JSON","stringify","ok","$router","push","created","$route","query","parse","decodeURIComponent","e"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\ConfiguracaoPedidoView.vue"],"sourcesContent":["<template>\r\n  <div class=\"config-container\" v-if=\"produto\">\r\n    <div class=\"config-card\">\r\n      <div class=\"product-summary-side\">\r\n        <div class=\"product-image-container\">\r\n          <img :src=\"produto.foto\" :alt=\"produto.nome\" class=\"product-image\" />\r\n        </div>\r\n        <h2 class=\"product-title\">{{ produto.nome }}</h2>\r\n        <p class=\"product-base-price\">Preço base: R$ {{ formatarPreco(produto.valor) }}</p>\r\n        <p class=\"product-description\" v-if=\"produto.descricao\">{{ produto.descricao }}</p>\r\n        <p class=\"product-description\" v-else>\r\n          Produto artesanal preparado com ingredientes selecionados de alta qualidade.\r\n        </p>\r\n      </div>\r\n\r\n      <div class=\"customization-side\">\r\n        <div class=\"options-group\">\r\n          <h3 class=\"group-title\">Escolha o Tamanho / Ponto</h3>\r\n          <div class=\"sizes-grid\">\r\n            <button \r\n              v-for=\"tamanho in listaTamanhos\" \r\n              :key=\"tamanho.id\"\r\n              type=\"button\"\r\n              :class=\"['btn-size', { active: tamanhoSelecionado?.id === tamanho.id }]\"\r\n              @click=\"selecionarTamanho(tamanho)\"\r\n            >\r\n              {{ tamanho.descricao }}\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"options-group\">\r\n          <h3 class=\"group-title\">Adicionais (Opcional)</h3>\r\n          <div class=\"addons-list\">\r\n            <label v-for=\"adicional in listaAdicionais\" :key=\"adicional.id\" class=\"addon-item\">\r\n              <div class=\"addon-left\">\r\n                <input \r\n                  type=\"checkbox\" \r\n                  :value=\"adicional\" \r\n                  v-model=\"adicionaisSelecionados\" \r\n                  class=\"addon-checkbox\"\r\n                />\r\n                <span class=\"addon-name\">{{ adicional.nome }}</span>\r\n              </div>\r\n              <span class=\"addon-price\">Grátis</span>\r\n            </label>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"footer-action-bar\">\r\n          <div class=\"price-row\">\r\n            <span class=\"total-label\">Total do Item:</span>\r\n            <span class=\"total-price\">R$ {{ formatarPreco(calcularTotal) }}</span>\r\n          </div>\r\n          <button type=\"button\" @click=\"enviarPedido\" class=\"btn-submit\">\r\n            Confirmar e Adicionar\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <div class=\"loading-container\" v-else>\r\n    <p>Carregando dados do produto...</p>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"ConfiguracaoPedidoView\",\r\n  data() {\r\n    return {\r\n      produto: null,\r\n      listaTamanhos: [],\r\n      listaAdicionais: [],\r\n      tamanhoSelecionado: null,\r\n      adicionaisSelecionados: [],\r\n      // Estado interno para alertas (interligado com seu AlertaComponent se houver)\r\n      alerta: {\r\n        mensagem: \"\",\r\n        tipo: \"info\",\r\n        visivel: false\r\n      }\r\n    };\r\n  },\r\n  computed: {\r\n    calcularTotal() {\r\n      if (!this.produto) return 0;\r\n      // Adicionais marcados como \"Grátis\", então mantém o preço base do produto\r\n      return parseFloat(this.produto.valor);\r\n    }\r\n  },\r\n  methods: {\r\n    formatarPreco(valor) {\r\n      if (!valor) return \"0.00\";\r\n      const num = parseFloat(String(valor).replace(\",\", \".\"));\r\n      return isNaN(num) ? \"0.00\" : num.toFixed(2);\r\n    },\r\n    selecionarTamanho(tamanho) {\r\n      this.tamanhoSelecionado = tamanho;\r\n    },\r\n    // CORRIGIDO: Removido o erro de 'mensaje is not defined'\r\n    mostrarAlerta(mensagem, tipo = \"success\") {\r\n      this.alerta.mensagem = mensagem;\r\n      this.alerta.tipo = tipo;\r\n      this.alerta.visivel = true;\r\n\r\n      // Se você usa o window.alert clássico para testes:\r\n      alert(mensagem);\r\n\r\n      setTimeout(() => {\r\n        this.alerta.visivel = false;\r\n      }, 3500);\r\n    },\r\n    async carregarDadosCustomizacao() {\r\n      try {\r\n        // Busca os tamanhos do seu db.json via json-server\r\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n        this.listaTamanhos = await resPontos.json();\r\n        \r\n        // Define o primeiro tamanho como padrão se houver\r\n        if (this.listaTamanhos.length > 0) {\r\n          this.tamanhoSelecionado = this.listaTamanhes ? this.listaTamanhos[0] : null;\r\n        }\r\n\r\n        // Busca os opcionais/complementos do seu db.json\r\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\r\n        const dadosOpcionais = await resOpcionais.json();\r\n        this.listaAdicionais = dadosOpcionais.complemento || [];\r\n      } catch (error) {\r\n        console.error(\"Erro ao carregar dados de customização:\", error);\r\n        this.mostrarAlerta(\"Erro ao conectar com o servidor.\", \"danger\");\r\n      }\r\n    },\r\n    async enviarPedido() {\r\n      if (!this.tamanhoSelecionado) {\r\n        this.mostrarAlerta(\"Por favor, selecione um tamanho/ponto.\", \"warning\");\r\n        return;\r\n      }\r\n\r\n      // Monta o objeto final esperado pela cozinha / aba de pedidos\r\n      const novoPedido = {\r\n        nome: this.produto.nome,\r\n        foto: this.produto.foto,\r\n        opcao: this.tamanhoSelecionado.descricao,\r\n        adicionais: this.adicionaisSelecionados.map(a => a.nome),\r\n        valor: this.calcularTotal,\r\n        status: \"Na Fila\" // Mapeado conforme seu db.json\r\n      };\r\n\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify(novoPedido)\r\n        });\r\n\r\n        if (response.ok) {\r\n          this.mostrarAlerta(\"Pedido enviado para a cozinha do Âmbar Café!\");\r\n          this.$router.push(\"/pedidos\");\r\n        } else {\r\n          this.mostrarAlerta(\"Falha ao salvar o pedido.\", \"danger\");\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao enviar pedido:\", error);\r\n        this.mostrarAlerta(\"Erro de rede ao enviar pedido.\", \"danger\");\r\n      }\r\n    }\r\n  },\r\n  created() {\r\n    // Recupera o produto enviado pela Home ou Menu através da Query String\r\n    if (this.$route.query.produto) {\r\n      try {\r\n        this.produto = JSON.parse(decodeURIComponent(this.$route.query.produto));\r\n      } catch (e) {\r\n        console.error(\"Erro ao parsear produto da query:\", e);\r\n      }\r\n    }\r\n    this.carregarDadosCustomizacao();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.config-container {\r\n  max-width: 1040px;\r\n  margin: 100px auto 40px auto;\r\n  padding: 0 20px;\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n}\r\n\r\n.config-card {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 40px;\r\n  background-color: #f5efe6;\r\n  border-radius: 32px;\r\n  padding: 40px;\r\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);\r\n}\r\n\r\n/* LADO ESQUERDO: RESUMO */\r\n.product-summary-side {\r\n  background-color: #faf6f0;\r\n  padding: 30px;\r\n  border-radius: 24px;\r\n  text-align: left;\r\n}\r\n\r\n.product-image-container {\r\n  width: 100%;\r\n  height: 320px;\r\n  border-radius: 20px;\r\n  overflow: hidden;\r\n  margin-bottom: 25px;\r\n}\r\n\r\n.product-image {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.product-title {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 32px;\r\n  color: #2b1b12;\r\n  margin: 0 0 10px 0;\r\n}\r\n\r\n.product-base-price {\r\n  font-size: 18px;\r\n  font-weight: 600;\r\n  color: #615045;\r\n  margin: 0 0 15px 0;\r\n}\r\n\r\n.product-description {\r\n  font-size: 14px;\r\n  color: #7a6a5e;\r\n  line-height: 1.6;\r\n  margin: 0;\r\n}\r\n\r\n/* LADO DIREITO: SELEÇÃO */\r\n.customization-side {\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: space-between;\r\n  text-align: left;\r\n}\r\n\r\n.options-group {\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.group-title {\r\n  font-size: 16px;\r\n  font-weight: 700;\r\n  color: #2b1b12;\r\n  margin-0-0-15px-0;\r\n  border-bottom: 1px solid rgba(43, 27, 18, 0.08);\r\n  padding-bottom: 8px;\r\n}\r\n\r\n/* BOTÕES DE TAMANHO */\r\n.sizes-grid {\r\n  display: flex;\r\n  gap: 12px;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n.btn-size {\r\n  background-color: #ffffff;\r\n  color: #2b1b12;\r\n  border: 1px solid rgba(43, 27, 18, 0.1);\r\n  padding: 12px 20px;\r\n  border-radius: 12px;\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n  cursor: pointer;\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n.btn-size:hover {\r\n  background-color: #f0e6da;\r\n}\r\n\r\n.btn-size.active {\r\n  background-color: #2b1b12;\r\n  color: #ffffff;\r\n  border-color: #2b1b12;\r\n}\r\n\r\n/* LISTA DE ADICIONAIS */\r\n.addons-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n}\r\n\r\n.addon-item {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  background-color: #ffffff;\r\n  padding: 14px 20px;\r\n  border-radius: 14px;\r\n  cursor: pointer;\r\n  border: 1px solid rgba(43, 27, 18, 0.02);\r\n  transition: background-color 0.15s;\r\n}\r\n\r\n.addon-item:hover {\r\n  background-color: #fcfbfa;\r\n}\r\n\r\n.addon-left {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n}\r\n\r\n.addon-checkbox {\r\n  width: 18px;\r\n  height: 18px;\r\n  accent-color: #2b1b12;\r\n  cursor: pointer;\r\n}\r\n\r\n.addon-name {\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n  color: #2b1b12;\r\n}\r\n\r\n.addon-price {\r\n  font-size: 13px;\r\n  color: #615045;\r\n  font-weight: 500;\r\n}\r\n\r\n/* FIXAÇÃO DO FOOTER */\r\n.footer-action-bar {\r\n  background-color: #2b1b12;\r\n  padding: 24px;\r\n  border-radius: 20px;\r\n  color: #f7f3ee;\r\n  margin-top: auto;\r\n}\r\n\r\n.price-row {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 16px;\r\n}\r\n\r\n.total-label {\r\n  font-size: 15px;\r\n  opacity: 0.85;\r\n}\r\n\r\n.total-price {\r\n  font-size: 26px;\r\n  font-weight: 700;\r\n}\r\n\r\n.btn-submit {\r\n  width: 100%;\r\n  background-color: #f7f3ee;\r\n  color: #2b1b12;\r\n  border: none;\r\n  padding: 16px;\r\n  border-radius: 14px;\r\n  font-size: 16px;\r\n  font-weight: 700;\r\n  cursor: pointer;\r\n  transition: transform 0.1s, background-color 0.2s;\r\n}\r\n\r\n.btn-submit:hover {\r\n  background-color: #e6dfd5;\r\n  transform: scale(1.01);\r\n}\r\n\r\n.loading-container {\r\n  text-align: center;\r\n  padding: 100px 20px;\r\n  color: #615045;\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .config-card {\r\n    grid-template-columns: 1fr;\r\n    padding: 20px;\r\n  }\r\n}\r\n</style>"],"mappings":";;;AAmEA,eAAe;EACbA,IAAI,EAAE,wBAAwB;EAC9BC,IAAIA,CAAA,EAA