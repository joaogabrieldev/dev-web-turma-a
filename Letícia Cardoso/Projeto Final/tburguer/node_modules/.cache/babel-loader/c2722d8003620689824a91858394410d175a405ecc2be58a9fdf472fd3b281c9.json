{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuCafeteria: []\n    };\n  },\n  methods: {\n    async consultarMenu() {\n      const response = await fetch(`${this.$apiUrl}/menu`);\n      const dados = await response.json();\n\n      // Isto garante que se a API trouxer 'cafes' ele usa, se não, tenta 'burgues'\n      this.listaMenuHamburgues = dados.cafes || dados.burgues;\n      console.log(this.listaMenuHamburgues);\n    },\n    selecionarItem(itemSelecionado) {\n      const param = JSON.stringify(itemSelecionado);\n      const itemJson = encodeURIComponent(param);\n      this.$router.push({\n        path: \"/config\",\n        query: {\n          produto: itemJson\n        }\n      });\n    }\n  },\n  mounted() {\n    this.consultarMenu();\n  }\n};","map":{"version":3,"names":["name","data","listaMenuCafeteria","methods","consultarMenu","response","fetch","$apiUrl","dados","json","listaMenuHamburgues","cafes","burgues","console","log","selecionarItem","itemSelecionado","param","JSON","stringify","itemJson","encodeURIComponent","$router","push","path","query","produto","mounted"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\MenuView.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <h1>Menu da Cafeteria</h1>\r\n    <div id=\"scroll-horizontal\">\r\n      <div\r\n        id=\"card-content\"\r\n        v-for=\"item in listaMenuCafeteria\"\r\n        :key=\"item.id\"\r\n      >\r\n        <div id=\"card-linha\">\r\n          <div class=\"foto-produto\">\r\n            <img :src=\"item.foto\" :alt=\"item.nome\" />\r\n            <div class=\"card-coluna\">\r\n              <p id=\"nome-content\">{{ item.nome }}</p>\r\n              <p id=\"preco-content\">R$ {{ item.valor }},00</p>\r\n              <p id=\"descricao-content\">{{ item.descricao }}</p>\r\n              <button @click=\"selecionarItem(item)\">Selecionar</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"MenuView\",\r\n  data() {\r\n    return {\r\n      listaMenuCafeteria: [],\r\n    };\r\n  },\r\n  methods: {\r\n  async consultarMenu() {\r\n  const response = await fetch(`${this.$apiUrl}/menu`);\r\n  const dados = await response.json();\r\n  \r\n  // Isto garante que se a API trouxer 'cafes' ele usa, se não, tenta 'burgues'\r\n  this.listaMenuHamburgues = dados.cafes || dados.burgues; \r\n  console.log(this.listaMenuHamburgues);\r\n},\r\n    selecionarItem(itemSelecionado) {\r\n      const param = JSON.stringify(itemSelecionado);\r\n      const itemJson = encodeURIComponent(param);\r\n      this.$router.push({ path: \"/config\", query: { produto: itemJson } });\r\n    },\r\n  },\r\n  mounted() {\r\n    this.consultarMenu();\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n#card-content {\r\n  display: inline-block;\r\n  width: 280px;\r\n  min-height: 500px;\r\n  margin: 20px;\r\n  border: 1px solid #ddd;\r\n  border-radius: 15px;\r\n  box-shadow: 0 4px 8px #444;\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n#scroll-horizontal {\r\n  flex: 1;\r\n  overflow-x: auto;\r\n  white-space: nowrap;\r\n  width: 700px;\r\n  margin: 0 auto;\r\n}\r\n.foto-produto img {\r\n  width: 100%;\r\n  object-fit: cover;\r\n  max-height: 200px;\r\n  border-radius: 10px 0 0;\r\n}\r\n#nome-content { font-size: 25px; font-weight: bold; text-align: center; margin: 12px; }\r\n#preco-content { font-size: 35px; text-align: center; font-weight: bold; color: #704214; margin: 16px; } /* Tom Café */\r\n#descricao-content { font-size: 16px; color: gray; margin: 16px; white-space: pre-line; }\r\n.card-coluna button {\r\n  padding: 10px;\r\n  background-color: #704214; /* Marrom Cafeteria */\r\n  color: #fff;\r\n  font-weight: bold;\r\n  border-radius: 8px;\r\n  border: none;\r\n  width: 80%;\r\n  margin: 20px;\r\n  cursor: pointer;\r\n}\r\n.card-coluna button:hover {\r\n  background-color: transparent;\r\n  color: #704214;\r\n  border: solid 1px #704214;\r\n}\r\n</style>"],"mappings":";AA0BA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,kBAAkB,EAAE;IACtB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACT,MAAMC,aAAaA,CAAA,EAAG;MACtB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,OAAO,CAAC;MACpD,MAAMC,KAAI,GAAI,MAAMH,QAAQ,CAACI,IAAI,CAAC,CAAC;;MAEnC;MACA,IAAI,CAACC,mBAAkB,GAAIF,KAAK,CAACG,KAAI,IAAKH,KAAK,CAACI,OAAO;MACvDC,OAAO,CAACC,GAAG,CAAC,IAAI,CAACJ,mBAAmB,CAAC;IACvC,CAAC;IACGK,cAAcA,CAACC,eAAe,EAAE;MAC9B,MAAMC,KAAI,GAAIC,IAAI,CAACC,SAAS,CAACH,eAAe,CAAC;MAC7C,MAAMI,QAAO,GAAIC,kBAAkB,CAACJ,KAAK,CAAC;MAC1C,IAAI,CAACK,OAAO,CAACC,IAAI,CAAC;QAAEC,IAAI,EAAE,SAAS;QAAEC,KAAK,EAAE;UAAEC,OAAO,EAAEN;QAAS;MAAE,CAAC,CAAC;IACtE;EACF,CAAC;EACDO,OAAOA,CAAA,EAAG;IACR,IAAI,CAACvB,aAAa,CAAC,CAAC;EACtB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}