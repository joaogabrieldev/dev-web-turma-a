{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport AlertaComponent from './AlertaComponent.vue';\nexport default {\n  name: \"PedidoComponent\",\n  components: {\n    AlertaComponent\n  },\n  props: {\n    produto: null\n  },\n  data() {\n    return {\n      listaPreparos: [],\n      listaExtras: [],\n      nomeCliente: \"\",\n      preparoSelecionado: \"\",\n      listaExtrasSelecionados: [],\n      alerta: {\n        mensagem: \"\",\n        tipo: \"\"\n      }\n    };\n  },\n  methods: {\n    exibirAlerta(mensagem, tipo) {\n      this.alerta = {\n        mensagem,\n        tipo\n      };\n      setTimeout(() => {\n        this.alerta = {\n          mensagem: \"\",\n          tipo: \"\"\n        };\n      }, 4000);\n    },\n    async getDadosCafeteria() {\n      // Ajuste os endpoints baseados na sua API mockada\n      const resPreparo = await fetch(`${this.$apiUrl}/tipos_pontos`);\n      this.listaPreparos = await resPreparo.json();\n      const resOpcionais = await fetch(`${this.$apiUrl}/opcionais`);\n      const dadosOpcionais = await resOpcionais.json();\n      this.listaExtras = dadosOpcionais.complemento || [];\n    },\n    async criarPedido(e) {\n      e.preventDefault();\n\n      // REGRA: Campos Obrigatórios Bloqueados\n      if (!this.nomeCliente.trim() || !this.preparoSelecionado) {\n        this.exibirAlerta(\"Erro: Preencha o Nome e o Tamanho/Preparo!\", \"erro\");\n        return;\n      }\n      const dadosPedido = {\n        nome: this.nomeCliente,\n        ponto: this.preparoSelecionado,\n        complemento: Array.from(this.listaExtrasSelecionados),\n        burguer: this.produto,\n        // Mantido o mapeamento original da API do professor se necessário\n        statusId: 1\n      };\n      try {\n        const req = await fetch(`${this.$apiUrl}/pedidos`, {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\"\n          },\n          body: JSON.stringify(dadosPedido)\n        });\n        if (req.ok) {\n          this.exibirAlerta(\"Pedido cadastrado com sucesso! Redirecionando...\", \"sucesso\");\n\n          // Redirecionamento Inteligente pós exibição do feedback positivo\n          setTimeout(() => {\n            this.$router.push(\"/pedidos\");\n          }, 2000);\n        }\n      } catch (err) {\n        this.exibirAlerta(\"Erro ao processar requisição com a API.\", \"erro\");\n      }\n    }\n  },\n  mounted() {\n    this.getDadosCafeteria();\n  }\n};","map":{"version":3,"names":["AlertaComponent","name","components","props","produto","data","listaPreparos","listaExtras","nomeCliente","preparoSelecionado","listaExtrasSelecionados","alerta","mensagem","tipo","methods","exibirAlerta","setTimeout","getDadosCafeteria","resPreparo","fetch","$apiUrl","json","resOpcionais","dadosOpcionais","complemento","criarPedido","e","preventDefault","trim","dadosPedido","nome","ponto","Array","from","burguer","statusId","req","method","headers","body","JSON","stringify","ok","$router","push","err","mounted"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\components\\PedidoComponent.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <AlertaComponent :mensagem=\"alerta.mensagem\" :tipo=\"alerta.tipo\" />\r\n\r\n    <form id=\"pedido-form\" @submit=\"criarPedido($event)\">\r\n      <div>\r\n        <p id=\"nome-produto-content\">\r\n          {{ produto && produto.nome ? produto.nome : \"-\" }}\r\n        </p>\r\n        <img id=\"foto-content\" :src=\"produto && produto.foto ? produto.foto : ''\" />\r\n      </div>\r\n\r\n      <div class=\"inputs\">\r\n        <label for=\"nome-cliente\">Nome do Cliente *</label>\r\n        <input\r\n          type=\"text\"\r\n          v-model=\"nomeCliente\"\r\n          id=\"nome-cliente\"\r\n          placeholder=\"Digite seu Nome\"\r\n        />\r\n      </div>\r\n\r\n      <div class=\"inputs\">\r\n        <label>Tamanho/Preparo *</label>\r\n        <select v-model=\"preparoSelecionado\">\r\n          <option value=\"\">Selecione a opção base</option>\r\n          <option v-for=\"opcao in listaPreparos\" :key=\"opcao.id\" :value=\"opcao\">\r\n            {{ opcao.descricao }}\r\n          </option>\r\n        </select>\r\n      </div>\r\n\r\n      <div class=\"inputs\">\r\n        <label id=\"opcionais-titulo\"> Acompanhamentos & Extras</label>\r\n        <div class=\"checkbox-container\" v-for=\"extra in listaExtras\" :key=\"extra.id\">\r\n          <input type=\"checkbox\" :value=\"extra\" v-model=\"listaExtrasSelecionados\" />\r\n          <span>{{ extra.nome }}</span>\r\n        </div>\r\n\r\n        <div class=\"inputs\">\r\n          <input type=\"submit\" class=\"submit-btn\" value=\"Confirmar Pedido\" />\r\n        </div>\r\n      </div>\r\n    </form>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AlertaComponent from './AlertaComponent.vue';\r\n\r\nexport default {\r\n  name: \"PedidoComponent\",\r\n  components: { AlertaComponent },\r\n  props: { produto: null },\r\n  data() {\r\n    return {\r\n      listaPreparos: [],\r\n      listaExtras: [],\r\n      nomeCliente: \"\",\r\n      preparoSelecionado: \"\",\r\n      listaExtrasSelecionados: [],\r\n      alerta: { mensagem: \"\", tipo: \"\" }\r\n    };\r\n  },\r\n  methods: {\r\n    exibirAlerta(mensagem, tipo) {\r\n      this.alerta = { mensagem, tipo };\r\n      setTimeout(() => { this.alerta = { mensagem: \"\", tipo: \"\" }; }, 4000);\r\n    },\r\n    async getDadosCafeteria() {\r\n      // Ajuste os endpoints baseados na sua API mockada\r\n      const resPreparo = await fetch(`${this.$apiUrl}/tipos_pontos`);\r\n      this.listaPreparos = await resPreparo.json();\r\n      \r\n      const resOpcionais = await fetch(`${this.$apiUrl}/opcionais`);\r\n      const dadosOpcionais = await resOpcionais.json();\r\n      this.listaExtras = dadosOpcionais.complemento || [];\r\n    },\r\n    async criarPedido(e) {\r\n      e.preventDefault();\r\n\r\n      // REGRA: Campos Obrigatórios Bloqueados\r\n      if (!this.nomeCliente.trim() || !this.preparoSelecionado) {\r\n        this.exibirAlerta(\"Erro: Preencha o Nome e o Tamanho/Preparo!\", \"erro\");\r\n        return;\r\n      }\r\n\r\n      const dadosPedido = {\r\n        nome: this.nomeCliente,\r\n        ponto: this.preparoSelecionado,\r\n        complemento: Array.from(this.listaExtrasSelecionados),\r\n        burguer: this.produto, // Mantido o mapeamento original da API do professor se necessário\r\n        statusId: 1, \r\n      };\r\n\r\n      try {\r\n        const req = await fetch(`${this.$apiUrl}/pedidos`, {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify(dadosPedido),\r\n        });\r\n\r\n        if (req.ok) {\r\n          this.exibirAlerta(\"Pedido cadastrado com sucesso! Redirecionando...\", \"sucesso\");\r\n          \r\n          // Redirecionamento Inteligente pós exibição do feedback positivo\r\n          setTimeout(() => {\r\n            this.$router.push(\"/pedidos\");\r\n          }, 2000);\r\n        }\r\n      } catch (err) {\r\n        this.exibirAlerta(\"Erro ao processar requisição com a API.\", \"erro\");\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    this.getDadosCafeteria();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* Aproveite a sua estilização adicionando tons #5c3a21 (marrom) nos botões e bordas de destaque */\r\nlabel { border-left: 4px solid #5c3a21; }\r\n.submit-btn { background-color: #5c3a21; color: white; }\r\n.submit-btn:hover { background-color: #3e2723; }\r\n</style>"],"mappings":";AAgDA,OAAOA,eAAc,MAAO,uBAAuB;AAEnD,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,UAAU,EAAE;IAAEF;EAAgB,CAAC;EAC/BG,KAAK,EAAE;IAAEC,OAAO,EAAE;EAAK,CAAC;EACxBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,aAAa,EAAE,EAAE;MACjBC,WAAW,EAAE,EAAE;MACfC,WAAW,EAAE,EAAE;MACfC,kBAAkB,EAAE,EAAE;MACtBC,uBAAuB,EAAE,EAAE;MAC3BC,MAAM,EAAE;QAAEC,QAAQ,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG;IACnC,CAAC;EACH,