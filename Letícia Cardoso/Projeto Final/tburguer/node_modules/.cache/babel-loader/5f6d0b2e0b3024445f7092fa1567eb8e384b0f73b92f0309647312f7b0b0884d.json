{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport AlertaComponent from './AlertaComponent.vue';\nexport default {\n  name: \"ListaPedidoComponent\",\n  components: {\n    AlertaComponent\n  },\n  data() {\n    return {\n      listaPedidosRealizados: [],\n      listaStatusPedido: [],\n      alerta: {\n        mensagem: \"\",\n        tipo: \"\"\n      }\n    };\n  },\n  methods: {\n    exibirAlerta(mensagem, tipo) {\n      this.alerta = {\n        mensagem,\n        tipo\n      };\n      setTimeout(() => {\n        this.alerta = {\n          mensagem: \"\",\n          tipo: \"\"\n        };\n      }, 3500);\n    },\n    async consultarPedidos() {\n      const response = await fetch(`${this.$apiUrl}/pedidos`);\n      this.listaPedidosRealizados = await response.json();\n    },\n    async consultarStatusPedido() {\n      const response = await fetch(`${this.$apiUrl}/status_pedido`);\n      this.listaStatusPedido = await response.json();\n    },\n    async deletarPedido(id) {\n      if (confirm(\"Deseja realmente remover este pedido?\")) {\n        const response = await fetch(`${this.$apiUrl}/pedidos/${id}`, {\n          method: \"DELETE\"\n        });\n        if (response.ok) {\n          this.exibirAlerta(\"Pedido excluído com sucesso!\", \"aviso\"); // Laranja/Aviso de remoção\n\n          // ATUALIZAÇÃO EM TEMPO REAL: Filtra o array local imediatamente para re-renderizar a tela\n          this.listaPedidosRealizados = this.listaPedidosRealizados.filter(pedido => pedido.id !== id);\n        }\n      }\n    },\n    async atualizarStatusPedido(event, idPedido) {\n      const novoStatus = event.target.value;\n      const response = await fetch(`${this.$apiUrl}/pedidos/${idPedido}`, {\n        method: \"PATCH\",\n        headers: {\n          \"Content-Type\": \"application/json\"\n        },\n        body: JSON.stringify({\n          statusId: novoStatus\n        })\n      });\n      if (response.ok) {\n        this.exibirAlerta(\"Status do pedido atualizado!\", \"info\"); // Azul\n      }\n    }\n  },\n  mounted() {\n    this.consultarPedidos();\n    this.consultarStatusPedido();\n  }\n};","map":{"version":3,"names":["AlertaComponent","name","components","data","listaPedidosRealizados","listaStatusPedido","alerta","mensagem","tipo","methods","exibirAlerta","setTimeout","consultarPedidos","response","fetch","$apiUrl","json","consultarStatusPedido","deletarPedido","id","confirm","method","ok","filter","pedido","atualizarStatusPedido","event","idPedido","novoStatus","target","value","headers","body","JSON","stringify","statusId","mounted"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\components\\ListaPedidoComponent.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <AlertaComponent :mensagem=\"alerta.mensagem\" :tipo=\"alerta.tipo\" />\r\n\r\n    <div id=\"pedidos-tabela\">\r\n      <div id=\"pedidos-tabela-cabecalho\">\r\n        <div id=\"ordem-id\">#ID</div>\r\n        <div>Cliente</div>\r\n        <div>Item</div>\r\n        <div>Preparo</div>\r\n        <div>Extras</div>\r\n        <div>Status</div>\r\n        <div id=\"div-acoes\">Ações</div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"pedidos-tabela-linha\" v-for=\"pedido in listaPedidosRealizados\" :key=\"pedido.id\">\r\n      <div id=\"ordem-numero\">{{ pedido.id }}</div>\r\n      <div>{{ pedido.nome }}</div>\r\n      <div>{{ pedido.burguer ? pedido.burguer.nome : 'Café Tradicional' }}</div>\r\n      <div>{{ pedido.ponto ? pedido.ponto.descricao : '-' }}</div>\r\n      <div>\r\n        <ul>\r\n          <li v-for=\"(extra, index) in pedido.complemento\" :key=\"index\">{{ extra.nome }}</li>\r\n        </ul>\r\n      </div>\r\n      <div>\r\n        <select class=\"status\" @change=\"atualizarStatusPedido($event, pedido.id)\">\r\n          <option v-for=\"status in listaStatusPedido\" :key=\"status.id\" :value=\"status.id\" :selected=\"status.id == pedido.statusId\">\r\n            {{ status.descricao }}\r\n          </option>\r\n        </select>\r\n      </div>\r\n      <div id=\"div-acoes\">\r\n        <img @click=\"deletarPedido(pedido.id)\" src=\"/img/icone_lixeira.png\" width=\"30px\" height=\"30px\" style=\"cursor:pointer;\" />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AlertaComponent from './AlertaComponent.vue';\r\n\r\nexport default {\r\n  name: \"ListaPedidoComponent\",\r\n  components: { AlertaComponent },\r\n  data() {\r\n    return {\r\n      listaPedidosRealizados: [],\r\n      listaStatusPedido: [],\r\n      alerta: { mensagem: \"\", tipo: \"\" }\r\n    };\r\n  },\r\n  methods: {\r\n    exibirAlerta(mensagem, tipo) {\r\n      this.alerta = { mensagem, tipo };\r\n      setTimeout(() => { this.alerta = { mensagem: \"\", tipo: \"\" }; }, 3500);\r\n    },\r\n    async consultarPedidos() {\r\n      const response = await fetch(`${this.$apiUrl}/pedidos`);\r\n      this.listaPedidosRealizados = await response.json();\r\n    },\r\n    async consultarStatusPedido() {\r\n      const response = await fetch(`${this.$apiUrl}/status_pedido`);\r\n      this.listaStatusPedido = await response.json();\r\n    },\r\n    async deletarPedido(id) {\r\n      if (confirm(\"Deseja realmente remover este pedido?\")) {\r\n        const response = await fetch(`${this.$apiUrl}/pedidos/${id}`, { method: \"DELETE\" });\r\n        \r\n        if (response.ok) {\r\n          this.exibirAlerta(\"Pedido excluído com sucesso!\", \"aviso\"); // Laranja/Aviso de remoção\r\n          \r\n          // ATUALIZAÇÃO EM TEMPO REAL: Filtra o array local imediatamente para re-renderizar a tela\r\n          this.listaPedidosRealizados = this.listaPedidosRealizados.filter(pedido => pedido.id !== id);\r\n        }\r\n      }\r\n    },\r\n    async atualizarStatusPedido(event, idPedido) {\r\n      const novoStatus = event.target.value;\r\n      const response = await fetch(`${this.$apiUrl}/pedidos/${idPedido}`, {\r\n        method: \"PATCH\",\r\n        headers: { \"Content-Type\": \"application/json\" },\r\n        body: JSON.stringify({ statusId: novoStatus }),\r\n      });\r\n\r\n      if (response.ok) {\r\n        this.exibirAlerta(\"Status do pedido atualizado!\", \"info\"); // Azul\r\n      }\r\n    },\r\n  },\r\n  mounted() {\r\n    this.consultarPedidos();\r\n    this.consultarStatusPedido();\r\n  },\r\n};\r\n</script>"],"mappings":";;AAyCA,OAAOA,eAAc,MAAO,uBAAuB;AAEnD,eAAe;EACbC,IAAI,EAAE,sBAAsB;EAC5BC,UAAU,EAAE;IAAEF;EAAgB,CAAC;EAC/BG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,sBAAsB,EAAE,EAAE;MAC1BC,iBAAiB,EAAE,EAAE;MACrBC,MAAM,EAAE;QAAEC,QAAQ,EAAE,EAAE;QAAEC,IAAI,EAAE;MAAG;IACnC,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,YAAYA,CAACH,QAAQ,EAAEC,IAAI,EAAE;MAC3B,IAAI,CAACF,MAAK,GAAI;QAAEC,QAAQ;QAAEC;MAAK,CAAC;MAChCG,UAAU,CAAC,MAAM;QAAE,IAAI,CAACL,MAAK,GAAI;UAAEC,QAAQ,EAAE,EAAE;UAAEC,IAAI,EAAE;QAAG,CAAC;MAAE,CAAC,EAAE,IAAI,CAAC;IACvE,CAAC;IACD,MAAMI,gBAAgBA,CAAA,EAAG;MACvB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,UAAU,CAAC;MACvD,IAAI,CAACX,sBAAqB,GAAI,MAAMS,QAAQ,CAACG,IAAI,CAAC,CAAC;IACrD,CAAC;IACD,MAAMC,qBAAqBA,CAAA,EAAG;MAC5B,MAAMJ,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,gBAAgB,CAAC;MAC7D,IAAI,CAACV,iBAAgB,GAAI,MAAMQ,QAAQ,CAACG,IAAI,CAAC,CAAC;IAChD,CAAC;IACD,MAAME,aAAaA,CAACC,EAAE,EAAE;MACtB,IAAIC,OAAO,CAAC,uCAAuC,CAAC,EAAE;QACpD,MAAMP,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,YAAYI,EAAE,EAAE,EAAE;UAAEE,MAAM,EAAE;QAAS,CAAC,CAAC;QAEnF,IAAIR,QAAQ,CAACS,EAAE,EAAE;UACf,IAAI,CAACZ,YAAY,CAAC,8BAA8B,EAAE,OAAO,CAAC,EAAE;;UAE5D;UACA,IAAI,CAACN,sBAAqB,GAAI,IAAI,CAACA,sBAAsB,CAACmB,MAAM,CAACC,MAAK,IAAKA,MAAM,CAACL,EAAC,KAAMA,EAAE,CAAC;QAC9F;MACF;IACF,CAAC;IACD,MAAMM,qBAAqBA,CAACC,KAAK,EAAEC,QAAQ,EAAE;MAC3C,MAAMC,UAAS,GAAIF,KAAK,CAACG,MAAM,CAACC,KAAK;MACrC,MAAMjB,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,YAAYY,QAAQ,EAAE,EAAE;QAClEN,MAAM,EAAE,OAAO;QACfU,OAAO,EAAE;UAAE,cAAc,EAAE;QAAmB,CAAC;QAC/CC,IAAI,EAAEC,IAAI,CAACC,SAAS,CAAC;UAAEC,QAAQ