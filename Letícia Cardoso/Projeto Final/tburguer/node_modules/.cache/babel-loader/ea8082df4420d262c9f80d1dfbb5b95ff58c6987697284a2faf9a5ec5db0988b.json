=\\\"round\\\" data-v-6d68006e><polyline points=\\\"3 6 5 6 21 6\\\" data-v-6d68006e></polyline><path d=\\\"M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2\\\" data-v-6d68006e></path><line x1=\\\"10\\\" y1=\\\"11\\\" x2=\\\"10\\\" y2=\\\"17\\\" data-v-6d68006e></line><line x1=\\\"14\\\" y1=\\\"11\\\" x2=\\\"14\\\" y2=\\\"17\\\" data-v-6d68006e></line></svg>\", 1)]))], 8 /* PROPS */, _hoisted_18)])]);\n  }), 128 /* KEYED_FRAGMENT */))]), _createElementVNode(\"div\", _hoisted_19, [_cache[12] || (_cache[12] = _createElementVNode(\"h3\", null, \"Resumo do Pedido\", -1 /* CACHED */)), _createElementVNode(\"div\", _hoisted_20, [_cache[11] || (_cache[11] = _createElementVNode(\"span\", null, \"Total dos Itens:\", -1 /* CACHED */)), _createElementVNode(\"span\", _hoisted_21, \"R$ \" + _toDisplayString($options.totalGeral.toFixed(2)), 1 /* TEXT */)]), _createElementVNode(\"button\", {\n    class: \"btn-finalizar\",\n    onClick: _cache[2] || (_cache[2] = (...args) => $options.finalizarCompra && $options.finalizarCompra(...args))\n  }, \" Confirmar e Pagar \")])]))]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_createVNode","_Transition","name","$data","modalRemover","visivel","_hoisted_2","_hoisted_3","_hoisted_4","_toDisplayString","nomeItem","_hoisted_5","onClick","_cache","args","$options","fecharModal","confirmarRemocao","listaPedidos","length","_hoisted_6","_component_router_link","to","_hoisted_7","_hoisted_8","_Fragment","_renderList","pedido","key","id","_hoisted_9","src","foto_cafe","alt","nome_cafe","_hoisted_11","_hoisted_12","ponto","opcionais","_hoisted_13","opc","nome","_hoisted_14","_hoisted_15","status","_hoisted_16","_hoisted_17","parseFloat","valor_total","toFixed","$event","abrirModalRemover","title","_hoisted_19","_hoisted_20","_hoisted_21","totalGeral","finalizarCompra"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\PedidosView.vue"],"sourcesContent":["<template>\r\n  <div class=\"carrinho-container\">\r\n    <h1 class=\"page-title\">Seu Carrinho de Compras</h1>\r\n\r\n    <transition name=\"modal-fade\">\r\n      <div v-if=\"modalRemover.visivel\" class=\"modal-overlay\">\r\n        <div class=\"modal-card\">\r\n          <div class=\"modal-header\">\r\n            <span class=\"modal-icon\">⚠️</span>\r\n            <h3>Confirmar Ação</h3>\r\n          </div>\r\n          <div class=\"modal-body\">\r\n            <p>Tem certeza que deseja remover <strong>{{ modalRemover.nomeItem }}</strong> do seu carrinho?</p>\r\n          </div>\r\n          <div class=\"modal-footer\">\r\n            <button class=\"btn-modal-cancelar\" @click=\"fecharModal\">Cancelar</button>\r\n            <button class=\"btn-modal-confirmar\" @click=\"confirmarRemocao\">Sim, Remover</button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </transition>\r\n\r\n    <div v-if=\"listaPedidos.length === 0\" class=\"carrinho-vazio\">\r\n      <p>O seu carrinho está vazio no momento.</p>\r\n      <router-link to=\"/menu\" class=\"btn-voltar\">Ver o Cardápio</router-link>\r\n    </div>\r\n\r\n    <div v-else class=\"carrinho-conteudo\">\r\n      <div class=\"lista-itens\">\r\n        <div v-for=\"pedido in listaPedidos\" :key=\"pedido.id\" class=\"pedido-card\">\r\n          <div class=\"pedido-foto\">\r\n            <img :src=\"pedido.foto_cafe\" :alt=\"pedido.nome_cafe\" />\r\n          </div>\r\n          \r\n          <div class=\"pedido-detalhes\">\r\n            <h3>{{ pedido.nome_cafe }}</h3>\r\n            <p class=\"pedido-opcao\"><strong>Opção:</strong> {{ pedido.ponto || 'Tamanho Único' }}</p>\r\n            \r\n            <div v-if=\"pedido.opcionais && pedido.opcionais.length > 0\" class=\"pedido-adicionais\">\r\n              <strong>Adicionais:</strong>\r\n              <ul>\r\n                <li v-for=\"opc in pedido.opcionais\" :key=\"opc.id\">\r\n                  • {{ opc.nome }}\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            \r\n            <p class=\"pedido-status\">\r\n              <span class=\"badge\">{{ pedido.status || 'Em preparação' }}</span>\r\n            </p>\r\n          </div>\r\n\r\n          <div class=\"pedido-preco-acao\">\r\n            <span class=\"preco-item\">R$ {{ parseFloat(pedido.valor_total).toFixed(2) }}</span>\r\n            <button class=\"btn-remover\" @click=\"abrirModalRemover(pedido)\" title=\"Remover item\">\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"3 6 5 6 21 6\"></polyline><path d=\"M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2\"></path><line x1=\"10\" y1=\"11\" x2=\"10\" y2=\"17\"></line><line x1=\"14\" y1=\"11\" x2=\"14\" y2=\"17\"></line></svg>\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"resumo-carrinho\">\r\n        <h3>Resumo do Pedido</h3>\r\n        <div class=\"resumo-linha\">\r\n          <span>Total dos Itens:</span>\r\n          <span class=\"resumo-total\">R$ {{ totalGeral.toFixed(2) }}</span>\r\n        </div>\r\n        <button class=\"btn-finalizar\" @click=\"finalizarCompra\">\r\n          Confirmar e Pagar\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"PedidosView\",\r\n  data() {\r\n    return {\r\n      listaPedidos: [],\r\n      // Controle do estado do modal refinado\r\n      modalRemover: {\r\n        visivel: false,\r\n        idItem: null,\r\n        nomeItem: \"\"\r\n      }\r\n    };\r\n  },\r\n  computed: {\r\n    totalGeral() {\r\n      return this.listaPedidos.reduce((soma, item) => {\r\n        let preco = String(item.valor_total).replace(',', '.');\r\n        return soma + (parseFloat(preco) || 0);\r\n      }, 0);\r\n    }\r\n  },\r\n  methods: {\r\n    async buscarPedidos() {\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\");\r\n        this.listaPedidos = await response.json();\r\n      } catch (error) {\r\n        console.error(\"Erro ao carregar o carrinho:\", error);\r\n      }\r\n    },\r\n    \r\n    abrirModalRemover(pedido) {\r\n      this.modalRemover.idItem = pedido.id;\r\n      this.modalRemover.nomeItem = pedido.nome_cafe;\r\n      this.modalRemover.visivel = true;\r\n    },\r\n\r\n    fecharModal() {\r\n      this.modalRemover.visivel = false;\r\n      this.modalRemover.idItem = null;\r\n      this.modalRemover.nomeItem = \"\";\r\n    },\r\n\r\n    async confirmarRemocao() {\r\n      const id = this.modalRemover.idItem;\r\n      try {\r\n        const response = await fetch(`http://localhost:3000/pedidos/${id}`, {\r\n          method: \"DELETE\"\r\n        });\r\n        \r\n        if (response.ok) {\r\n          this.listaPedidos = this.listaPedidos.filter(p => p.id !== id);\r\n          this.fecharModal();\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao deletar item:\", error);\r\n      }\r\n    },\r\n\r\n    finalizarCompra() {\r\n      alert(\"Pedido enviado para a cozinha do Âmbar Café!\");\r\n    }\r\n  },\r\n  mounted() {\r\n    this.buscarPedidos();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* MODAL DE CONFIRMAÇÃO PREMIUM */\r\n.modal-overlay {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100vw;\r\n  height: 100vh;\r\n  background-color: rgba(43, 27, 18, 0.4); /* Fundo escurecido suave */\r\n  backdrop-filter: blur(4px); /* Desfoque sutil de fundo */\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  z-index: 9999;\r\n}\r\n\r\n.modal-card {\r\n  background-color: #f7f3ee;\r\n  border-radius: 20px;\r\n  width: 90%;\r\n  max-width: 420px;\r\n  padding: 25px;\r\n  box-shadow: 0 15px 40px rgba(43, 27, 18, 0.15);\r\n  border: 1px solid rgba(230, 126, 34, 0.2); /* Borda sutil de aviso */\r\n}\r\n\r\n.modal-header {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.modal-icon {\r\n  font-size: 24px;\r\n  background-color: #e67e22; /* Laranja de Aviso conforme requisito */\r\n  color: #ffffff;\r\n  width: 38px;\r\n  height: 38px;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  border-radius: 50%;\r\n}\r\n\r\n.modal-header h3 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  color: #2b1b12;\r\n  font-size: 20px;\r\n  margin: 0;\r\n}\r\n\r\n.modal-body p {\r\n  color: #615045;\r\n  font-size: 15px;\r\n  line-height: 1.5;\r\n  margin: 0 0 25px 0;\r\n}\r\n\r\n.modal-footer {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: 12px;\r\n}\r\n\r\n.btn-modal-cancelar {\r\n  background-color: #e6dfd5;\r\n  color: #523b2e;\r\n  border: none;\r\n  padding: 10px 20px;\r\n  border-radius: 8px;\r\n  font-weight: 600;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.btn-modal-cancelar:hover {\r\n  background-color: #dcd4c9;\r\n}\r\n\r\n.btn-modal-confirmar {\r\n  background-color: #a84343; /* Tom avermelhado elegante para destruição/remoção */\r\n  color: #ffffff;\r\n  border: none;\r\n  padding: 10px 20px;\r\n  border-radius: 8px;\r\n  font-weight: 600;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n  transition: opacity 0.2s;\r\n}\r\n\r\n.btn-modal-confirmar:hover {\r\n  opacity: 0.9;\r\n}\r\n\r\n/* Transições de Entrada/Saída */\r\n.modal-fade-enter-active, .modal-fade-leave-active {\r\n  transition: opacity 0.25s ease;\r\n}\r\n.modal-fade-enter, .modal-fade-leave-to {\r\n  opacity: 0;\r\n}\r\n\r\n/* Layout Geral (Mantido) */\r\n.carrinho-container {\r\n  max-width: 1100px;\r\n  margin: 120px auto 40px auto;\r\n  padding: 0 20px;\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  text-align: left;\r\n}\r\n.page-title {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  color: #2b1b12;\r\n  font-size: 32px;\r\n  margin-bottom: 30px;\r\n}\r\n.carrinho-vazio {\r\n  text-align: center;\r\n  padding: 60px;\r\n  background-color: #f7f3ee;\r\n  border-radius: 20px;\r\n  color: #615045;\r\n}\r\n.btn-voltar {\r\n  display: inline-block;\r\n  margin-top: 20px;\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  text-decoration: none;\r\n  padding: 12px 24px;\r\n  border-radius: 10px;\r\n  font-weight: 600;\r\n  transition: opacity 0.2s;\r\n}\r\n.carrinho-conteudo {\r\n  display: grid;\r\n  grid-template-columns: 2fr 1fr;\r\n  gap: 40px;\r\n  align-items: start;\r\n}\r\n.lista-itens {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 16px;\r\n}\r\n.pedido-card {\r\n  display: flex;\r\n  align-items: center;\r\n  background-color: #f7f3ee;\r\n  padding: 20px;\r\n  border-radius: 18px;\r\n  box-shadow: 0 4px 15px rgba(43, 27, 18, 0.02);\r\n}\r\n.pedido-foto {\r\n  width: 100px;\r\n  height: 100px;\r\n  border-radius: 12px;\r\n  overflow: hidden;\r\n  margin-right: 20px;\r\n  flex-shrink: 0;\r\n}\r\n.pedido-foto img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n.pedido-detalhes {\r\n  flex-grow: 1;\r\n}\r\n.pedido-detalhes h3 {\r\n  font-size: 18px;\r\n  color: #2b1b12;\r\n  margin: 0 0 6px 0;\r\n}\r\n.pedido-opcao {\r\n  font-size: 13px;\r\n  color: #615045;\r\n  margin: 0 0 8px 0;\r\n}\r\n.pedido-adicionais {\r\n  font-size: 13px;\r\n  color: #615045;\r\n  margin-bottom: 8px;\r\n}\r\n.pedido-adicionais ul {\r\n  list-style: none;\r\n  padding: 0;\r\n  margin: 4px 0 0 0;\r\n  display: flex;\r\n  gap: 10px;\r\n  flex-wrap: wrap;\r\n}\r\n.pedido-status .badge {\r\n  display: inline-block;\r\n  background-color: #e6dfd5;\r\n  color: #523b2e;\r\n  padding: 4px 10px;\r\n  border-radius: 20px;\r\n  font-size: 11px;\r\n  font-weight: 600;\r\n  text-transform: uppercase;\r\n}\r\n.pedido-preco-acao {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: flex-end;\r\n  gap: 15px;\r\n  margin-left: 20px;\r\n}\r\n.preco-item {\r\n  font-size: 18px;\r\n  font-weight: 700;\r\n  color: #2b1b12;\r\n}\r\n.btn-remover {\r\n  background: none;\r\n  border: none;\r\n  color: #a84343;\r\n  cursor: pointer;\r\n  padding: 5px;\r\n  transition: transform 0.1s;\r\n}\r\n.btn-remover:hover {\r\n  transform: scale(1.1);\r\n}\r\n.resumo-carrinho {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  padding: 24px;\r\n  border-radius: 20px;\r\n}\r\n.resumo-carrinho h3 {\r\n  margin-top: 0;\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 20px;\r\n  border-bottom: 1px solid rgba(247, 243, 238, 0.1);\r\n  padding-bottom: 12px;\r\n}\r\n.resumo-linha {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin: 20px 0;\r\n  font-size: 15px;\r\n}\r\n.resumo-total {\r\n  font-size: 22px;\r\n  font-weight: 700;\r\n}\r\n.btn-finalizar {\r\n  width: 100%;\r\n  background-color: #f7f3ee;\r\n  color: #2b1b12;\r\n  border: none;\r\n  padding: 14px;\r\n  border-radius: 12px;\r\n  font-weight: 600;\r\n  font-size: 15px;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n.btn-finalizar:hover {\r\n  background-color: #e6dfd5;\r\n}\r\n@media (max-width: 768px) {\r\n  .carrinho-conteudo { grid-template-columns: 1fr; }\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAoB;;;EAIMA,KAAK,EAAC;;;EAChCA,KAAK,EAAC;AAAY;;EAKhBA,KAAK,EAAC;AAAY;;EAGlBA,KAAK,EAAC;AAAc;;;EAQOA,KAAK,EAAC;;;;EAKhCA,KAAK,EAAC;;;EACXA,KAAK,EAAC;AAAa;;EAEfA,KAAK,EAAC;AAAa;;;EAInBA,KAAK,EAAC;AAAiB;;EAEvBA,KAAK,EAAC;AAAc;;;EAEqCA,KAAK,EAAC;;;EAS/DA,KAAK,EAAC;AAAe;;EAChBA,KAAK,EAAC;AAAO;;EAIlBA,KAAK,EAAC;AAAmB;;EACtBA,KAAK,EAAC;AAAY;;;EAQzBA,KAAK,EAAC;AAAiB;;EAErBA,KAAK,EAAC;AAAc;;EAEjBA,KAAK,EAAC;AAAc;;;uBAhElCC,mBAAA,CAuEM,OAvENC,UAuEM,G,4BAtEJC,mBAAA,CAAmD;IAA/CH,KAAK,EAAC;EAAY,GAAC,yBAAuB,qBAE9CI,YAAA,CAgBaC,WAAA;IAhBDC,IAAI,EAAC;EAAY;sBAC3B,MAcM,CAdKC,KAAA,CAAAC,YAAY,CAACC,OAAO,I,cAA/BR,mBAA