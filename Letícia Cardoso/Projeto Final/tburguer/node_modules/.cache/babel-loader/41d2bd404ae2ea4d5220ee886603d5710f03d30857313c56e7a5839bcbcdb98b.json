{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nexport default {\n  name: \"PedidosView\",\n  data() {\n    return {\n      listaPedidos: []\n    };\n  },\n  computed: {\n    // Soma o valor total de todos os itens guardados no db.json\n    totalGeral() {\n      return this.listaPedidos.reduce((soma, item) => {\n        let preco = String(item.valor_total).replace(',', '.');\n        return soma + (parseFloat(preco) || 0);\n      }, 0);\n    }\n  },\n  methods: {\n    async buscarPedidos() {\n      try {\n        const response = await fetch(\"http://localhost:3000/pedidos\");\n        this.listaPedidos = await response.json();\n      } catch (error) {\n        console.error(\"Erro ao carregar o carrinho:\", error);\n      }\n    },\n    async removerDoCarrinho(id) {\n      if (!confirm(\"Tem certeza que deseja remover este item do carrinho?\")) return;\n      try {\n        const response = await fetch(`http://localhost:3000/pedidos/${id}`, {\n          method: \"DELETE\"\n        });\n        if (response.ok) {\n          // Atualiza a lista local removendo o item deletado\n          this.listaPedidos = this.listaPedidos.filter(p => p.id !== id);\n        }\n      } catch (error) {\n        console.error(\"Erro ao deletar item:\", error);\n      }\n    },\n    finalizarCompra() {\n      alert(\"Pedido enviado para a cozinha com sucesso! Agradecemos a preferência.\");\n      // Aqui você poderia mudar o status de todos para 'Pago' ou limpar o db, se quisesse\n    }\n  },\n  mounted() {\n    this.buscarPedidos();\n  }\n};","map":{"version":3,"names":["name","data","listaPedidos","computed","totalGeral","reduce","soma","item","preco","String","valor_total","replace","parseFloat","methods","buscarPedidos","response","fetch","json","error","console","removerDoCarrinho","id","confirm","method","ok","filter","p","finalizarCompra","alert","mounted"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\PedidosView.vue"],"sourcesContent":["<template>\r\n  <div class=\"carrinho-container\">\r\n    <h1 class=\"page-title\">Seu Carrinho de Compras</h1>\r\n\r\n    <div v-if=\"listaPedidos.length === 0\" class=\"carrinho-vazio\">\r\n      <p>O seu carrinho está vazio no momento.</p>\r\n      <router-link to=\"/menu\" class=\"btn-voltar\">Ver o Cardápio</router-link>\r\n    </div>\r\n\r\n    <div v-else class=\"carrinho-conteudo\">\r\n      <div class=\"lista-itens\">\r\n        <div v-for=\"pedido in listaPedidos\" :key=\"pedido.id\" class=\"pedido-card\">\r\n          <div class=\"pedido-foto\">\r\n            <img :src=\"pedido.foto_cafe\" :alt=\"pedido.nome_cafe\" />\r\n          </div>\r\n          \r\n          <div class=\"pedido-detalhes\">\r\n            <h3>{{ pedido.nome_cafe }}</h3>\r\n            <p class=\"pedido-opcao\"><strong>Opção:</strong> {{ pedido.ponto || 'Tamanho Único' }}</p>\r\n            \r\n            <div v-if=\"pedido.opcionais && pedido.opcionais.length > 0\" class=\"pedido-adicionais\">\r\n              <strong>Adicionais:</strong>\r\n              <ul>\r\n                <li v-for=\"opc in pedido.opcionais\" :key=\"opc.id\">\r\n                  • {{ opc.nome }}\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            \r\n            <p class=\"pedido-status\">\r\n              <span class=\"badge\">{{ pedido.status || 'Em preparação' }}</span>\r\n            </p>\r\n          </div>\r\n\r\n          <div class=\"pedido-preco-acao\">\r\n            <span class=\"preco-item\">R$ {{ parseFloat(pedido.valor_total).toFixed(2) }}</span>\r\n            <button class=\"btn-remover\" @click=\"removerDoCarrinho(pedido.id)\" title=\"Remover item\">\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"3 6 5 6 21 6\"></polyline><path d=\"M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2\"></path><line x1=\"10\" y1=\"11\" x2=\"10\" y2=\"17\"></line><line x1=\"14\" y1=\"11\" x2=\"14\" y2=\"17\"></line></svg>\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"resumo-carrinho\">\r\n        <h3>Resumo do Pedido</h3>\r\n        <div class=\"resumo-linha\">\r\n          <span>Total dos Itens:</span>\r\n          <span class=\"resumo-total\">R$ {{ totalGeral.toFixed(2) }}</span>\r\n        </div>\r\n        <button class=\"btn-finalizar\" @click=\"finalizarCompra\">\r\n          Confirmar e Pagar\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"PedidosView\",\r\n  data() {\r\n    return {\r\n      listaPedidos: []\r\n    };\r\n  },\r\n  computed: {\r\n    // Soma o valor total de todos os itens guardados no db.json\r\n    totalGeral() {\r\n      return this.listaPedidos.reduce((soma, item) => {\r\n        let preco = String(item.valor_total).replace(',', '.');\r\n        return soma + (parseFloat(preco) || 0);\r\n      }, 0);\r\n    }\r\n  },\r\n  methods: {\r\n    async buscarPedidos() {\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\");\r\n        this.listaPedidos = await response.json();\r\n      } catch (error) {\r\n        console.error(\"Erro ao carregar o carrinho:\", error);\r\n      }\r\n    },\r\n    \r\n    async removerDoCarrinho(id) {\r\n      if (!confirm(\"Tem certeza que deseja remover este item do carrinho?\")) return;\r\n      \r\n      try {\r\n        const response = await fetch(`http://localhost:3000/pedidos/${id}`, {\r\n          method: \"DELETE\"\r\n        });\r\n        \r\n        if (response.ok) {\r\n          // Atualiza a lista local removendo o item deletado\r\n          this.listaPedidos = this.listaPedidos.filter(p => p.id !== id);\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao deletar item:\", error);\r\n      }\r\n    },\r\n\r\n    finalizarCompra() {\r\n      alert(\"Pedido enviado para a cozinha com sucesso! Agradecemos a preferência.\");\r\n      // Aqui você poderia mudar o status de todos para 'Pago' ou limpar o db, se quisesse\r\n    }\r\n  },\r\n  mounted() {\r\n    this.buscarPedidos();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.carrinho-container {\r\n  max-width: 1100px;\r\n  margin: 120px auto 40px auto;\r\n  padding: 0 20px;\r\n  font-family: 'Plus Jakarta Sans', sans-serif;\r\n  text-align: left;\r\n}\r\n\r\n.page-title {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  color: #2b1b12;\r\n  font-size: 32px;\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.carrinho-vazio {\r\n  text-align: center;\r\n  padding: 60px;\r\n  background-color: #f7f3ee;\r\n  border-radius: 20px;\r\n  color: #615045;\r\n}\r\n\r\n.btn-voltar {\r\n  display: inline-block;\r\n  margin-top: 20px;\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  text-decoration: none;\r\n  padding: 12px 24px;\r\n  border-radius: 10px;\r\n  font-weight: 600;\r\n  transition: opacity 0.2s;\r\n}\r\n\r\n.btn-voltar:hover {\r\n  opacity: 0.9;\r\n}\r\n\r\n.carrinho-conteudo {\r\n  display: grid;\r\n  grid-template-columns: 2fr 1fr;\r\n  gap: 40px;\r\n  align-items: start;\r\n}\r\n\r\n.lista-itens {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 16px;\r\n}\r\n\r\n.pedido-card {\r\n  display: flex;\r\n  align-items: center;\r\n  background-color: #f7f3ee;\r\n  padding: 20px;\r\n  border-radius: 18px;\r\n  box-shadow: 0 4px 15px rgba(43, 27, 18, 0.02);\r\n}\r\n\r\n.pedido-foto {\r\n  width: 100px;\r\n  height: 100px;\r\n  border-radius: 12px;\r\n  overflow: hidden;\r\n  margin-right: 20px;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.pedido-foto img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.pedido-detalhes {\r\n  flex-grow: 1;\r\n}\r\n\r\n.pedido-detalhes h3 {\r\n  font-size: 18px;\r\n  color: #2b1b12;\r\n  margin: 0 0 6px 0;\r\n}\r\n\r\n.pedido-opcao {\r\n  font-size: 13px;\r\n  color: #615045;\r\n  margin: 0 0 8px 0;\r\n}\r\n\r\n.pedido-adicionais {\r\n  font-size: 13px;\r\n  color: #615045;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.pedido-adicionais ul {\r\n  list-style: none;\r\n  padding: 0;\r\n  margin: 4px 0 0 0;\r\n  display: flex;\r\n  gap: 10px;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n.pedido-status .badge {\r\n  display: inline-block;\r\n  background-color: #e6dfd5;\r\n  color: #523b2e;\r\n  padding: 4px 10px;\r\n  border-radius: 20px;\r\n  font-size: 11px;\r\n  font-weight: 600;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.pedido-preco-acao {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: flex-end;\r\n  gap: 15px;\r\n  margin-left: 20px;\r\n}\r\n\r\n.preco-item {\r\n  font-size: 18px;\r\n  font-weight: 700;\r\n  color: #2b1b12;\r\n}\r\n\r\n.btn-remover {\r\n  background: none;\r\n  border: none;\r\n  color: #a84343;\r\n  cursor: pointer;\r\n  padding: 5px;\r\n  transition: transform 0.1s;\r\n}\r\n\r\n.btn-remover:hover {\r\n  transform: scale(1.1);\r\n}\r\n\r\n/* Caixa lateral de Resumo */\r\n.resumo-carrinho {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  padding: 24px;\r\n  border-radius: 20px;\r\n}\r\n\r\n.resumo-carrinho h3 {\r\n  margin-top: 0;\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 20px;\r\n  border-bottom: 1px solid rgba(247, 243, 238, 0.1);\r\n  padding-bottom: 12px;\r\n}\r\n\r\n.resumo-linha {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin: 20px 0;\r\n  font-size: 15px;\r\n}\r\n\r\n.resumo-total {\r\n  font-size: 22px;\r\n  font-weight: 700;\r\n}\r\n\r\n.btn-finalizar {\r\n  width: 100%;\r\n  background-color: #f7f3ee;\r\n  color: #2b1b12;\r\n  border: none;\r\n  padding: 14px;\r\n  border-radius: 12px;\r\n  font-weight: 600;\r\n  font-size: 15px;\r\n  cursor: pointer;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.btn-finalizar:hover {\r\n  background-color: #e6dfd5;\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .carrinho-conteudo {\r\n    grid-template-columns: 1fr;\r\n  }\r\n}\r\n</style>"],"mappings":";;;AA0DA,eAAe;EACbA,IAAI,EAAE,aAAa;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,YAAY,EAAE;IAChB,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACR;IACAC,UAAUA,CAAA,EAAG;MACX,OAAO,IAAI,CAACF,YAAY,CAACG,MAAM,CAAC,CAACC,IAAI,EAAEC,IAAI,KAAK;QAC9C,IAAIC,KAAI,GAAIC,MAAM,CAACF,IAAI,CAACG,WAAW,CAAC,CAACC,OAAO,CAAC,GAAG,EAAE,GAAG,CAAC;QACtD,OAAOL,IAAG,IAAKM,UAAU,CAACJ,KAAK,KAAK,CAAC,CAAC;MACxC,CAAC,EAAE,CAAC,CAAC;IACP;EACF,CAAC;EACDK,OAAO,EAAE;IACP,MAAMC,aAAaA,CAAA,EAAG;MACpB,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,+BAA+B,CAAC;QAC7D,IAAI,CAACd,YAAW,GAAI,MAAMa,QAAQ,CAACE,IAAI,CAAC,CAAC;MAC3C,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,8BAA8B,EAAEA,KAAK,CAAC;MACtD;IACF,CAAC;IAED,MAAME,iBAAiBA,CAACC,EAAE,EAAE;MAC1B,IAAI,CAACC,OAAO,CAAC,uDAAuD,CAAC,EAAE;MAEvE,IAAI;QACF,MAAMP,QAAO,GAAI,MAAMC,KAAK,CAAC,iCAAiCK,EAAE,EAAE,EAAE;UAClEE,MAAM,EAAE;QACV,CAAC,CAAC;QAEF,IAAIR,QAAQ,CAACS,EAAE,EAAE;UACf;UACA,IAAI,CAACtB,YAAW,GAAI,IAAI,CAACA,YAAY,CAACuB,MAAM,CAACC,CAAA,IAAKA,CAAC,CAACL,EAAC,KAAMA,EAAE,CAAC;QAChE;MACF,EAAE,OAAOH,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,uBAAuB,EAAEA,KAAK,CAAC;MAC/C;IACF,CAAC;IAEDS,eAAeA,CAAA,EAAG;MAChBC,KAAK,CAAC,uEAAuE,CAAC;MAC9E;IACF;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACf,aAAa,CAAC,CAAC;EACtB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}