{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nexport default {\n  name: \"PedidosView\",\n  data() {\n    return {\n      listaPedidos: [],\n      modalRemover: {\n        visivel: false,\n        idItem: null,\n        nomeItem: \"\"\n      },\n      alerta: {\n        visivel: false,\n        mensagem: \"\",\n        tipo: \"\"\n      }\n    };\n  },\n  computed: {\n    totalGeral() {\n      return this.listaPedidos.reduce((soma, item) => {\n        let preco = String(item.valor_total).replace(',', '.');\n        return soma + (parseFloat(preco) || 0);\n      }, 0);\n    },\n    alertIcon() {\n      switch (this.alerta.tipo) {\n        case 'erro':\n          return '❌';\n        case 'aviso':\n          return '⚠️';\n        case 'info':\n          return 'ℹ️';\n        case 'sucesso':\n          return '✅';\n        default:\n          return '';\n      }\n    }\n  },\n  methods: {\n    mostrarAlerta(mensagem, tipo = \"info\") {\n      this.alerta.mensagem = mensagem;\n      this.alerta.tipo = tipo;\n      this.alerta.visivel = true;\n      setTimeout(() => {\n        this.alerta.visivel = false;\n      }, 3500);\n    },\n    async buscarPedidos() {\n      try {\n        const response = await fetch(\"http://localhost:3000/pedidos\");\n        this.listaPedidos = await response.json();\n      } catch (error) {\n        this.mostrarAlerta(\"Erro de comunicação ao carregar os itens do carrinho.\", \"erro\");\n      }\n    },\n    abrirModalRemover(pedido) {\n      this.modalRemover.idItem = pedido.id;\n      this.modalRemover.nomeItem = pedido.nome_cafe;\n      this.modalRemover.visivel = true;\n    },\n    fecharModal() {\n      this.modalRemover.visivel = false;\n      this.modalRemover.idItem = null;\n      this.modalRemover.nomeItem = \"\";\n    },\n    async confirmarRemocao() {\n      const id = this.modalRemover.idItem;\n      try {\n        const response = await fetch(`http://localhost:3000/pedidos/${id}`, {\n          method: \"DELETE\"\n        });\n        if (response.ok) {\n          this.listaPedidos = this.listaPedidos.filter(p => p.id !== id);\n          this.fecharModal();\n          this.mostrarAlerta(\"Item removido com sucesso do carrinho.\", \"sucesso\");\n        } else {\n          this.mostrarAlerta(\"Não foi possível excluir o item.\", \"erro\");\n        }\n      } catch (error) {\n        this.mostrarAlerta(\"Erro ao tentar excluir. Tente novamente.\", \"erro\");\n      }\n    },\n    finalizarCompra() {\n      this.mostrarAlerta(\"Pedido enviado para a cozinha do Âmbar Café com sucesso!\", \"sucesso\");\n    }\n  },\n  mounted() {\n    this.buscarPedidos();\n  }\n};","map":{"version":3,"names":["name","data","listaPedidos","modalRemover","visivel","idItem","nomeItem","alerta","mensagem","tipo","computed","totalGeral","reduce","soma","item","preco","String","valor_total","replace","parseFloat","alertIcon","methods","mostrarAlerta","setTimeout","buscarPedidos","response","fetch","json","error","abrirModalRemover","pedido","id","nome_cafe","fecharModal","confirmarRemocao","method","ok","filter","p","finalizarCompra","mounted"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\PedidosView.vue"],"sourcesContent":["<template>\r\n  <div class=\"carrinho-container\">\r\n    <h1 class=\"page-title\">Seu Carrinho de Compras</h1>\r\n\r\n    <transition name=\"toast-fade\">\r\n      <div v-if=\"alerta.visivel\" :class=\"['custom-alert', alerta.tipo]\">\r\n        <span class=\"alert-icon\">{{ alertIcon }}</span>\r\n        <span class=\"alert-message\">{{ alerta.mensagem }}</span>\r\n      </div>\r\n    </transition>\r\n\r\n    <transition name=\"modal-fade\">\r\n      <div v-if=\"modalRemover.visivel\" class=\"modal-overlay\">\r\n        <div class=\"modal-card\">\r\n          <div class=\"modal-header\">\r\n            <span class=\"modal-icon\">⚠️</span>\r\n            <h3>Confirmar Ação</h3>\r\n          </div>\r\n          <div class=\"modal-body\">\r\n            <p>Tem certeza que deseja remover <strong>{{ modalRemover.nomeItem }}</strong> do seu carrinho?</p>\r\n          </div>\r\n          <div class=\"modal-footer\">\r\n            <button class=\"btn-modal-cancelar\" @click=\"fecharModal\">Cancelar</button>\r\n            <button class=\"btn-modal-confirmar\" @click=\"confirmarRemocao\">Sim, Remover</button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </transition>\r\n\r\n    <div v-if=\"listaPedidos.length === 0\" class=\"carrinho-vazio\">\r\n      <p>O seu carrinho está vazio no momento.</p>\r\n      <router-link to=\"/menu\" class=\"btn-voltar\">Ver o Cardápio</router-link>\r\n    </div>\r\n\r\n    <div v-else class=\"carrinho-conteudo\">\r\n      <div class=\"lista-itens\">\r\n        <div v-for=\"pedido in listaPedidos\" :key=\"pedido.id\" class=\"pedido-card\">\r\n          <div class=\"pedido-foto\">\r\n            <img :src=\"pedido.foto_cafe\" :alt=\"pedido.nome_cafe\" />\r\n          </div>\r\n          \r\n          <div class=\"pedido-detalhes\">\r\n            <h3>{{ pedido.nome_cafe }}</h3>\r\n            <p class=\"pedido-cliente\"><strong>Cliente:</strong> {{ pedido.nome_cliente || 'Não informado' }}</p>\r\n            <p class=\"pedido-opcao\"><strong>Opção:</strong> {{ pedido.ponto || 'Tamanho Único' }}</p>\r\n            \r\n            <div v-if=\"pedido.opcionais && pedido.opcionais.length > 0\" class=\"pedido-adicionais\">\r\n              <strong>Adicionais:</strong>\r\n              <ul>\r\n                <li v-for=\"opc in pedido.opcionais\" :key=\"opc.id\">\r\n                  • {{ opc.nome }}\r\n                </li>\r\n              </ul>\r\n            </div>\r\n            \r\n            <p class=\"pedido-status\">\r\n              <span class=\"badge\">{{ pedido.status || 'Em preparação' }}</span>\r\n            </p>\r\n          </div>\r\n\r\n          <div class=\"pedido-preco-acao\">\r\n            <span class=\"preco-item\">R$ {{ parseFloat(pedido.valor_total).toFixed(2) }}</span>\r\n            <button class=\"btn-remover\" @click=\"abrirModalRemover(pedido)\" title=\"Remover item\">\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"3 6 5 6 21 6\"></polyline><path d=\"M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2\"></path><line x1=\"10\" y1=\"11\" x2=\"10\" y2=\"17\"></line><line x1=\"14\" y1=\"11\" x2=\"14\" y2=\"17\"></line></svg>\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"resumo-carrinho\">\r\n        <h3>Resumo do Pedido</h3>\r\n        <div class=\"resumo-linha\">\r\n          <span>Total dos Itens:</span>\r\n          <span class=\"resumo-total\">R$ {{ totalGeral.toFixed(2) }}</span>\r\n        </div>\r\n        <button class=\"btn-finalizar\" @click=\"finalizarCompra\">\r\n          Confirmar e Pagar\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"PedidosView\",\r\n  data() {\r\n    return {\r\n      listaPedidos: [],\r\n      modalRemover: {\r\n        visivel: false,\r\n        idItem: null,\r\n        nomeItem: \"\"\r\n      },\r\n      alerta: {\r\n        visivel: false,\r\n        mensagem: \"\",\r\n        tipo: \"\" \r\n      }\r\n    };\r\n  },\r\n  computed: {\r\n    totalGeral() {\r\n      return this.listaPedidos.reduce((soma, item) => {\r\n        let preco = String(item.valor_total).replace(',', '.');\r\n        return soma + (parseFloat(preco) || 0);\r\n      }, 0);\r\n    },\r\n    alertIcon() {\r\n      switch (this.alerta.tipo) {\r\n        case 'erro': return '❌';\r\n        case 'aviso': return '⚠️';\r\n        case 'info': return 'ℹ️';\r\n        case 'sucesso': return '✅';\r\n        default: return '';\r\n      }\r\n    }\r\n  },\r\n  methods: {\r\n    mostrarAlerta(mensagem, tipo = \"info\") {\r\n      this.alerta.mensagem = mensagem;\r\n      this.alerta.tipo = tipo;\r\n      this.alerta.visivel = true;\r\n      setTimeout(() => {\r\n        this.alerta.visivel = false;\r\n      }, 3500);\r\n    },\r\n    async buscarPedidos() {\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\");\r\n        this.listaPedidos = await response.json();\r\n      } catch (error) {\r\n        this.mostrarAlerta(\"Erro de comunicação ao carregar os itens do carrinho.\", \"erro\");\r\n      }\r\n    },\r\n    abrirModalRemover(pedido) {\r\n      this.modalRemover.idItem = pedido.id;\r\n      this.modalRemover.nomeItem = pedido.nome_cafe;\r\n      this.modalRemover.visivel = true;\r\n    },\r\n    fecharModal() {\r\n      this.modalRemover.visivel = false;\r\n      this.modalRemover.idItem = null;\r\n      this.modalRemover.nomeItem = \"\";\r\n    },\r\n    async confirmarRemocao() {\r\n      const id = this.modalRemover.idItem;\r\n      try {\r\n        const response = await fetch(`http://localhost:3000/pedidos/${id}`, {\r\n          method: \"DELETE\"\r\n        });\r\n        \r\n        if (response.ok) {\r\n          this.listaPedidos = this.listaPedidos.filter(p => p.id !== id);\r\n          this.fecharModal();\r\n          this.mostrarAlerta(\"Item removido com sucesso do carrinho.\", \"sucesso\");\r\n        } else {\r\n          this.mostrarAlerta(\"Não foi possível excluir o item.\", \"erro\");\r\n        }\r\n      } catch (error) {\r\n        this.mostrarAlerta(\"Erro ao tentar excluir. Tente novamente.\", \"erro\");\r\n      }\r\n    },\r\n    finalizarCompra() {\r\n      this.mostrarAlerta(\"Pedido enviado para a cozinha do Âmbar Café com sucesso!\", \"sucesso\");\r\n    }\r\n  },\r\n  mounted() {\r\n    this.buscarPedidos();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.custom-alert {\r\n  position: fixed;\r\n  top: 100px;\r\n  right: 20px;\r\n  z-index: 10000;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  padding: 16px 24px;\r\n  border-radius: 12px;\r\n  color: #ffffff;\r\n  font-weight: 600;\r\n  font-size: 14px;\r\n  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\r\n  min-width: 300px;\r\n  max-width: 450px;\r\n}\r\n.custom-alert.erro { background-color: #d93838; }\r\n.custom-alert.aviso { background-color: #e67e22; }\r\n.custom-alert.info { background-color: #2980b9; }\r\n.custom-alert.sucesso { background-color: #27ae60; }\r\n\r\n.toast-fade-enter-active, .toast-fade-leave-active { transition: all 0.3s ease; }\r\n.toast-fade-enter, .toast-fade-leave-to { transform: translateX(50px); opacity: 0; }\r\n\r\n.modal-overlay {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100vw;\r\n  height: 100vh;\r\n  background-color: rgba(43, 27, 18, 0.4);\r\n  backdrop-filter: blur(4px);\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  z-index: 9999;\r\n}\r\n.modal-card {\r\n  background-color: #f7f3ee;\r\n  border-radius: 20px;\r\n  width: 90%;\r\n  max-width: 420px;\r\n  padding: 25px;\r\n  box-shadow: 0 15px 40px rgba(43, 27, 18, 0.15);\r\n  border: 1px solid rgba(230, 126, 34, 0.2);\r\n}\r\n.modal-header { display: flex; align-items: center; gap: 12px; margin-bottom: 15px; }\r\n.modal-icon { font-size: 24px; background-color: #e67e22; color: #ffffff; width: 38px; height: 38px; display: flex; justify-content: center; align-items: center; border-radius: 50%; }\r\n.modal-header h3 { font-family: 'Playfair Display', Georgia, serif; color: #2b1b12; font-size: 20px; margin: 0; }\r\n.modal-body p { color: #615045; font-size: 15px; line-height: 1.5; margin: 0 0 25px 0; }\r\n.modal-footer { display: flex; justify-content: flex-end; gap: 12px; }\r\n.btn-modal-cancelar { background-color: #e6dfd5; color: #523b2e; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: background-color 0.2s; }\r\n.btn-modal-cancelar:hover { background-color: #dcd4c9; }\r\n.btn-modal-confirmar { background-color: #a84343; color: #ffffff; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: opacity 0.2s; }\r\n.btn-modal-confirmar:hover { opacity: 0.9; }\r\n\r\n.modal-fade-enter-active, .modal-fade-leave-active { transition: opacity 0.25s ease; }\r\n.modal-fade-enter, .modal-fade-leave-to { opacity: 0; }\r\n\r\n.carrinho-container { max-width: 1100px; margin: 120px auto 40px auto; padding: 0 20px; font-family: 'Plus Jakarta Sans', sans-serif; text-align: left; }\r\n.page-title { font-family: 'Playfair Display', Georgia, serif; color: #2b1b12; font-size: 32px; margin-bottom: 30px; }\r\n.carrinho-vazio { text-align: center; padding: 60px; background-color: #f7f3ee; border-radius: 20px; color: #615045; }\r\n.btn-voltar { display: inline-block; margin-top: 20px; background-color: #2b1b12; color: #f7f3ee; text-decoration: none; padding: 12px 24px; border-radius: 10px; font-weight: 600; transition: opacity 0.2s; }\r\n.btn-voltar:hover { opacity: 0.9; }\r\n.carrinho-conteudo { display: grid; grid-template-columns: 2fr 1fr; gap: 40px; align-items: start; }\r\n.lista-itens { display: flex; flex-direction: column; gap: 16px; }\r\n.pedido-card { display: flex; align-items: center; background-color: #f7f3ee; padding: 20px; border-radius: 18px; box-shadow: 0 4px 15px rgba(43, 27, 18, 0.02); }\r\n.pedido-foto { width: 100px; height: 100px; border-radius: 12px; overflow: hidden; margin-right: 20px; flex-shrink: 0; }\r\n.pedido-foto img { width: 100%; height: 100%; object-fit: cover; }\r\n.pedido-detalhes { flex-grow: 1; }\r\n.pedido-detalhes h3 { font-size: 18px; color: #2b1b12; margin: 0 0 6px 0; }\r\n.pedido-cliente { font-size: 14px; color: #523b2e; margin: 0 0 4px 0; }\r\n.pedido-opcao { font-size: 13px; color: #615045; margin: 0 0 8px 0; }\r\n.pedido-adicionais { font-size: 13px; color: #615045; margin-bottom: 8px; }\r\n.pedido-adicionais ul { list-style: none; padding: 0; margin: 4px 0 0 0; display: flex; gap: 10px; flex-wrap: wrap; }\r\n.pedido-status .badge { display: inline-block; background-color: #e6dfd5; color: #523b2e; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; text-transform: uppercase; }\r\n.pedido-preco-acao { display: flex; flex-direction: column; align-items: flex-end; gap: 15px; margin-left: 20px; }\r\n.preco-item { font-size: 18px; font-weight: 700; color: #2b1b12; }\r\n.btn-remover { background: none; border: none; color: #a84343; cursor: pointer; padding: 5px; transition: transform 0.1s; }\r\n.btn-remover:hover { transform: scale(1.1); }\r\n.resumo-carrinho { background-color: #2b1b12; color: #f7f3ee; padding: 24px; border-radius: 20px; }\r\n.resumo-carrinho h3 { margin-top: 0; font-family: 'Playfair Display', Georgia, serif; font-size: 20px; border-bottom: 1px solid rgba(247, 243, 238, 0.1); padding-bottom: 12px; }\r\n.resumo-linha { display: flex; justify-content: space-between; align-items: center; margin: 20px 0; font-size: 15px; }\r\n.resumo-total { font-size: 22px; font-weight: 700; }\r\n.btn-finalizar { width: 100%; background-color: #f7f3ee; color: #2b1b12; border: none; padding: 14px; border-radius: 12px; font-weight: 600; font-size: 15px; cursor: pointer; transition: background-color 0.2s; }\r\n.btn-finalizar:hover { background-color: #e6dfd5; }\r\n\r\n@media (max-width: 768px) {\r\n  .carrinho-conteudo { grid-template-columns: 1fr; }\r\n}\r\n</style>"],"mappings":";;;AAoFA,eAAe;EACbA,IAAI,EAAE,aAAa;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,YAAY,EAAE,EAAE;MAChBC,YAAY,EAAE;QACZC,OAAO,EAAE,KAAK;QACdC,MAAM,EAAE,IAAI;QACZC,QAAQ,EAAE;MACZ,CAAC;MACDC,MAAM,EAAE;QACNH,OAAO,EAAE,KAAK;QACdI,QAAQ,EAAE,EAAE;QACZC,IAAI,EAAE;MACR;IACF,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,UAAUA,CAAA,EAAG;MACX,OAAO,IAAI,CAACT,YAAY,CAACU,MAAM,CAAC,CA