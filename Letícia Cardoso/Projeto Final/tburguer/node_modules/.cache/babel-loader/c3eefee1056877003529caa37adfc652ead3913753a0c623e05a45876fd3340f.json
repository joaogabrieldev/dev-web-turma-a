{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuCafeteria: [],\n      categoriaAtiva: 'todos'\n    };\n  },\n  computed: {\n    // Filtra dinamicamente baseado no botão clicado\n    produtosFiltrados() {\n      if (this.categoriaAtiva === 'todos') {\n        return this.listaMenuCafeteria;\n      }\n      return this.listaMenuCafeteria.filter(item => item.categoria === this.categoriaAtiva);\n    }\n  },\n  methods: {\n    async consultarMenu() {\n      try {\n        const response = await fetch(`${this.$apiUrl}/menu`);\n        const dados = await response.json();\n\n        // CORREÇÃO CRUCIAL: Se o JSON Server devolver um objeto, acessamos .menu\n        // Se ele devolver a Array diretamente, usamos os dados brutos.\n        if (dados && dados.menu) {\n          this.listaMenuCafeteria = dados.menu;\n        } else if (Array.isArray(dados)) {\n          this.listaMenuCafeteria = dados;\n        } else {\n          this.listaMenuCafeteria = [];\n        }\n      } catch (error) {\n        console.error(\"Erro ao buscar o menu da cafeteria:\", error);\n      }\n    },\n    selecionarItem(item) {\n      const param = JSON.stringify(item);\n      const itemJson = encodeURIComponent(param);\n      this.$router.push({\n        path: \"/config\",\n        query: {\n          produto: itemJson\n        }\n      });\n    }\n  },\n  mounted() {\n    this.consultarMenu();\n  }\n};","map":{"version":3,"names":["name","data","listaMenuCafeteria","categoriaAtiva","computed","produtosFiltrados","filter","item","categoria","methods","consultarMenu","response","fetch","$apiUrl","dados","json","menu","Array","isArray","error","console","selecionarItem","param","JSON","stringify","itemJson","encodeURIComponent","$router","push","path","query","produto","mounted"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\MenuView.vue"],"sourcesContent":["<template>\r\n  <div class=\"menu-section\">\r\n    <div class=\"section-header\">\r\n      <h2>Nossas Especialidades</h2>\r\n      <p>Escolha o seu café perfeito, preparado por baristas experientes.</p>\r\n    </div>\r\n\r\n    <div class=\"filter-container\">\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'todos' }]\" \r\n        @click=\"categoriaAtiva = 'todos'\"\r\n      >\r\n        Todos\r\n      </button>\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'bebidas' }]\" \r\n        @click=\"categoriaAtiva = 'bebidas'\"\r\n      >\r\n        Bebidas\r\n      </button>\r\n      <button \r\n        :class=\"['filter-btn', { active: categoriaAtiva === 'lanches' }]\" \r\n        @click=\"categoriaAtiva = 'lanches'\"\r\n      >\r\n        Lanches\r\n      </button>\r\n    </div>\r\n\r\n    <div id=\"scroll-horizontal\">\r\n      <div \r\n        id=\"card-content\" \r\n        v-for=\"item in produtosFiltrados\" \r\n        :key=\"item.id\"\r\n      >\r\n        <div id=\"card-linha\">\r\n          <div class=\"foto-produto\">\r\n            <img :src=\"item.foto\" :alt=\"item.nome\" />\r\n          </div>\r\n          <div class=\"card-coluna\">\r\n            <p id=\"nome-content\">{{ item.nome }}</p>\r\n            <p id=\"preco-content\">R$ {{ item.valor }}</p>\r\n            <p id=\"descricao-content\">{{ item.descricao }}</p>\r\n            <button @click=\"selecionarItem(item)\">Selecionar</button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"MenuView\",\r\n  data() {\r\n    return {\r\n      listaMenuCafeteria: [],\r\n      categoriaAtiva: 'todos'\r\n    };\r\n  },\r\n  computed: {\r\n    // Filtra dinamicamente baseado no botão clicado\r\n    produtosFiltrados() {\r\n      if (this.categoriaAtiva === 'todos') {\r\n        return this.listaMenuCafeteria;\r\n      }\r\n      return this.listaMenuCafeteria.filter(item => item.categoria === this.categoriaAtiva);\r\n    }\r\n  },\r\n  methods: {\r\n    async consultarMenu() {\r\n      try {\r\n        const response = await fetch(`${this.$apiUrl}/menu`);\r\n        const dados = await response.json();\r\n        \r\n        // CORREÇÃO CRUCIAL: Se o JSON Server devolver um objeto, acessamos .menu\r\n        // Se ele devolver a Array diretamente, usamos os dados brutos.\r\n        if (dados && dados.menu) {\r\n          this.listaMenuCafeteria = dados.menu;\r\n        } else if (Array.isArray(dados)) {\r\n          this.listaMenuCafeteria = dados;\r\n        } else {\r\n          this.listaMenuCafeteria = [];\r\n        }\r\n      } catch (error) {\r\n        console.error(\"Erro ao buscar o menu da cafeteria:\", error);\r\n      }\r\n    },\r\n    selecionarItem(item) {\r\n      const param = JSON.stringify(item);\r\n      const itemJson = encodeURIComponent(param);\r\n      this.$router.push({ path: \"/config\", query: { produto: itemJson } });\r\n    }\r\n  },\r\n  mounted() {\r\n    this.consultarMenu();\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* ESTILOS DOS BOTÕES DE FILTRO */\r\n.menu-section {\r\n  padding: 20px 40px;\r\n  max-width: 1300px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.section-header {\r\n  margin-bottom: 20px;\r\n  text-align: left;\r\n}\r\n\r\n.section-header h2 {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  font-size: 32px;\r\n  color: #2b1b12;\r\n  margin-bottom: 5px;\r\n}\r\n\r\n.section-header p {\r\n  color: #615045;\r\n  font-size: 15px;\r\n}\r\n\r\n.filter-container {\r\n  display: flex;\r\n  gap: 12px;\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.filter-btn {\r\n  background-color: transparent;\r\n  color: #615045;\r\n  border: 1px solid rgba(43, 27, 18, 0.2);\r\n  padding: 8px 20px;\r\n  border-radius: 50px;\r\n  font-weight: 500;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n.filter-btn:hover {\r\n  background-color: rgba(43, 27, 18, 0.05);\r\n  color: #2b1b12;\r\n}\r\n\r\n.filter-btn.active {\r\n  background-color: #2b1b12;\r\n  color: #f7f3ee;\r\n  border-color: #2b1b12;\r\n  font-weight: 600;\r\n  box-shadow: 0 4px 12px rgba(43, 27, 18, 0.15);\r\n}\r\n\r\n/* SEUS ESTILOS ORIGINAIS DO SCROLL HORIZONTAL (Mantidos e higienizados) */\r\n#scroll-horizontal {\r\n  display: flex;\r\n  overflow-x: auto;\r\n  gap: 20px;\r\n  padding-bottom: 15px;\r\n}\r\n\r\n#card-content {\r\n  background-color: #f7f3ee;\r\n  border-radius: 15px;\r\n  padding: 15px;\r\n  min-width: 320px;\r\n  box-shadow: 0 4px 10px rgba(0,0,0,0.05);\r\n}\r\n\r\n#card-linha {\r\n  display: flex;\r\n  gap: 15px;\r\n  align-items: center;\r\n}\r\n\r\n.foto-produto {\r\n  width: 90px;\r\n  height: 90px;\r\n  border-radius: 10px;\r\n  overflow: hidden;\r\n}\r\n\r\n.foto-produto img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.card-coluna {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: flex-start;\r\n  text-align: left;\r\n  flex: 1;\r\n}\r\n\r\n#nome-content {\r\n  font-weight: bold;\r\n  font-size: 16px;\r\n  color: #2b1b12;\r\n  margin: 0 0 4px 0;\r\n}\r\n\r\n#preco-content {\r\n  color: #523b2e;\r\n  font-weight: 600;\r\n  margin: 0 0 4px 0;\r\n}\r\n\r\n#descricao-content {\r\n  font-size: 12px;\r\n  color: #777;\r\n  margin: 0 0 10px 0;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n  overflow: hidden;\r\n}\r\n\r\n.card-coluna button {\r\n  background-color: #2b1b12;\r\n  color: white;\r\n  border: none;\r\n  padding: 6px 14px;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n  font-size: 13px;\r\n}\r\n\r\n.card-coluna button:hover {\r\n  background-color: #4a3427;\r\n}\r\n</style>"],"mappings":";;;AAmDA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,kBAAkB,EAAE,EAAE;MACtBC,cAAc,EAAE;IAClB,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACR;IACAC,iBAAiBA,CAAA,EAAG;MAClB,IAAI,IAAI,CAACF,cAAa,KAAM,OAAO,EAAE;QACnC,OAAO,IAAI,CAACD,kBAAkB;MAChC;MACA,OAAO,IAAI,CAACA,kBAAkB,CAACI,MAAM,CAACC,IAAG,IAAKA,IAAI,CAACC,SAAQ,KAAM,IAAI,CAACL,cAAc,CAAC;IACvF;EACF,CAAC;EACDM,OAAO,EAAE;IACP,MAAMC,aAAaA,CAAA,EAAG;MACpB,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,GAAG,IAAI,CAACC,OAAO,OAAO,CAAC;QACpD,MAAMC,KAAI,GAAI,MAAMH,QAAQ,CAACI,IAAI,CAAC,CAAC;;QAEnC;QACA;QACA,IAAID,KAAI,IAAKA,KAAK,CAACE,IAAI,EAAE;UACvB,IAAI,CAACd,kBAAiB,GAAIY,KAAK,CAACE,IAAI;QACtC,OAAO,IAAIC,KAAK,CAACC,OAAO,CAACJ,KAAK,CAAC,EAAE;UAC/B,IAAI,CAACZ,kBAAiB,GAAIY,KAAK;QACjC,OAAO;UACL,IAAI,CAACZ,kBAAiB,GAAI,EAAE;QAC9B;MACF,EAAE,OAAOiB,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,qCAAqC,EAAEA,KAAK,CAAC;MAC7D;IACF,CAAC;IACDE,cAAcA,CAACd,IAAI,EAAE;MACnB,MAAMe,KAAI,GAAIC,IAAI,CAACC,SAAS,CAACjB,IAAI,CAAC;MAClC,MAAMkB,QAAO,GAAIC,kBAAkB,CAACJ,KAAK,CAAC;MAC1C,IAAI,CAACK,OAAO,CAACC,IAAI,CAAC;QAAEC,IAAI,EAAE,SAAS;QAAEC,KAAK,EAAE;UAAEC,OAAO,EAAEN;QAAS;MAAE,CAAC,CAAC;IACtE;EACF,CAAC;EACDO,OAAOA,CAAA,EAAG;IACR,IAAI,CAACtB,aAAa,CAAC,CAAC;EACtB;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}