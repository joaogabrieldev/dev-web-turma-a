che[6] || (_cache[6] = $event => $data.leiteSelecionado = $event),\n      onChange: _cache[7] || (_cache[7] = $event => $data.erros.leite = false)\n    }, null, 40 /* PROPS, NEED_HYDRATION */, _hoisted_19), [[_vModelRadio, $data.leiteSelecionado]]), _createElementVNode(\"span\", _hoisted_20, [_createElementVNode(\"strong\", null, _toDisplayString(op.label), 1 /* TEXT */), op.extra ? (_openBlock(), _createElementBlock(\"small\", _hoisted_21, _toDisplayString(op.extra), 1 /* TEXT */)) : _createCommentVNode(\"v-if\", true)])], 2 /* CLASS */);\n  }), 128 /* KEYED_FRAGMENT */))]), $data.erros.leite ? (_openBlock(), _createElementBlock(\"span\", _hoisted_22, \"Selecione o tipo de leite para continuar.\")) : _createCommentVNode(\"v-if\", true)], 2 /* CLASS */), _createCommentVNode(\" Grupo: Extras (opcionais) \"), _createElementVNode(\"div\", _hoisted_23, [_cache[14] || (_cache[14] = _createElementVNode(\"h3\", {\n    class: \"group-title\"\n  }, [_createTextVNode(\"Acompanhamentos \"), _createElementVNode(\"span\", {\n    class: \"optional-tag\"\n  }, \"Opcional\")], -1 /* CACHED */)), _createElementVNode(\"div\", _hoisted_24, [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($data.extrasDisponiveis, extra => {\n    return _openBlock(), _createElementBlock(\"label\", {\n      key: extra.id,\n      class: _normalizeClass(['checkbox-card', {\n        selected: $data.extrasAtivos.includes(extra.id)\n      }])\n    }, [_withDirectives(_createElementVNode(\"input\", {\n      type: \"checkbox\",\n      value: extra.id,\n      \"onUpdate:modelValue\": _cache[8] || (_cache[8] = $event => $data.extrasAtivos = $event)\n    }, null, 8 /* PROPS */, _hoisted_25), [[_vModelCheckbox, $data.extrasAtivos]]), _createElementVNode(\"span\", _hoisted_26, [_createTextVNode(_toDisplayString(extra.nome) + \" \", 1 /* TEXT */), extra.preco ? (_openBlock(), _createElementBlock(\"small\", _hoisted_27, \"+ R$ \" + _toDisplayString(extra.preco), 1 /* TEXT */)) : _createCommentVNode(\"v-if\", true)])], 2 /* CLASS */);\n  }), 128 /* KEYED_FRAGMENT */))])]), _createCommentVNode(\" Botão de confirmação \"), _createElementVNode(\"button\", {\n    class: \"btn-submit\",\n    disabled: $data.enviando,\n    onClick: _cache[9] || (_cache[9] = (...args) => $options.confirmarPedido && $options.confirmarPedido(...args))\n  }, [$data.enviando ? (_openBlock(), _createElementBlock(\"span\", _hoisted_29)) : _createCommentVNode(\"v-if\", true), _createTextVNode(\" \" + _toDisplayString($data.enviando ? 'Enviando...' : 'Confirmar Pedido'), 1 /* TEXT */)], 8 /* PROPS */, _hoisted_28)])])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createCommentVNode","_createVNode","_component_AlertaComponent","mensagem","$data","alerta","tipo","onFechar","_cache","$event","_createElementVNode","_hoisted_2","_hoisted_3","_hoisted_4","src","produto","foto","imagemFallback","alt","nome","onError","e","target","_hoisted_6","_hoisted_7","_toDisplayString","categoria","_hoisted_8","_hoisted_9","descricao","_hoisted_10","_hoisted_11","valor","_hoisted_12","_normalizeClass","erros","nomeCliente","for","id","type","placeholder","onInput","trim","_hoisted_13","tamanho","_hoisted_14","_Fragment","_renderList","opcoesTamanho","op","key","value","selected","tamanhoSelecionado","name","onChange","_hoisted_16","label","desc","_hoisted_17","leite","_hoisted_18","opcoesLeite","leiteSelecionado","_hoisted_20","extra","_hoisted_21","_hoisted_22","_hoisted_23","_hoisted_24","extrasDisponiveis","extrasAtivos","includes","_hoisted_26","preco","_hoisted_27","disabled","enviando","onClick","args","$options","confirmarPedido","_hoisted_29"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\ConfiguracaoPedidoView.vue"],"sourcesContent":["<template>\r\n  <div class=\"config-page\">\r\n    <!-- Alerta de feedback (erro, aviso, sucesso, info) -->\r\n    <AlertaComponent\r\n      :mensagem=\"alerta.mensagem\"\r\n      :tipo=\"alerta.tipo\"\r\n      @fechar=\"alerta.mensagem = ''\"\r\n    />\r\n\r\n    <div class=\"config-container\">\r\n      <!-- === COLUNA ESQUERDA: Resumo do produto selecionado === -->\r\n      <aside class=\"product-summary\">\r\n        <div class=\"product-image-container\">\r\n          <img :src=\"produto.foto || imagemFallback\" :alt=\"produto.nome\" @error=\"(e) => e.target.src = imagemFallback\" />\r\n        </div>\r\n        <div class=\"product-details\">\r\n          <span class=\"category-pill\">{{ produto.categoria || 'Especialidade' }}</span>\r\n          <h2 class=\"product-title\">{{ produto.nome || 'Café Especial' }}</h2>\r\n          <p class=\"product-description-text\">{{ produto.descricao || 'Prepare uma experiência única.' }}</p>\r\n          <div class=\"price-row\">\r\n            <span class=\"price-label\">Valor base</span>\r\n            <span class=\"price-value\">R$ {{ produto.valor || '—' }}</span>\r\n          </div>\r\n        </div>\r\n      </aside>\r\n\r\n      <!-- === COLUNA DIREITA: Formulário de customização === -->\r\n      <section class=\"customization-panel\">\r\n        <div class=\"panel-header\">\r\n          <h1 class=\"panel-title\">Personalize sua Bebida</h1>\r\n          <p class=\"panel-subtitle\">Escolha os detalhes perfeitos para a sua experiência Âmbar.</p>\r\n        </div>\r\n\r\n        <!-- Campo: Nome do cliente (obrigatório) -->\r\n        <div class=\"form-group\" :class=\"{ 'has-error': erros.nomeCliente }\">\r\n          <label class=\"form-label\" for=\"nome-cliente\">\r\n            Nome do Cliente <span class=\"required\">*</span>\r\n          </label>\r\n          <input\r\n            id=\"nome-cliente\"\r\n            type=\"text\"\r\n            v-model.trim=\"nomeCliente\"\r\n            class=\"form-input\"\r\n            placeholder=\"Como devemos chamar você?\"\r\n            @input=\"erros.nomeCliente = false\"\r\n          />\r\n          <span v-if=\"erros.nomeCliente\" class=\"field-error\">Informe seu nome para continuar.</span>\r\n        </div>\r\n\r\n        <!-- Grupo: Tamanho da Bebida (obrigatório) -->\r\n        <div class=\"options-group\" :class=\"{ 'has-error': erros.tamanho }\">\r\n          <h3 class=\"group-title\">\r\n            Tamanho da Bebida <span class=\"required\">*</span>\r\n          </h3>\r\n          <div class=\"radio-grid\">\r\n            <label\r\n              v-for=\"op in opcoesTamanho\"\r\n              :key=\"op.value\"\r\n              :class=\"['radio-card', { selected: tamanhoSelecionado === op.value }]\"\r\n            >\r\n              <input\r\n                type=\"radio\"\r\n                name=\"tamanho\"\r\n                :value=\"op.value\"\r\n                v-model=\"tamanhoSelecionado\"\r\n                @change=\"erros.tamanho = false\"\r\n              />\r\n              <span class=\"radio-label-text\">\r\n                <strong>{{ op.label }}</strong>\r\n                <small>{{ op.desc }}</small>\r\n              </span>\r\n            </label>\r\n          </div>\r\n          <span v-if=\"erros.tamanho\" class=\"field-error\">Selecione um tamanho para continuar.</span>\r\n        </div>\r\n\r\n        <!-- Grupo: Tipo de Leite (obrigatório) -->\r\n        <div class=\"options-group\" :class=\"{ 'has-error': erros.leite }\">\r\n          <h3 class=\"group-title\">\r\n            Tipo de Leite <span class=\"required\">*</span>\r\n          </h3>\r\n          <div class=\"radio-grid\">\r\n            <label\r\n              v-for=\"op in opcoesLeite\"\r\n              :key=\"op.value\"\r\n              :class=\"['radio-card', { selected: leiteSelecionado === op.value }]\"\r\n            >\r\n              <input\r\n                type=\"radio\"\r\n                name=\"leite\"\r\n                :value=\"op.value\"\r\n                v-model=\"leiteSelecionado\"\r\n                @change=\"erros.leite = false\"\r\n              />\r\n              <span class=\"radio-label-text\">\r\n                <strong>{{ op.label }}</strong>\r\n                <small v-if=\"op.extra\" class=\"extra-cost\">{{ op.extra }}</small>\r\n              </span>\r\n            </label>\r\n          </div>\r\n          <span v-if=\"erros.leite\" class=\"field-error\">Selecione o tipo de leite para continuar.</span>\r\n        </div>\r\n\r\n        <!-- Grupo: Extras (opcionais) -->\r\n        <div class=\"options-group\">\r\n          <h3 class=\"group-title\">Acompanhamentos <span class=\"optional-tag\">Opcional</span></h3>\r\n          <div class=\"checkbox-grid\">\r\n            <label\r\n              v-for=\"extra in extrasDisponiveis\"\r\n              :key=\"extra.id\"\r\n              :class=\"['checkbox-card', { selected: extrasAtivos.includes(extra.id) }]\"\r\n            >\r\n              <input\r\n                type=\"checkbox\"\r\n                :value=\"extra.id\"\r\n                v-model=\"extrasAtivos\"\r\n              />\r\n              <span class=\"checkbox-label-text\">\r\n                {{ extra.nome }}\r\n                <small v-if=\"extra.preco\" class=\"extra-cost\">+ R$ {{ extra.preco }}</small>\r\n              </span>\r\n            </label>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Botão de confirmação -->\r\n        <button\r\n          class=\"btn-submit\"\r\n          :disabled=\"enviando\"\r\n          @click=\"confirmarPedido\"\r\n        >\r\n          <span v-if=\"enviando\" class=\"spinner-btn\"></span>\r\n          {{ enviando ? 'Enviando...' : 'Confirmar Pedido' }}\r\n        </button>\r\n      </section>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AlertaComponent from \"@/components/AlertaComponent.vue\";\r\n\r\nexport default {\r\n  name: \"ConfiguracaoPedidoView\",\r\n  components: { AlertaComponent },\r\n\r\n  data() {\r\n    return {\r\n      // Produto recebido via query param (passa de MenuView ou HomeView)\r\n      produto: {},\r\n\r\n      // Campos do formulário\r\n      nomeCliente: \"\",\r\n      tamanhoSelecionado: \"\",\r\n      leiteSelecionado: \"\",\r\n      extrasAtivos: [],\r\n\r\n      // Estado de envio e erros\r\n      enviando: false,\r\n      erros: {\r\n        nomeCliente: false,\r\n        tamanho: false,\r\n        leite: false\r\n      },\r\n\r\n      // Alerta de feedback\r\n      alerta: { mensagem: \"\", tipo: \"info\" },\r\n\r\n      // Imagem de fallback sem dependência local\r\n      imagemFallback:\r\n        \"https://images.unsplash.com/photo-1509042239860-f550ce710b93?q=80&w=600&auto=format&fit=crop\",\r\n\r\n      // Opções de customização\r\n      opcoesTamanho: [\r\n        { value: \"p\", label: \"Pequeno\", desc: \"200ml\" },\r\n        { value: \"m\", label: \"Médio\",   desc: \"350ml\" },\r\n        { value: \"g\", label: \"Grande\",  desc: \"500ml\" }\r\n      ],\r\n      opcoesLeite: [\r\n        { value: \"integral\",  label: \"Integral\",      extra: null },\r\n        { value: \"desnatado\", label: \"Desnatado\",     extra: null },\r\n        { value: \"aveia\",     label: \"Aveia\",         extra: \"+ R$ 4,00\" },\r\n        { value: \"amêndoas\",  label: \"Amêndoas\",      extra: \"+ R$ 5,00\" }\r\n      ],\r\n      extrasDisponiveis: [\r\n        { id: 1, nome: \"Chantilly extra\",   preco: \"2,00\" },\r\n        { id: 2, nome: \"Calda de caramelo\", preco: \"2,00\" },\r\n        { id: 3, nome: \"Shot duplo de café\", preco: \"3,00\" },\r\n        { id: 4, nome: \"Cinnamon Roll\",     preco: \"9,90\" }\r\n      ]\r\n    };\r\n  },\r\n\r\n  methods: {\r\n    mostrarAlerta(mensagem, tipo = \"info\") {\r\n      this.alerta = { mensagem, tipo };\r\n    },\r\n\r\n    /** Valida os campos obrigatórios e retorna true se tudo ok */\r\n    validar() {\r\n      let valido = true;\r\n      this.erros = { nomeCliente: false, tamanho: false, leite: false };\r\n\r\n      if (!this.nomeCliente) {\r\n        this.erros.nomeCliente = true;\r\n        valido = false;\r\n      }\r\n      if (!this.tamanhoSelecionado) {\r\n        this.erros.tamanho = true;\r\n        valido = false;\r\n      }\r\n      if (!this.leiteSelecionado) {\r\n        this.erros.leite = true;\r\n        valido = false;\r\n      }\r\n\r\n      if (!valido) {\r\n        this.mostrarAlerta(\r\n          \"Preencha todos os campos obrigatórios antes de confirmar o pedido.\",\r\n          \"erro\"\r\n        );\r\n      }\r\n      return valido;\r\n    },\r\n\r\n    async confirmarPedido() {\r\n      if (!this.validar()) return;\r\n\r\n      this.enviando = true;\r\n\r\n      // Monta o tamanho e leite legíveis\r\n      const tamanhoTexto = this.opcoesTamanho.find(o => o.value === this.tamanhoSelecionado);\r\n      const leiteTexto   = this.opcoesLeite.find(o => o.value === this.leiteSelecionado);\r\n      const extrasSelecionados = this.extrasDisponiveis.filter(e => this.extrasAtivos.includes(e.id));\r\n\r\n      const dadosPedido = {\r\n        nome_cliente:  this.nomeCliente,\r\n        nome_cafe:     this.produto.nome     || \"Café Especial\",\r\n        foto_cafe:     this.produto.foto     || this.imagemFallback,\r\n        categoria:     this.produto.categoria || \"bebidas\",\r\n        tamanho:       tamanhoTexto ? `${tamanhoTexto.label} (${tamanhoTexto.desc})` : this.tamanhoSelecionado,\r\n        tipo_leite:    leiteTexto   ? leiteTexto.label : this.leiteSelecionado,\r\n        opcionais:     extrasSelecionados,\r\n        valor_total:   this.produto.valor    || \"0,00\",\r\n        status:        \"Em preparação\",\r\n        ponto:         tamanhoTexto ? tamanhoTexto.label : this.tamanhoSelecionado,\r\n        data_pedido:   new Date().toISOString()\r\n      };\r\n\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify(dadosPedido)\r\n        });\r\n\r\n        if (response.ok) {\r\n          // Feedback verde de sucesso\r