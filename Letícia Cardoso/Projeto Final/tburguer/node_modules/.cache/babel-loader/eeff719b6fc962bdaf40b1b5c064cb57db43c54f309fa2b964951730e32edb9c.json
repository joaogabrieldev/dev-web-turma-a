{"ast":null,"code":"export default {\n  name: \"BannerComponent\"\n};","map":{"version":3,"names":["name"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\components\\BannerComponent.vue"],"sourcesContent":["<template>\r\n  <div class=\"banner-wrapper\">\r\n    <div class=\"hero-cover\">\r\n      <div class=\"hero-content-overlay\">\r\n        <div class=\"hero-badge\">ARTESANAL & FRESCO</div>\r\n        <h1 class=\"hero-title\">Brewed Fresh,<br />Served Warm</h1>\r\n        <p class=\"hero-subtitle\">\r\n          Sinta o aroma marcante dos grãos selecionados e a\r\n          cremosidade perfeita em cada xícara.\r\n        </p>\r\n\r\n        <router-link to=\"/MenuView\" class=\"btn-hero-menu\">\r\n          Conheça o Menu\r\n        </router-link>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"BannerComponent\"\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.banner-wrapper {\r\n  width: 100%;\r\n  max-width: 1140px;\r\n  margin: 0 auto;\r\n  padding: 0 20px;\r\n}\r\n\r\n.hero-cover {\r\n  width: 100%;\r\n  min-height: 400px;\r\n  /* Usando uma imagem online para evitar erros locais de imagem faltando */\r\n  background-image: linear-gradient(rgba(43, 27, 18, 0.6), rgba(43, 27, 18, 0.7)), \r\n                    url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=1200&auto=format&fit=crop');\r\n  background-size: cover;\r\n  background-position: center;\r\n  border-radius: 32px;\r\n  display: flex;\r\n  align-items: center;\r\n  padding: 60px;\r\n  box-shadow: 0 20px 40px rgba(43, 27, 18, 0.15);\r\n}\r\n\r\n.hero-content-overlay {\r\n  text-align: left;\r\n  max-width: 550px;\r\n}\r\n\r\n.hero-badge {\r\n  background-color: rgba(255, 255, 255, 0.15);\r\n  color: #f5efe6;\r\n  display: inline-block;\r\n  padding: 6px 16px;\r\n  border-radius: 20px;\r\n  font-size: 11px;\r\n  font-weight: 700;\r\n  letter-spacing: 2px;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.hero-title {\r\n  font-family: 'Playfair Display', Georgia, serif;\r\n  color: #ffffff;\r\n  font-size: 48px;\r\n  line-height: 1.2;\r\n  margin: 0 0 16px 0;\r\n  font-weight: 700;\r\n}\r\n\r\n.hero-subtitle {\r\n  color: #e3dcd5;\r\n  font-size: 16px;\r\n  line-height: 1.6;\r\n  margin: 0 0 32px 0;\r\n}\r\n\r\n.btn-hero-menu {\r\n  background-color: #ffffff;\r\n  color: #2b1b12;\r\n  padding: 14px 32px;\r\n  border-radius: 30px;\r\n  font-weight: 700;\r\n  text-decoration: none;\r\n  font-size: 15px;\r\n  display: inline-block;\r\n  transition: all 0.2s ease;\r\n  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.btn-hero-menu:hover {\r\n  background-color: #f5efe6;\r\n  transform: translateY(-2px);\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .hero-cover {\r\n    padding: 30px;\r\n    text-align: center;\r\n  }\r\n  .hero-content-overlay {\r\n    text-align: center;\r\n    margin: 0 auto;\r\n  }\r\n  .hero-title {\r\n    font-size: 32px;\r\n  }\r\n}\r\n</style>"],"mappings":"AAoBA,eAAe;EACbA,IAAI,EAAE;AACR,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}