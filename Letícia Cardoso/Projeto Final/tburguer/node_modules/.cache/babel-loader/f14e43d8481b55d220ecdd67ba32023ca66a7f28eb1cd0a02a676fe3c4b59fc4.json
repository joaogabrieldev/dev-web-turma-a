"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $data.opcionaisSelecionados = $event)\n    }, null, 8 /* PROPS */, _hoisted_20), [[_vModelCheckbox, $data.opcionaisSelecionados]]), _createElementVNode(\"span\", _hoisted_21, _toDisplayString(opcional.nome), 1 /* TEXT */)]), _createElementVNode(\"span\", _hoisted_22, _toDisplayString(opcional.valor ? '+ R$ ' + $options.formatarPreco(opcional.valor) : 'Grátis'), 1 /* TEXT */)], 2 /* CLASS */);\n  }), 128 /* KEYED_FRAGMENT */))])]), _createElementVNode(\"div\", _hoisted_23, [_createElementVNode(\"div\", _hoisted_24, [_cache[7] || (_cache[7] = _createElementVNode(\"span\", null, \"Total do Item:\", -1 /* CACHED */)), _createElementVNode(\"span\", _hoisted_25, \"R$ \" + _toDisplayString($options.valorTotal.toFixed(2)), 1 /* TEXT */)]), _createElementVNode(\"button\", {\n    class: _normalizeClass(['btn-submit', {\n      'btn-disabled': !$options.formValido && $data.exibindoErros\n    }]),\n    onClick: _cache[3] || (_cache[3] = (...args) => $options.enviarParaCarrinho && $options.enviarParaCarrinho(...args))\n  }, \" Adicionar ao Carrinho → \", 2 /* CLASS */)])])])) : _createCommentVNode(\"v-if\", true);\n}","map":{"version":3,"names":["class","$data","produto","_createElementBlock","_hoisted_1","_createVNode","_Transition","name","alerta","visivel","_normalizeClass","tipo","_createElementVNode","_hoisted_2","_toDisplayString","$options","alertIcon","_hoisted_3","mensagem","_hoisted_4","_hoisted_5","src","foto","alt","nome","_hoisted_7","_hoisted_8","formatarPreco","valor","_hoisted_9","descricao","_hoisted_10","_hoisted_11","type","nomeCliente","$event","placeholder","exibindoErros","trim","_hoisted_12","listaPontos","length","_hoisted_13","_hoisted_14","_Fragment","_renderList","ponto","key","id","selected","pontoSelecionado","value","_hoisted_16","_hoisted_17","_hoisted_18","listaOpcionais","opcional","checked","opcionaisSelecionados","includes","_hoisted_19","_hoisted_21","_hoisted_22","_hoisted_23","_hoisted_24","_hoisted_25","valorTotal","toFixed","formValido","onClick","_cache","args","enviarParaCarrinho"],"sources":["C:\\Users\\ASUS\\dev-web-turma-a\\Letícia Cardoso\\Projeto Final\\tburguer\\src\\views\\ConfiguracaoPedidoView.vue"],"sourcesContent":["<template>\r\n  <div class=\"config-container\" v-if=\"produto\">\r\n    \r\n    <transition name=\"toast-fade\">\r\n      <div v-if=\"alerta.visivel\" :class=\"['custom-alert', alerta.tipo]\">\r\n        <span class=\"alert-icon\">{{ alertIcon }}</span>\r\n        <span class=\"alert-message\">{{ alerta.mensagem }}</span>\r\n      </div>\r\n    </transition>\r\n\r\n    <div class=\"product-preview\">\r\n      <div class=\"image-box\">\r\n        <img :src=\"produto.foto\" :alt=\"produto.nome\" />\r\n      </div>\r\n      <div class=\"product-info\">\r\n        <h2>{{ produto.nome }}</h2>\r\n        <p class=\"base-price\">Preço base: R$ {{ formatarPreco(produto.valor) }}</p>\r\n        <p class=\"description\">\r\n          {{ produto.descricao || 'Item preparado com ingredientes selecionados de forma artesanal.' }}\r\n        </p>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"customization-form\">\r\n      \r\n      <div class=\"options-group\">\r\n        <h3>Identificação do Cliente <span class=\"required\">*</span></h3>\r\n        <input \r\n          type=\"text\" \r\n          v-model=\"nomeCliente\" \r\n          placeholder=\"Digite o nome para o copo/pedido\"\r\n          :class=\"['input-cliente', { 'input-error': exibindoErros && !nomeCliente.trim() }]\"\r\n        />\r\n        <span v-if=\"exibindoErros && !nomeCliente.trim()\" class=\"error-text\">\r\n          O nome do cliente é obrigatório para identificação.\r\n        </span>\r\n      </div>\r\n\r\n      <div class=\"options-group\" v-if=\"listaPontos.length > 0\">\r\n        <h3>Escolha o Tamanho / Ponto <span class=\"required\">*</span></h3>\r\n        <div class=\"radio-grid\">\r\n          <label \r\n            v-for=\"ponto in listaPontos\" \r\n            :key=\"ponto.id\" \r\n            :class=\"['radio-card', { selected: pontoSelecionado === ponto.id }]\"\r\n          >\r\n            <input \r\n              type=\"radio\" \r\n              name=\"ponto\" \r\n              :value=\"ponto.id\" \r\n              v-model=\"pontoSelecionado\"\r\n            />\r\n            <span class=\"radio-label\">{{ ponto.descricao }}</span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"options-group\">\r\n        <h3>Adicionais (Opcional)</h3>\r\n        <div class=\"checkbox-list\">\r\n          <label \r\n            v-for=\"opcional in listaOpcionais\" \r\n            :key=\"opcional.id\" \r\n            :class=\"['checkbox-item', { checked: opcionaisSelecionados.includes(opcional.id) }]\"\r\n          >\r\n            <div class=\"checkbox-wrapper\">\r\n              <input \r\n                type=\"checkbox\" \r\n                :value=\"opcional.id\" \r\n                v-model=\"opcionaisSelecionados\"\r\n              />\r\n              <span class=\"opcional-name\">{{ opcional.nome }}</span>\r\n            </div>\r\n            <span class=\"opcional-price\">{{ opcional.valor ? '+ R$ ' + formatarPreco(opcional.valor) : 'Grátis' }}</span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"summary-section\">\r\n        <div class=\"price-row\">\r\n          <span>Total do Item:</span>\r\n          <span class=\"total-price\">R$ {{ valorTotal.toFixed(2) }}</span>\r\n        </div>\r\n        <button \r\n          :class=\"['btn-submit', { 'btn-disabled': !formValido && exibindoErros }]\" \r\n          @click=\"enviarParaCarrinho\"\r\n        >\r\n          Adicionar ao Carrinho →\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"ConfiguracaoPedidoView\",\r\n  data() {\r\n    return {\r\n      produto: null,\r\n      nomeCliente: \"\",\r\n      listaPontos: [],\r\n      listaOpcionais: [],\r\n      pontoSelecionado: null,\r\n      opcionaisSelecionados: [],\r\n      exibindoErros: false,\r\n      \r\n      // Estado do componente de alerta\r\n      alerta: {\r\n        visivel: false,\r\n        mensagem: \"\",\r\n        tipo: \"\" // erro, aviso, info, sucesso\r\n      }\r\n    };\r\n  },\r\n  computed: {\r\n    // Validação reativa dos campos essenciais\r\n    formValido() {\r\n      const nomePreenchido = this.nomeCliente.trim().length > 0;\r\n      const precisaPonto = this.produto && this.produto.categoria !== \"lanches\" && this.listaPontos.length > 0;\r\n      const pontoPreenchido = precisaPonto ? !!this.pontoSelecionado : true;\r\n      \r\n      return nomePreenchido && pontoPreenchido;\r\n    },\r\n    \r\n    // Ícone dinâmico baseado na paleta semântica\r\n    alertIcon() {\r\n      switch (this.alerta.tipo) {\r\n        case 'erro': return '❌';\r\n        case 'aviso': return '⚠️';\r\n        case 'info': return 'ℹ️';\r\n        case 'sucesso': return '✅';\r\n        default: return '';\r\n      }\r\n    },\r\n\r\n    valorTotal() {\r\n      let total = 0;\r\n      if (this.produto && this.produto.valor) {\r\n        let valorBase = String(this.produto.valor).replace(',', '.');\r\n        total += parseFloat(valorBase) || 0;\r\n      }\r\n      if (Array.isArray(this.opcionaisSelecionados)) {\r\n        this.opcionaisSelecionados.forEach(id => {\r\n          const item = this.listaOpcionais.find(o => o.id === id);\r\n          if (item && item.valor) {\r\n            let valorOpcional = String(item.valor).replace(',', '.');\r\n            total += parseFloat(valorOpcional) || 0;\r\n          }\r\n        });\r\n      }\r\n      return total;\r\n    }\r\n  },\r\n  methods: {\r\n    formatarPreco(valor) {\r\n      if (!valor) return \"0.00\";\r\n      let num = parseFloat(String(valor).replace(',', '.'));\r\n      return isNaN(num) ? \"0.00\" : num.toFixed(2);\r\n    },\r\n\r\n    // Função para disparar os alertas semânticos em tela\r\n    mostrarAlerta(mensagem, tipo = \"info\") {\r\n      this.alerta.mensagem = mensaje;\r\n      this.alerta.tipo = tipo;\r\n      this.alerta.visivel = true;\r\n      \r\n      // Auto-oculta o alerta após 3.5 segundos\r\n      setTimeout(() => {\r\n        this.alerta.visivel = false;\r\n      }, 3500);\r\n    },\r\n\r\n    async carregarDadosCustomizacao() {\r\n      try {\r\n        const resPontos = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n        const todosPontos = await resPontos.json();\r\n\r\n        const resOpcionais = await fetch(\"http://localhost:3000/opcionais\");\r\n        const dadosOpcionais = await resOpcionais.json();\r\n        const todosOpcionais = dadosOpcionais.complemento || [];\r\n\r\n        if (this.produto && this.produto.categoria === \"lanches\") {\r\n          this.listaPontos = [];\r\n          this.pontoSelecionado = \"padrao\";\r\n          const itensParaEvitar = [\"Chantilly\", \"Canela em pó\", \"Xarope de Baunilha\", \"Calda de Caramelo Extra\", \"Dose Dupla de Espresso\"];\r\n          this.listaOpcionais = todosOpcionais.filter(item => !itensParaEvitar.includes(item.nome));\r\n          \r\n          this.mostrarAlerta(\"Carregando opções artesanais para o seu lanche.\", \"info\");\r\n        } else {\r\n          this.listaPontos = todosPontos;\r\n          if (this.listaPontos.length > 0) {\r\n            this.pontoSelecionado = this.listaPontos[0].id;\r\n          }\r\n          this.listaOpcionais = todosOpcionais;\r\n          \r\n          this.mostrarAlerta(\"Personalize o tamanho e adicionais do seu café.\", \"info\");\r\n        }\r\n      } catch (error) {\r\n        this.mostrarAlerta(\"Falha de comunicação com o servidor ao carregar adicionais.\", \"erro\");\r\n      }\r\n    },\r\n\r\n    async enviarParaCarrinho() {\r\n      this.exibindoErros = true;\r\n\r\n      // Executa a validação de integridade de dados antes do POST\r\n      if (!this.formValido) {\r\n        if (!this.nomeCliente.trim()) {\r\n          this.mostrarAlerta(\"Preenchimento obrigatório: Digite o Nome do Cliente.\", \"erro\");\r\n        } else {\r\n          this.mostrarAlerta(\"Escolha uma opção de tamanho base antes de continuar.\", \"aviso\");\r\n        }\r\n        return;\r\n      }\r\n\r\n      const opcionaisDetalhados = this.opcionaisSelecionados.map(id => {\r\n        return this.listaOpcionais.find(o => o.id === id);\r\n      });\r\n\r\n      let textoPonto = \"Tamanho Único\";\r\n      if (this.produto.categoria !== \"lanches\") {\r\n        const pontoEscolhido = this.listaPontos.find(p => p.id === this.pontoSelecionado);\r\n        textoPonto = pontoEscolhido ? pontoEscolhido.descricao : \"\";\r\n      }\r\n\r\n      const pedidoPayload = {\r\n        cliente: this.nomeCliente.trim(),\r\n        nome_cafe: this.produto.nome,\r\n        foto_cafe: this.produto.foto,\r\n        valor_total: this.valorTotal.toFixed(2),\r\n        ponto: textoPonto,\r\n        opcionais: opcionaisDetalhados,\r\n        status: \"Em preparação\"\r\n      };\r\n\r\n      try {\r\n        const response = await fetch(\"http://localhost:3000/pedidos\", {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify(pedidoPayload)\r\n        });\r\n\r\n        if (response.ok) {\r\n          this.mostrarAlerta(\"Item adicionado com sucesso! Redirecionando...\", \"sucesso\");\r\n          setTimeout(() => {\r\n            this.$router.push(\"/pedidos\");\r\n          }, 1500);\r\n        } else {\r\n          this.mostrarAlerta(\"Não foi possível registrar seu pedido. Tente novamente.\", \"erro\");\r\n        }\r\n      } catch (error) {\r\n        this.mostrarAlerta(\"Erro de rede. Verifique se o banco de dados está online.\", \"erro\");\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    const query = this.$route.query;\r\n    if (query.produto) {\r\n      try {\r\n        this.produto = JSON.parse(decodeURIComponent(query.produto));\r\n      } catch (e) {\r\n        console.error(e);\r\n      }\r\n    }\r\n    this.carregarDadosCustomizacao();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* COMPONENTE DE ALERTA SEMÂNTICO (NOTIFICAÇÃO EM TELA) */\r\n.custom-alert {\r\n  position: fixed;\r\n  top: 100px;\r\n  right: 20px;\r\n  z-index: 9999;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  padding: 16px 24px;\r\n  border-radius: 12px;\r\n  color: #ffffff;\r\n  font-weight: 600;\r\n  font-size: 14px;\r\n  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\r\n  min-width: 300px;\r\n  max-width: 450px;\r\n}\r\n\r\n/* Paleta Semântica */\r\n.custom-alert.erro { background-color: #d93838; }      /* Vermelho */\r\n.custom-alert.aviso { background-color: #e67e22; }     /* Laranja */\r\n.custom-alert.info { background-color: #2980b9; }      /* Azul */\r\n.custom-alert.sucesso { background-color: #27ae60; }   /* Verde */\r\n\r\n/* Campo do Cliente */\r\n.input-cliente {\r\n  width: 100%;\r\n  padding: 14px 18px;\r\n  border-radius: 12px;\r\n  border: 1px solid rgba(43, 27, 18, 0.2);\r\n  font-size: 15px;\r\n  background-color: #ffffff;\r\n  color: #2b1b12;\r\n  outline: none;\r\n  transition: border-color 0.2s;\r\n  box-sizing: border-box;\r\n}\r\n.input-cliente:focus {\r\n  border-color: #2b1b12;\r\n}\r\n.input-cliente.input-error {\r\n  border-color: #d93838;\r\n  background-color: #fff5f5;\r\n}\r\n.error-text {\r\n  color: #d93838;\r\n  font-size: 12px;\r\n  margin-top: 6px;\r\n  display: block;\r\n}\r\n.required {\r\n  color: #d93838;\r\n}\r\n\r\n/* Estados de Bloqueio do Botão */\r\n.btn-disabled {\r\n  opacity: 0.6;\r\n  cursor: not-allowed !important;\r\n  background-color: #7f7f7f !important;\r\n}\r\n\r\n/* Transições do Alerta */\r\n.toast-fade-enter-active, .toast-fade-leave-active {\r\n  transition: all 0.3s ease;\r\n}\r\n.toast-fade-enter {\r\n  transform: translateX(50px);\r\n  opacity: 0;\r\n}\r\n.toast-fade-leave-to {\r\n  transform